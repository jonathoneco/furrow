  require_state "$_vwtsub_name" > /dev/null

  if ! validate_worktree_summary "$_vwtsub_name"; then
    exit 1
  fi

  echo "Worktree summary valid."
}

# ============================================================
#  Subcommand: add-user-action
# ============================================================

add_user_action() {
  _aua_name="$1"
  _aua_id="$2"
  _aua_instructions="$3"

  _aua_state_file="$(require_state "$_aua_name")"

  # Validate id format
  if ! echo "$_aua_id" | grep -qE '^[a-z0-9-]+$'; then
    echo "Invalid user action id: '$_aua_id'. Must match ^[a-z0-9-]+$." >&2
    exit "$EXIT_VALIDATION"
  fi

  # Check for duplicate id
  _aua_existing="$(jq -r --arg id "$_aua_id" '.pending_user_actions // [] | .[] | select(.id == $id) | .id' "$_aua_state_file" 2>/dev/null)" || _aua_existing=""
  if [ -n "$_aua_existing" ]; then
    echo "User action already exists: '$_aua_id'" >&2
    exit "$EXIT_VALIDATION"
  fi

  # Build record and append
  _aua_now="$(now_iso)"
  _aua_record="$(jq -n \
    --arg id "$_aua_id" \
    --arg instructions "$_aua_instructions" \
    --arg created_at "$_aua_now" \
    '{id: $id, instructions: $instructions, created_at: $created_at, completed_at: null}'
  )"

  update_state "$_aua_name" ".pending_user_actions = (.pending_user_actions // []) + [$_aua_record]" > /dev/null
  echo "User action added: $_aua_id"
}

rws_add_user_action() {
  if [ "$#" -lt 3 ]; then
    echo "Usage: rws add-user-action [name] <id> <instructions>" >&2
    exit "$EXIT_USAGE"
  fi

  # Resolve optional name argument
  if [ "$#" -ge 3 ]; then
    # Check if first arg looks like a row name (no spaces, kebab) vs an action id
    # Strategy: if there are exactly 3 args, check if first is an existing row
    _auar_candidate="$1"
    _auar_state="$(resolve_state_file "$_auar_candidate")"
    if [ -f "$_auar_state" ]; then
      _auar_name="$1"
      _auar_id="$2"
      _auar_instructions="$3"
    else
      _auar_name="$(resolve_name "")"
      _auar_id="$1"
      _auar_instructions="$2"
    fi
  fi

  add_user_action "$_auar_name" "$_auar_id" "$_auar_instructions"
}

# ============================================================
#  Subcommand: complete-user-action
# ============================================================

complete_user_action() {
  _cua_name="$1"
  _cua_id="$2"

  _cua_state_file="$(require_state "$_cua_name")"

  # Check action exists
  _cua_existing="$(jq -r --arg id "$_cua_id" '.pending_user_actions // [] | .[] | select(.id == $id) | .id' "$_cua_state_file" 2>/dev/null)" || _cua_existing=""
  if [ -z "$_cua_existing" ]; then
    echo "User action not found: '$_cua_id'" >&2
    exit "$EXIT_VALIDATION"
  fi

  # Set completed_at
  _cua_now="$(now_iso)"
  update_state "$_cua_name" ".pending_user_actions |= map(if .id == \"$_cua_id\" then .completed_at = \"$_cua_now\" else . end)" > /dev/null
  echo "User action completed: $_cua_id"
}

rws_complete_user_action() {
  if [ "$#" -lt 2 ]; then
    echo "Usage: rws complete-user-action [name] <id>" >&2
    exit "$EXIT_USAGE"
  fi

  # Resolve optional name
  if [ "$#" -ge 2 ]; then
    _cuar_candidate="$1"
    _cuar_state="$(resolve_state_file "$_cuar_candidate")"
    if [ -f "$_cuar_state" ]; then
      _cuar_name="$1"
      _cuar_id="$2"
    else
      _cuar_name="$(resolve_name "")"
      _cuar_id="$1"
    fi
  fi

  complete_user_action "$_cuar_name" "$_cuar_id"
}

# ============================================================
#  Subcommand: list-user-actions
# ============================================================

list_user_actions() {
  _lua_name="$1"
  _lua_state_file="$(require_state "$_lua_name")"

  _lua_count="$(jq -r '.pending_user_actions // [] | length' "$_lua_state_file" 2>/dev/null)" || _lua_count=0
  if [ "$_lua_count" -eq 0 ]; then
    echo "No user actions."
    return 0
  fi

  jq -r '.pending_user_actions[] | if .completed_at then "[DONE] " + .id + " — " + .instructions else "[PENDING] " + .id + " — " + .instructions end' "$_lua_state_file"
}

rws_list_user_actions() {
  _luar_name="$(resolve_name "${1:-}")"
  list_user_actions "$_luar_name"
}

# ============================================================
#  validate_reintegration_json — jq-based schema check
#  Returns 0 (valid) or 3 (invalid). Prints errors to stderr.
# ============================================================

validate_reintegration_json() {
  _vrj_file="$1"
  if [ ! -f "$_vrj_file" ]; then
    echo "reintegration.json not found: $_vrj_file" >&2
    return 2
  fi

  _vrj_schema="${FURROW_ROOT}/schemas/reintegration.schema.json"
  if [ ! -f "$_vrj_schema" ]; then
    printf 'reintegration.json schema not found: %s\n' "$_vrj_schema" >&2
    return 3
  fi

  # Pre-check: must be parseable JSON before we hand it to jsonschema.
  if ! jq -e . "$_vrj_file" >/dev/null 2>&1; then
    printf 'reintegration.json is not valid JSON: %s\n' "$_vrj_file" >&2
    return 3
  fi

  # Full jsonschema validation via Python (Draft 2020-12, matches
  # validate-definition.sh pattern). Catches additionalProperties, enum,
  # pattern, type, and const constraints that a grep/jq check can't express.
  if ! command -v python3 >/dev/null 2>&1; then
    printf 'reintegration.json validation requires python3\n' >&2
    return 3
  fi

  _vrj_errors="$(python3 -c '
import json, sys
try:
    from jsonschema import Draft202012Validator
except ImportError:
    print("jsonschema not installed (need >=4.0)", file=sys.stderr)
    sys.exit(2)
with open(sys.argv[1]) as f:
    schema = json.load(f)
with open(sys.argv[2]) as f:
    instance = json.load(f)
validator = Draft202012Validator(schema)
errs = sorted(validator.iter_errors(instance), key=lambda e: list(e.path))
for e in errs:
    path = ".".join(str(p) for p in e.absolute_path) or "(root)"
    print(f"Schema error at {path}: {e.message}")
' "$_vrj_schema" "$_vrj_file" 2>&1)"
  _vrj_py_exit=$?

  # python3 exit semantics here: 0 = ran ok (errors, if any, in stdout);
  # 1 = typical SystemExit/traceback; 2 = our custom "jsonschema missing".
  # Anything non-zero means we can't trust stdout — treat as validation failure.
  if [ "$_vrj_py_exit" -ne 0 ]; then
    printf '%s\n' "$_vrj_errors" >&2
    return 3
  fi

  if [ -n "$_vrj_errors" ]; then
    printf 'reintegration.json schema validation failed:\n%s\n' "$_vrj_errors" >&2
    return 3
  fi
  return 0
}

# ============================================================
#  Subcommand: generate-reintegration
# ============================================================

rws_generate_reintegration() {
  _gr_name="$(resolve_name "${1:-}")"
  require_state "$_gr_name" > /dev/null

  _gr_script="${FURROW_ROOT}/bin/frw.d/scripts/generate-reintegration.sh"
  if [ ! -x "$_gr_script" ]; then
    echo "generate-reintegration: helper script not found or not executable: $_gr_script" >&2
    exit "$EXIT_NOT_FOUND"
  fi

  "$_gr_script" "$_gr_name" "$FURROW_ROOT"
  _gr_exit=$?
  if [ "$_gr_exit" -ne 0 ]; then
    exit "$_gr_exit"
  fi

  # Bump state.json timestamp
  update_state "$_gr_name" "." > /dev/null 2>&1 || true
}

# ============================================================
#  Subcommand: get-reintegration-json
# ============================================================

rws_get_reintegration_json() {
  _grj_name="$(resolve_name "${1:-}")"
  require_state "$_grj_name" > /dev/null

  _grj_work_dir="$(resolve_row_dir "$_grj_name")"
  _grj_file="${_grj_work_dir}/reintegration.json"

  if [ ! -f "$_grj_file" ]; then
    printf 'reintegration.json not found for row '\''%s'\''. Run: rws generate-reintegration %s\n' \
      "$_grj_name" "$_grj_name" >&2
    exit "$EXIT_NOT_FOUND"
  fi

  # Validate before returning
  if ! validate_reintegration_json "$_grj_file"; then
    exit "$EXIT_VALIDATION"
  fi

  cat "$_grj_file"
}

# ============================================================
#  Subcommand: validate-sort-invariant
# ============================================================

rws_validate_sort_invariant() {
  _vsi_file=""
  _vsi_key=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --file)
        [ $# -ge 2 ] || { printf 'rws: validate-sort-invariant: --file requires a path\n' >&2; exit 2; }
        _vsi_file="$2"
        shift 2
        ;;
      --key)
        [ $# -ge 2 ] || { printf 'rws: validate-sort-invariant: --key requires an expression\n' >&2; exit 2; }
        _vsi_key="$2"
        shift 2
        ;;
      *)
        printf 'rws: validate-sort-invariant: unknown argument: %s\n' "$1" >&2
        exit 2
        ;;
    esac
  done

  # Default key expression
  _vsi_default_key='[.created_at // "", .id // ""]'
  [ -n "$_vsi_key" ] || _vsi_key="$_vsi_default_key"

  _vsi_exit=0

  if [ -n "$_vsi_file" ]; then
    # Single-file mode
    _vsi_check_file "$_vsi_file" "$_vsi_key" || _vsi_exit=$?
  else
    # Default: check both seeds.jsonl and todos.yaml
    _seeds=".furrow/seeds/seeds.jsonl"
    _todos=".furrow/almanac/todos.yaml"

    if [ -f "$_seeds" ]; then
      _vsi_check_file "$_seeds" "$_vsi_default_key" || _vsi_exit=$?
    fi
    if [ -f "$_todos" ]; then
      _vsi_check_todos "$_todos" "$_vsi_default_key" || _vsi_exit=$?
    fi
  fi

  return $_vsi_exit
}

# _vsi_check_file: check seeds.jsonl sort invariant (no mutation)
_vsi_check_file() {
  _cf_path="$1"
  _cf_key="$2"

  if [ ! -f "$_cf_path" ]; then
    printf '[furrow:error] validate-sort-invariant: file not found: %s\n' "$_cf_path" >&2
    return 2
  fi

  # Determine if it's a JSONL or YAML file
  case "$_cf_path" in
    *.yaml|*.yml)
      _vsi_check_todos "$_cf_path" "$_cf_key"
      return $?
      ;;
  esac

  # JSONL file: sort in-memory and diff
  _cf_tmp_keys=$(mktemp)
  _cf_tmp_sorted=$(mktemp)
  # shellcheck disable=SC2064
  trap "rm -f '$_cf_tmp_keys' '$_cf_tmp_sorted'" EXIT INT TERM

  _cf_linenum=0
  _cf_err=0
  while IFS= read -r _cf_line || [ -n "$_cf_line" ]; do
    case "$_cf_line" in
      '') continue ;;
    esac
    _cf_linenum=$((_cf_linenum + 1))
    _cf_key_val=$(printf '%s\n' "$_cf_line" | LC_ALL=C jq -r "($_cf_key) | @tsv" 2>/dev/null) || {
      printf '[furrow:error] validate-sort-invariant: invalid JSON at line %d of %s\n' "$_cf_linenum" "$_cf_path" >&2
      _cf_err=1
      break
    }
    printf '%s\t%d\t%s\n' "$_cf_key_val" "$_cf_linenum" "$_cf_line" >> "$_cf_tmp_keys"
  done < "$_cf_path"

  if [ "$_cf_err" -ne 0 ]; then
    rm -f "$_cf_tmp_keys" "$_cf_tmp_sorted"
    trap - EXIT INT TERM
    return 2
  fi

  if [ ! -s "$_cf_tmp_keys" ]; then
    rm -f "$_cf_tmp_keys" "$_cf_tmp_sorted"
    trap - EXIT INT TERM
    return 0
  fi

  # Produce sorted version
  LC_ALL=C sort -t "$(printf '\t')" -k1,1 -k2,2 -k3,3n "$_cf_tmp_keys" | \
    cut -f4- > "$_cf_tmp_sorted"

  # Compare: sorted version vs on-disk (non-empty lines only)
  _cf_disk=$(grep -v '^$' "$_cf_path" 2>/dev/null || true)
  _cf_sorted_content=$(cat "$_cf_tmp_sorted" 2>/dev/null || true)

  rm -f "$_cf_tmp_keys" "$_cf_tmp_sorted"
  trap - EXIT INT TERM

  if [ "$_cf_disk" = "$_cf_sorted_content" ]; then
    return 0
  fi

  # Find first out-of-order pair by comparing line by line
  _cf_first_bad=0
  _cf_n=0
  while IFS= read -r _cf_sorted_line; do
    _cf_n=$((_cf_n + 1))
    _cf_disk_line=$(printf '%s\n' "$_cf_disk" | sed -n "${_cf_n}p")
    if [ "$_cf_sorted_line" != "$_cf_disk_line" ]; then
      _cf_first_bad=$_cf_n
      break
    fi
  done << EOF
$(printf '%s\n' "$_cf_sorted_content")
EOF

  printf '[furrow:error] sort-invariant violated on %s: first out-of-order pair at line %d\n' \
    "$_cf_path" "$_cf_first_bad" >&2
  return 3
}

# _vsi_check_todos: check todos.yaml sort invariant (no mutation)
_vsi_check_todos() {
  _ct_path="$1"
  _ct_key="$2"  # not used for yq — always .created_at, .id

  if [ ! -f "$_ct_path" ]; then
    printf '[furrow:error] validate-sort-invariant: file not found: %s\n' "$_ct_path" >&2
    return 2
  fi

  if ! command -v yq >/dev/null 2>&1; then
    printf '[furrow:error] validate-sort-invariant: yq required for YAML files\n' >&2
    return 2
  fi

  _ct_tmp_sorted=$(mktemp)
  _ct_tmp_disk=$(mktemp)
  # shellcheck disable=SC2064
  trap "rm -f '$_ct_tmp_sorted' '$_ct_tmp_disk'" EXIT INT TERM

  # Get normalized form of on-disk file
  LC_ALL=C yq -o=yaml '.' "$_ct_path" > "$_ct_tmp_disk" 2>/dev/null || {
    printf '[furrow:error] validate-sort-invariant: failed to parse %s\n' "$_ct_path" >&2
    rm -f "$_ct_tmp_sorted" "$_ct_tmp_disk"
    trap - EXIT INT TERM
    return 2
  }

  # Get sorted form
  LC_ALL=C yq -o=yaml 'sort_by(.created_at, .id)' "$_ct_path" > "$_ct_tmp_sorted" 2>/dev/null || {
    printf '[furrow:error] validate-sort-invariant: yq sort failed on %s\n' "$_ct_path" >&2
    rm -f "$_ct_tmp_sorted" "$_ct_tmp_disk"
    trap - EXIT INT TERM
    return 2
  }

  # Compare
  if cmp -s "$_ct_tmp_disk" "$_ct_tmp_sorted"; then
    rm -f "$_ct_tmp_sorted" "$_ct_tmp_disk"
    trap - EXIT INT TERM
    return 0
  fi

  # Find first diff line
  _ct_first_bad=$(diff "$_ct_tmp_disk" "$_ct_tmp_sorted" | grep '^[0-9]' | head -1 | sed 's/[^0-9].*//')

  rm -f "$_ct_tmp_sorted" "$_ct_tmp_disk"
  trap - EXIT INT TERM

  printf '[furrow:error] sort-invariant violated on %s: first out-of-order pair at line %s\n' \
    "$_ct_path" "${_ct_first_bad:-unknown}" >&2
  return 3
}

# ============================================================
#  Subcommand: help
# ============================================================

rws_help() {
  cat << 'EOF'
rws — row lifecycle management

Usage: rws <command> [args...]

Commands:
  init <name> [opts]                     Initialize a new row
    --title T                            Human-readable title
    --mode code|research                 Work mode (default: from furrow.yaml)
    --gate-policy supervised|delegated|autonomous
    --source-todo ID                     TODO entry this row was created from
    --seed-id ID                         Pre-existing seed ID to link

  transition <name> <outcome> <decided_by> <evidence> [conditions]
                                         Record gate, validate, and advance step

  status [name]                          Show row status (default: focused row)
  list [--active|--archived|--all]       List rows (default: --active)
  complete-deliverable [name] <deliverable>
                                         Mark a deliverable as completed
  complete-step [name]                   Mark the current step as completed
  archive <name>                         Archive a completed row

  add-user-action [name] <id> <instructions>
                                         Declare a user action that must be completed
  complete-user-action [name] <id>       Mark a user action as completed
  list-user-actions [name]               List user actions with [PENDING]/[DONE] status

  gate-check <step> <def_path> <state_path>
                                         Structural pre-filter for gate evaluation
  rewind <name> <target_step>            Rewind to a previous step
  diff [name]                            Show git diff since base commit
  focus [name|--clear]                   Compatibility wrapper for furrow row focus
  regenerate-summary [name]              Regenerate summary.md skeleton
  validate-summary [name] [--step S]     Validate summary.md sections
  update-summary [name] <section> [--replace]
                                         Update an agent-written summary section
  regenerate-worktree-summary [name]     Regenerate worktree-summary.md skeleton
  validate-worktree-summary [name]       Validate worktree-summary.md sections
  update-worktree-summary [name] <section> [--replace]
                                         Update an agent-written worktree-summary section

  validate-sort-invariant [--file <path>] [--key <key-expr>]
                                         Verify sort invariant on seeds.jsonl / todos.yaml
                                         Exit 0 = sorted; exit 3 = out-of-order; no mutation

  generate-reintegration [name]          Build reintegration.json + render ## Reintegration
                                         section in summary.md from git log + state + reviews.
                                         Exit 0 success; 2 row not found; 3 schema failed; 4 subprocess.
  get-reintegration-json [name]          Emit reintegration.json verbatim (primary read path
                                         for /furrow:merge). Exit 2 if missing; 3 if schema invalid.

  help                                   Show this help message

Exit codes:
  0  Success
  1  Usage / argument error
  2  State file not found
  3  Validation failed
  4  Sub-operation failed
  5  Wrong step_status
  6  Policy violation
  7  Seed mismatch
EOF
}

# ============================================================
#  Main dispatch
# ============================================================

cmd="${1:-help}"
[ $# -gt 0 ] && shift

case "$cmd" in
  init)               rws_init "$@" ;;
  transition)         rws_transition "$@" ;;
  status)             rws_exec_furrow row status "$@" ;;
  list)               rws_list_compat "$@" ;;
  complete-deliverable) rws_complete_deliverable "$@" ;;
  complete-step)      rws_complete_step "$@" ;;
  add-user-action)    rws_add_user_action "$@" ;;
  complete-user-action) rws_complete_user_action "$@" ;;
  list-user-actions)  rws_list_user_actions "$@" ;;
  archive)            rws_archive "$@" ;;
  gate-check)         rws_gate_check "$@" ;;
  rewind)             rws_rewind "$@" ;;
  diff)               rws_diff "$@" ;;
  repair-deliverables)
    rws_exec_furrow row repair-deliverables "$@"
    ;;
  focus)              rws_exec_furrow row focus "$@" ;;
  regenerate-summary) rws_regenerate_summary "$@" ;;
  validate-summary)   rws_validate_summary "$@" ;;
  update-summary)     rws_update_summary "$@" ;;
  regenerate-worktree-summary) rws_regenerate_worktree_summary "$@" ;;
  validate-worktree-summary)   rws_validate_worktree_summary "$@" ;;
  update-worktree-summary)     rws_update_worktree_summary "$@" ;;
  validate-sort-invariant)     rws_validate_sort_invariant "$@" ;;
  generate-reintegration)      rws_generate_reintegration "$@" ;;
  get-reintegration-json)      rws_get_reintegration_json "$@" ;;
  gate-policy)        rws_gate_policy "$@" ;;
  help|--help|-h)     rws_help ;;
  *)                  echo "Unknown command: $cmd" >&2; rws_help >&2; exit 1 ;;
esac
