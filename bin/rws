#!/bin/sh
# rws — row lifecycle management CLI
# Monolithic POSIX shell + jq script for Furrow row operations.
# Requires: jq. Optional: yq (for definition.yaml parsing).
set -eu

# --- Furrow root resolution ---

SCRIPT_PATH="$(readlink -f "$0")"
FURROW_ROOT="$(cd "$(dirname "$SCRIPT_PATH")" && cd .. && pwd)"

# PROJECT_ROOT defaults to cwd (the project using this rws); required by the
# three-tier config resolver in common.sh. Callers may override by exporting.
PROJECT_ROOT="${PROJECT_ROOT:-$(pwd)}"
export PROJECT_ROOT FURROW_ROOT

# Source shared library (provides extract_md_section, replace_md_section, etc.)
_RWS_LIB="${FURROW_ROOT}/bin/frw.d/lib/common.sh"
if [ -f "$_RWS_LIB" ]; then
  # shellcheck source=bin/frw.d/lib/common.sh
  . "$_RWS_LIB"
fi
unset _RWS_LIB

# --- Exit codes ---

EXIT_SUCCESS=0
EXIT_USAGE=1
EXIT_NOT_FOUND=2
EXIT_VALIDATION=3
EXIT_SUB_FAILED=4
# shellcheck disable=SC2034 # Reserved for compatibility with older callers.
EXIT_WRONG_STATUS=5
EXIT_POLICY=6
# shellcheck disable=SC2034 # Reserved for compatibility with older callers.
EXIT_SEED_MISMATCH=7

# --- Constants ---

VALID_STEPS="ideate research plan spec decompose implement review"
ROWS_DIR=".furrow/rows"
FOCUSED_FILE=".furrow/.focused"
FURROW_YAML=".claude/furrow.yaml"

# ============================================================
#  Internal helpers
# ============================================================

die() { printf 'rws: %s\n' "$*" >&2; exit "$EXIT_USAGE"; }

rws_exec_furrow() {
  if command -v furrow >/dev/null 2>&1; then
    exec furrow "$@"
  fi
  cd "${PROJECT_ROOT:-$FURROW_ROOT}" || exit "$EXIT_SUB_FAILED"
  exec go run "${FURROW_ROOT}/cmd/furrow" "$@"
}

rws_list_compat() {
  if [ $# -eq 0 ]; then
    rws_exec_furrow row list --active
  fi
  rws_exec_furrow row list "$@"
}

now_iso() { date -u '+%Y-%m-%dT%H:%M:%SZ'; }

is_valid_step() {
  for _s in ${VALID_STEPS}; do
    [ "$_s" = "$1" ] && return 0
  done
  return 1
}

step_index() {
  _idx=0
  for _s in ${VALID_STEPS}; do
    [ "$_s" = "$1" ] && { echo "$_idx"; return 0; }
    _idx=$((_idx + 1))
  done
  echo "-1"
}

validate_kebab() {
  echo "$1" | grep -qE '^[a-z][a-z0-9]*(-[a-z0-9]+)*$'
}

resolve_row_dir() {
  echo "${ROWS_DIR}/$1"
}

step_to_seed_status() {
  case "$1" in
    ideate)    echo "ideating" ;;
    research)  echo "researching" ;;
    plan)      echo "planning" ;;
    spec)      echo "speccing" ;;
    decompose) echo "decomposing" ;;
    implement) echo "implementing" ;;
    review)    echo "reviewing" ;;
    *)         echo "" ;;
  esac
}

sync_seed_status() {
  _sss_name="$1"
  _sss_step="$2"
  _sss_state_file="$(resolve_state_file "$_sss_name")"
  _sss_seed_id="$(jq -r '.seed_id // ""' "$_sss_state_file" 2>/dev/null)" || _sss_seed_id=""

  if [ -z "$_sss_seed_id" ] || [ "$_sss_seed_id" = "null" ]; then
    return 0
  fi

  _sss_seed_status="$(step_to_seed_status "$_sss_step")"
  if [ -z "$_sss_seed_status" ]; then
    return 0
  fi

  if command -v sds > /dev/null 2>&1; then
    sds update "$_sss_seed_id" --status "$_sss_seed_status" 2>/dev/null || \
      echo "Warning: failed to sync seed status to $_sss_seed_status" >&2
  fi
}

resolve_state_file() {
  echo "${ROWS_DIR}/$1/state.json"
}

require_state() {
  _sf="$(resolve_state_file "$1")"
  if [ ! -f "$_sf" ]; then
    echo "State file not found: $_sf" >&2
    exit "$EXIT_NOT_FOUND"
  fi
  echo "$_sf"
}

read_gate_policy() {
  # Canonical resolver chain (project .furrow/furrow.yaml → XDG → compiled-in).
  # Per the xdg-config-consumer-wiring contract we use resolve_config_value;
  # the hardcoded "supervised" fallback only applies when all three tiers miss.
  # Row-local overrides still work because the project tier is the first hit.
  if _rgp_val="$(resolve_config_value gate_policy)"; then
    printf '%s\n' "$_rgp_val"
  else
    echo "supervised"
  fi
}

# rws_gate_policy [<row>] — print the resolved gate_policy for a row.
# Row argument is currently informational: gate_policy resolves through the
# config chain, not from the row's definition.yaml. Accepted for
# forward-compatibility and scripting convenience.
rws_gate_policy() {
  read_gate_policy "${1:-}"
}

# ============================================================
#  find_focused_row — .furrow/.focused resolution
# ============================================================

find_focused_row() {
  # Try .focused file first
  if [ -f "$FOCUSED_FILE" ]; then
    _focused_name="$(cat "$FOCUSED_FILE" 2>/dev/null)" || _focused_name=""
    if [ -n "$_focused_name" ] && [ -f "${ROWS_DIR}/${_focused_name}/state.json" ]; then
      # Fail-open: jq failure treats row as not archived
      _archived="$(jq -r '.archived_at // "null"' "${ROWS_DIR}/${_focused_name}/state.json" 2>/dev/null)" || _archived="null"
      if [ "$_archived" = "null" ]; then
        echo "$_focused_name"
        return 0
      fi
    fi
    echo "[furrow:warning] Stale .focused file (row: ${_focused_name:-empty}), falling back" >&2
  fi

  # Fallback: most recently updated active row
  _best_name=""
  _best_ts=""

  for _state_file in "${ROWS_DIR}"/*/state.json; do
    [ -f "$_state_file" ] || continue
    _archived="$(jq -r '.archived_at // "null"' "$_state_file" 2>/dev/null)" || continue
    if [ "$_archived" = "null" ]; then
      _name="$(jq -r '.name // ""' "$_state_file" 2>/dev/null)" || continue
      _updated="$(jq -r '.updated_at // ""' "$_state_file" 2>/dev/null)" || _updated=""
      if [ -z "$_best_name" ] || { [ -n "$_updated" ] && [ -n "$_best_ts" ] && [ "$(printf '%s\n%s\n' "$_best_ts" "$_updated" | sort | tail -n 1)" = "$_updated" ] && [ "$_updated" != "$_best_ts" ]; }; then
        _best_name="$_name"
        _best_ts="$_updated"
      fi
    fi
  done

  echo "$_best_name"
}

# ============================================================
#  find_active_rows — scan .furrow/rows/*/state.json
# ============================================================

find_active_rows() {
  _count=0
  for _state_file in "${ROWS_DIR}"/*/state.json; do
    [ -f "$_state_file" ] || continue
    _archived="$(jq -r '.archived_at // "null"' "$_state_file" 2>/dev/null)" || continue
    if [ "$_archived" = "null" ]; then
      _name="$(jq -r '.name // ""' "$_state_file" 2>/dev/null)" || continue
      if [ -n "$_name" ]; then
        echo "$_name"
        _count=$((_count + 1))
      fi
    fi
  done
  echo "$_count" >&2
}

# ============================================================
#  resolve_name — resolve row name from argument or focused row
# ============================================================

resolve_name() {
  _name="${1:-}"
  if [ -z "$_name" ]; then
    _name="$(find_focused_row)"
    if [ -z "$_name" ]; then
      echo "No row specified and no focused row found." >&2
      echo "Use 'rws list --active' to see active rows, or 'rws focus <name>' to set one." >&2
      exit "$EXIT_USAGE"
    fi
  fi
  echo "$_name"
}

# ============================================================
#  update_state — atomic jq mutation with timestamp
# ============================================================

update_state() {
  _us_name="$1"
  _us_jq_expr="$2"

  _us_state_file="$(resolve_state_file "$_us_name")"

  if [ ! -f "$_us_state_file" ]; then
    echo "State file not found: $_us_state_file" >&2
    return 2
  fi

  _us_now="$(now_iso)"
  _us_tmp="${_us_state_file}.tmp.$$"

  if ! jq --arg now "$_us_now" "${_us_jq_expr} | .updated_at = \$now" "$_us_state_file" > "$_us_tmp" 2>/dev/null; then
    rm -f "$_us_tmp"
    echo "Failed to apply jq expression: $_us_jq_expr" >&2
    return 4
  fi

  # --- schema validation via jq ---

  _us_valid="$(jq -r '
    def check_enum(val; allowed):
      if (val | type) != "string" then "type"
      elif ([val] | inside(allowed) | not) then "enum"
      else "ok"
      end;

    def check_nullable_string(val):
      if val == null then "ok"
      elif (val | type) == "string" then "ok"
      else "type"
      end;

    if .name == null then "missing:name"
    elif (.name | type) != "string" then "type:name"
    elif .title == null and (.title | type) != "string" then "type:title"
    elif (.description | type) != "string" then "type:description"
    elif check_enum(.step; ["ideate","research","plan","spec","decompose","implement","review"]) != "ok" then "invalid:step"
    elif check_enum(.step_status; ["not_started","in_progress","completed","blocked"]) != "ok" then "invalid:step_status"
    elif (.steps_sequence | type) != "array" then "type:steps_sequence"
    elif (.steps_sequence | length) != 7 then "length:steps_sequence"
    elif (.deliverables | type) != "object" then "type:deliverables"
    elif (.gates | type) != "array" then "type:gates"
    elif check_enum(.mode; ["code","research"]) != "ok" then "invalid:mode"
    elif (.base_commit | type) != "string" then "type:base_commit"
    elif (.created_at | type) != "string" then "type:created_at"
    elif (.updated_at | type) != "string" then "type:updated_at"
    elif check_nullable_string(.archived_at) != "ok" then "type:archived_at"
    elif check_nullable_string(.seed_id) != "ok" then "type:seed_id"
    elif check_nullable_string(.epic_seed_id) != "ok" then "type:epic_seed_id"
    elif check_nullable_string(.force_stop_at) != "ok" then "type:force_stop_at"
    elif check_nullable_string(.branch) != "ok" then "type:branch"
    else "ok"
    end
  ' "$_us_tmp" 2>/dev/null)" || _us_valid="parse_error"

  if [ "$_us_valid" != "ok" ]; then
    rm -f "$_us_tmp"
    echo "Schema validation failed: $_us_valid" >&2
    return 3
  fi

  # Validate deliverable entries
  _us_deliv="$(jq -r '
    [.deliverables | to_entries[] |
      if (.value | type) != "object" then "type:\(.key)"
      elif (.value.status | type) != "string" then "type:\(.key).status"
      elif ([.value.status] | inside(["not_started","in_progress","completed","blocked"]) | not) then "enum:\(.key).status"
      elif (.value.wave | type) != "number" then "type:\(.key).wave"
      elif (.value.corrections | type) != "number" then "type:\(.key).corrections"
      else empty
      end
    ] | if length == 0 then "ok" else .[0] end
  ' "$_us_tmp" 2>/dev/null)" || _us_deliv="ok"

  if [ "$_us_deliv" != "ok" ]; then
    rm -f "$_us_tmp"
    echo "Schema validation failed for deliverable: $_us_deliv" >&2
    return 3
  fi

  # Validate gate entries
  _us_gate="$(jq -r '
    def valid_step: . as $s | ["ideate","research","plan","spec","decompose","implement","review"] | index($s) != null;
    [.gates[] |
      if (.boundary | type) != "string" then "type:boundary"
      elif (.boundary | split("->") | length) != 2 then "format:boundary"
      elif (.boundary | split("->") | .[0] | valid_step | not) then "enum:boundary_from"
      elif (.boundary | split("->") | .[1] | valid_step | not) then "enum:boundary_to"
      elif ([.outcome] | inside(["pass","fail","conditional"]) | not) then "enum:outcome"
      elif ([.decided_by] | inside(["manual","evaluated","prechecked"]) | not) then "enum:decided_by"
      elif (.evidence | type) != "string" then "type:evidence"
      elif (.evidence | length) == 0 then "empty:evidence"
      elif (.timestamp | type) != "string" then "type:timestamp"
      elif .outcome == "conditional" and (.conditions | type) != "array" then "missing:conditions"
      elif .outcome != "conditional" and .conditions != null then "extra:conditions"
      else empty
      end
    ] | if length == 0 then "ok" else .[0] end
  ' "$_us_tmp" 2>/dev/null)" || _us_gate="ok"

  if [ "$_us_gate" != "ok" ]; then
    rm -f "$_us_tmp"
    echo "Schema validation failed for gate: $_us_gate" >&2
    return 3
  fi

  mv "$_us_tmp" "$_us_state_file"
  echo "State updated: $_us_state_file"
}

# ============================================================
#  record_gate — append to gates[]
# ============================================================

record_gate() {
  _rg_name="$1"
  _rg_boundary="$2"
  _rg_outcome="$3"
  _rg_decided_by="$4"
  _rg_evidence="$5"
  _rg_conditions="${6:-}"

  # Validate boundary format
  _rg_from="$(echo "$_rg_boundary" | sed -n 's/^\([a-z]*\)->.*/\1/p')"
  _rg_to="$(echo "$_rg_boundary" | sed -n 's/.*->\([a-z]*\)$/\1/p')"

  if [ -z "$_rg_from" ] || [ -z "$_rg_to" ]; then
    echo "Invalid boundary format: '$_rg_boundary'. Must be '{from}->{to}'." >&2
    return 3
  fi

  if ! is_valid_step "$_rg_from"; then
    echo "Invalid step in boundary: '$_rg_from' is not a valid step name." >&2
    return 3
  fi

  if ! is_valid_step "$_rg_to"; then
    echo "Invalid step in boundary: '$_rg_to' is not a valid step name." >&2
    return 3
  fi

  # Validate outcome
  case "$_rg_outcome" in
    pass|fail|conditional) ;;
    *)
      echo "Invalid outcome: '$_rg_outcome'. Must be 'pass', 'fail', or 'conditional'." >&2
      return 3
      ;;
  esac

  # Validate decided_by
  case "$_rg_decided_by" in
    manual|evaluated|prechecked) ;;
    *)
      echo "Invalid decided_by: '$_rg_decided_by'. Must be 'manual', 'evaluated', or 'prechecked'." >&2
      return 3
      ;;
  esac

  # Validate conditions
  if [ "$_rg_outcome" = "conditional" ]; then
    if [ -z "$_rg_conditions" ]; then
      echo "Conditional outcome requires conditions array" >&2
      return 3
    fi
    if ! echo "$_rg_conditions" | jq -e 'type == "array"' > /dev/null 2>&1; then
      echo "Conditions must be a JSON array of strings." >&2
      return 3
    fi
  fi

  if [ "$_rg_outcome" != "conditional" ] && [ -n "$_rg_conditions" ]; then
    echo "Conditions only valid for conditional outcome" >&2
    return 3
  fi

  # Build gate record
  _rg_now="$(now_iso)"

  if [ "$_rg_outcome" = "conditional" ]; then
    _rg_record="$(jq -n \
      --arg boundary "$_rg_boundary" \
      --arg outcome "$_rg_outcome" \
      --arg decided_by "$_rg_decided_by" \
      --arg evidence "$_rg_evidence" \
      --argjson conditions "$_rg_conditions" \
      --arg timestamp "$_rg_now" \
      '{
        boundary: $boundary,
        outcome: $outcome,
        decided_by: $decided_by,
        evidence: $evidence,
        conditions: $conditions,
        timestamp: $timestamp
      }'
    )"
  else
    _rg_record="$(jq -n \
      --arg boundary "$_rg_boundary" \
      --arg outcome "$_rg_outcome" \
      --arg decided_by "$_rg_decided_by" \
      --arg evidence "$_rg_evidence" \
      --arg timestamp "$_rg_now" \
      '{
        boundary: $boundary,
        outcome: $outcome,
        decided_by: $decided_by,
        evidence: $evidence,
        timestamp: $timestamp
      }'
    )"
  fi

  update_state "$_rg_name" ".gates += [$_rg_record]"
  echo "Gate recorded: $_rg_boundary ($_rg_outcome)"
}

# ============================================================
#  validate_step_artifacts — boundary artifact checks
# ============================================================

validate_step_artifacts() {
  _va_name="$1"
  _va_boundary="$2"

  _va_work_dir="$(resolve_row_dir "$_va_name")"
  _va_state_file="${_va_work_dir}/state.json"
  _va_def_file="${_va_work_dir}/definition.yaml"

  if [ ! -f "$_va_state_file" ]; then
    echo "State file not found: $_va_state_file" >&2
    return 2
  fi

  # Helper: count deliverables from definition.yaml
  _va_deliv_count() {
    if [ -f "$_va_def_file" ] && command -v yq > /dev/null 2>&1; then
      yq -r '.deliverables | length' "$_va_def_file" 2>/dev/null || echo "0"
    else
      echo "0"
    fi
  }

  case "$_va_boundary" in

    "ideate->research")
      if [ ! -f "$_va_def_file" ]; then
        echo "ideate->research: $_va_def_file not found" >&2
        return 3
      fi
      if [ ! -s "$_va_def_file" ]; then
        echo "ideate->research: $_va_def_file is empty" >&2
        return 3
      fi
      # Validate against schema if validation available
      if command -v frw > /dev/null 2>&1; then
        if ! frw validate-definition "$_va_def_file" > /dev/null 2>&1; then
          echo "ideate->research: $_va_def_file failed schema validation" >&2
          return 3
        fi
      fi
      ;;

    "research->plan")
      _va_research_file=""
      if [ -f "${_va_work_dir}/research.md" ]; then
        _va_research_file="${_va_work_dir}/research.md"
      elif [ -f "${_va_work_dir}/research/synthesis.md" ]; then
        _va_research_file="${_va_work_dir}/research/synthesis.md"
      fi

      if [ -z "$_va_research_file" ]; then
        echo "research->plan: neither ${_va_work_dir}/research.md nor ${_va_work_dir}/research/synthesis.md exists" >&2
        return 3
      fi
      if [ ! -s "$_va_research_file" ]; then
        echo "research->plan: $_va_research_file is empty" >&2
        return 3
      fi

      _va_headings="$(grep -c '^## ' "$_va_research_file" 2>/dev/null)" || _va_headings="0"
      if [ "$_va_headings" -eq 0 ]; then
        echo "research->plan: $_va_research_file contains no ## headings" >&2
        return 3
      fi
      ;;

    "plan->spec")
      _va_count="$(_va_deliv_count)"
      if [ "$_va_count" -gt 1 ]; then
        _va_plan_file="${_va_work_dir}/plan.json"
        if [ ! -f "$_va_plan_file" ]; then
          echo "plan->spec: $_va_plan_file required ($_va_count deliverables) but not found" >&2
          return 3
        fi
        if ! validate_plan_json "$_va_plan_file" "$_va_def_file"; then
          echo "plan->spec: $_va_plan_file failed validation" >&2
          return 3
        fi
      fi
      ;;

    "spec->decompose")
      _va_has_spec=0
      if [ -f "${_va_work_dir}/spec.md" ]; then
        _va_has_spec=1
      elif [ -d "${_va_work_dir}/specs" ]; then
        _va_md_count="$(find "${_va_work_dir}/specs" -maxdepth 1 -name '*.md' -type f 2>/dev/null | wc -l)" || _va_md_count="0"
        if [ "$_va_md_count" -gt 0 ]; then
          _va_has_spec=1
        fi
      fi

      if [ "$_va_has_spec" -eq 0 ]; then
        echo "spec->decompose: neither ${_va_work_dir}/spec.md nor ${_va_work_dir}/specs/*.md found" >&2
        return 3
      fi

      _va_count="$(_va_deliv_count)"
      if [ "$_va_count" -gt 1 ]; then
        if [ ! -d "${_va_work_dir}/specs" ]; then
          echo "spec->decompose: ${_va_work_dir}/specs/ directory required for $_va_count deliverables" >&2
          return 3
        fi
        _va_missing=""
        _va_del_tmp="$(mktemp)"
        yq -r '.deliverables[].name' "$_va_def_file" 2>/dev/null > "$_va_del_tmp" || true
        while IFS= read -r _va_del_name; do
          if [ ! -f "${_va_work_dir}/specs/${_va_del_name}.md" ]; then
            _va_missing="$_va_missing $_va_del_name"
          fi
        done < "$_va_del_tmp"
        rm -f "$_va_del_tmp"
        if [ -n "$_va_missing" ]; then
          echo "spec->decompose: missing spec files for deliverables:$_va_missing" >&2
          return 3
        fi
      fi
      ;;

    "decompose->implement")
      _va_plan_file="${_va_work_dir}/plan.json"
      if [ ! -f "$_va_plan_file" ]; then
        echo "decompose->implement: $_va_plan_file not found" >&2
        return 3
      fi
      if ! validate_plan_json "$_va_plan_file" "$_va_def_file"; then
        echo "decompose->implement: $_va_plan_file failed validation" >&2
        return 3
      fi

      _va_branch="$(jq -r '.branch // ""' "$_va_state_file" 2>/dev/null)" || _va_branch=""
      if [ -z "$_va_branch" ] || [ "$_va_branch" = "null" ]; then
        # Auto-detect or create branch
        create_work_branch "$_va_name" || {
          echo "decompose->implement: failed to create or detect work branch" >&2
          return 3
        }
      fi
      ;;

    "implement->review")
      _va_mode="$(jq -r '.mode' "$_va_state_file" 2>/dev/null)" || _va_mode=""

      if [ "$_va_mode" = "code" ]; then
        _va_base="$(jq -r '.base_commit' "$_va_state_file" 2>/dev/null)" || _va_base=""
        if [ -z "$_va_base" ] || [ "$_va_base" = "null" ]; then
          echo "implement->review: state.json 'base_commit' field is not set" >&2
          return 3
        fi
        _va_diff="$(git diff --stat "$_va_base"..HEAD 2>/dev/null)" || _va_diff=""
        if [ -z "$_va_diff" ]; then
          echo "implement->review: no changes detected since base commit $_va_base" >&2
          return 3
        fi
      elif [ "$_va_mode" = "research" ]; then
        if [ ! -d "${_va_work_dir}/deliverables" ]; then
          echo "implement->review: ${_va_work_dir}/deliverables/ directory not found" >&2
          return 3
        fi
        _va_ne_count=0
        for _va_f in "${_va_work_dir}"/deliverables/*; do
          [ -f "$_va_f" ] || continue
          if [ -s "$_va_f" ]; then
            _va_ne_count=$((_va_ne_count + 1))
          fi
        done
        if [ "$_va_ne_count" -eq 0 ]; then
          echo "implement->review: no non-empty files in ${_va_work_dir}/deliverables/" >&2
          return 3
        fi
      fi
      ;;

    "review->archive")
      if [ ! -d "${_va_work_dir}/reviews" ]; then
        echo "review->archive: ${_va_work_dir}/reviews/ directory not found" >&2
        return 3
      fi

      _va_del_names="$(jq -r '.deliverables | keys[]' "$_va_state_file" 2>/dev/null)" || _va_del_names=""
      if [ -z "$_va_del_names" ]; then
        echo "review->archive: no deliverables found in state.json" >&2
        return 3
      fi

      _va_del_tmp="$(mktemp)"
      printf '%s\n' "$_va_del_names" > "$_va_del_tmp"
      # shellcheck disable=SC2094 # The temp file is removed before returning on validation failures.
      while IFS= read -r _va_del_name; do
        _va_review_file="${_va_work_dir}/reviews/${_va_del_name}.json"
        if [ ! -f "$_va_review_file" ]; then
          rm -f "$_va_del_tmp"
          echo "review->archive: missing review file for deliverable '$_va_del_name'" >&2
          return 3
        fi
        _va_overall="$(jq -r '.overall' "$_va_review_file" 2>/dev/null)" || _va_overall=""
        if [ "$_va_overall" != "pass" ]; then
          rm -f "$_va_del_tmp"
          echo "review->archive: deliverable '$_va_del_name' review has overall='$_va_overall', expected 'pass'" >&2
          return 3
        fi
      done < "$_va_del_tmp"
      rm -f "$_va_del_tmp"
      ;;

    *)
      echo "Unknown boundary: $_va_boundary" >&2
      return 3
      ;;
  esac

  return 0
}

# ============================================================
#  validate_plan_json — plan structure validation
# ============================================================

validate_plan_json() {
  _vp_plan_path="$1"
  _vp_def_path="${2:-}"

  if [ ! -f "$_vp_plan_path" ]; then
    echo "File not found: $_vp_plan_path" >&2
    return 1
  fi

  _vp_errors=""

  # Validate wave number contiguity
  _vp_wave_valid="$(jq -r '
    [.waves[].wave] | sort |
    if length == 0 then "empty"
    elif .[0] != 1 then "must start at 1"
    else . as $arr |
      [range($arr | length - 1) | . as $i | if $arr[$i + 1] - $arr[$i] != 1 then "non-contiguous" else empty end] |
      if length > 0 then .[0] else "ok" end
    end
  ' "$_vp_plan_path" 2>/dev/null)" || _vp_wave_valid="error"

  case "$_vp_wave_valid" in
    ok) ;;
    empty) _vp_errors="${_vp_errors}Plan has no waves\n" ;;
    *) _vp_errors="${_vp_errors}Wave numbers: $_vp_wave_valid\n" ;;
  esac

  # Check all definition deliverables are covered
  if [ -n "$_vp_def_path" ] && [ -f "$_vp_def_path" ] && command -v yq > /dev/null 2>&1; then
    _vp_def_names="$(yq -r '.deliverables[].name' "$_vp_def_path" 2>/dev/null | sort)" || _vp_def_names=""
    _vp_plan_names="$(jq -r '[.waves[].deliverables[]] | .[]' "$_vp_plan_path" 2>/dev/null | sort)" || _vp_plan_names=""

    if [ -n "$_vp_def_names" ]; then
      for _vp_n in $_vp_def_names; do
        if ! echo "$_vp_plan_names" | grep -qx "$_vp_n"; then
          _vp_errors="${_vp_errors}Deliverable missing from plan: $_vp_n\n"
        fi
      done
    fi

    # Check dependency ordering
    _vp_dep_errors="$(jq -r --argjson def_json "$(yq -o=json '.' "$_vp_def_path" 2>/dev/null)" '
      . as $plan |
      [.waves[] | .wave as $w | .deliverables[] | {name: ., value: $w}] |
      from_entries as $wave_map |
      [$def_json.deliverables[] | select(.depends_on != null) |
        .name as $name | .depends_on[] |
        . as $dep |
        if ($wave_map[$name] // 0) <= ($wave_map[$dep] // 0) then
          "Dependency violation: \($name) (wave \($wave_map[$name])) depends on \($dep) (wave \($wave_map[$dep]))"
        else empty end
      ] | .[]
    ' "$_vp_plan_path" 2>/dev/null)" || _vp_dep_errors=""
    if [ -n "$_vp_dep_errors" ]; then
      _vp_errors="${_vp_errors}${_vp_dep_errors}\n"
    fi
  fi

  # Check file_ownership non-overlap within a wave
  _vp_overlap="$(jq -r '
    .waves[] | .wave as $w |
    [.assignments | to_entries[] | .value.file_ownership // [] | .[]] |
    group_by(.) | map(select(length > 1) | .[0]) |
    if length > 0 then
      "Overlapping file_ownership in wave \($w): \(join(", "))"
    else empty end
  ' "$_vp_plan_path" 2>/dev/null)" || _vp_overlap=""
  if [ -n "$_vp_overlap" ]; then
    _vp_errors="${_vp_errors}${_vp_overlap}\n"
  fi

  if [ -n "$_vp_errors" ]; then
    printf "%b" "$_vp_errors" >&2
    return 1
  fi
  return 0
}

# ============================================================
#  advance_step — step state machine
# ============================================================

advance_step() {
  _as_name="$1"
  _as_state_file="$(require_state "$_as_name")"

  _as_current="$(jq -r '.step' "$_as_state_file")"
  _as_current_idx="$(jq -r --arg step "$_as_current" '.steps_sequence | to_entries[] | select(.value == $step) | .key' "$_as_state_file")"
  _as_total="$(jq -r '.steps_sequence | length' "$_as_state_file")"
  _as_last=$((_as_total - 1))

  if [ "$_as_current_idx" -eq "$_as_last" ]; then
    echo "Cannot advance past final step 'review'. Use archive to complete the row." >&2
    return 3
  fi

  _as_next_idx=$((_as_current_idx + 1))
  _as_next="$(jq -r --argjson idx "$_as_next_idx" '.steps_sequence[$idx]' "$_as_state_file")"

  # Verify passing gate record exists
  _as_boundary="${_as_current}->${_as_next}"
  _as_gate_pass="$(jq -r --arg boundary "$_as_boundary" '
    [.gates[] | select(.boundary == $boundary and (.outcome == "pass" or .outcome == "conditional"))] | length
  ' "$_as_state_file")"

  if [ "$_as_gate_pass" -eq 0 ]; then
    echo "No passing gate record for boundary '$_as_boundary'." >&2
    return 4
  fi

  update_state "$_as_name" ".step = \"$_as_next\" | .step_status = \"not_started\""

  # Branch creation trigger at decompose->implement
  if [ "$_as_current" = "decompose" ] && [ "$_as_next" = "implement" ]; then
    # Re-read state after update
    _as_state_file="$(resolve_state_file "$_as_name")"
    _as_existing_branch="$(jq -r '.branch // ""' "$_as_state_file")"
    if [ -z "$_as_existing_branch" ] || [ "$_as_existing_branch" = "null" ]; then
      create_work_branch "$_as_name" || {
        echo "Warning: branch creation failed" >&2
      }
    fi
  fi

  echo "Advanced: $_as_current -> $_as_next"
}

# ============================================================
#  create_work_branch — create and checkout row branch
# ============================================================

create_work_branch() {
  _cwb_name="$1"
  _cwb_branch="work/${_cwb_name}"
  _cwb_state_file="$(resolve_state_file "$_cwb_name")"

  if [ ! -f "$_cwb_state_file" ]; then
    echo "State file not found: $_cwb_state_file" >&2
    return 2
  fi

  _cwb_current="$(git branch --show-current 2>/dev/null || true)"

  if [ -n "$_cwb_current" ] && echo "$_cwb_current" | grep -q '^work/'; then
    _cwb_branch="$_cwb_current"
    echo "Already on work branch: $_cwb_branch"
  elif git rev-parse --verify "$_cwb_branch" > /dev/null 2>&1; then
    git checkout "$_cwb_branch"
    echo "Checked out existing branch: $_cwb_branch"
  else
    git checkout -b "$_cwb_branch"
    echo "Created and checked out branch: $_cwb_branch"
  fi

  update_state "$_cwb_name" ".branch = \"$_cwb_branch\""
  echo "Branch recorded in state.json: $_cwb_branch"
}

# ============================================================
#  check_wave_conflicts — wave boundary conflict detection
# ============================================================

check_wave_conflicts() {
  _wc_name="$1"
  _wc_work_dir="$(resolve_row_dir "$_wc_name")"
  _wc_unplanned="${_wc_work_dir}/.unplanned_changes"
  _wc_plan="${_wc_work_dir}/plan.json"

  if [ ! -f "$_wc_unplanned" ] || [ ! -s "$_wc_unplanned" ]; then
    echo "No unplanned changes detected. Clean."
    return 0
  fi

  if [ ! -f "$_wc_plan" ]; then
    echo "Warning: plan.json not found. Cannot check ownership overlap." >&2
    echo "Unplanned changes exist but ownership cannot be verified."
    return 0
  fi

  _wc_conflicts=""

  while IFS= read -r _wc_changed_file; do
    [ -n "$_wc_changed_file" ] || continue

    _wc_owners="$(jq -r --arg file "$_wc_changed_file" '
      [.waves[].assignments | to_entries[] |
       select(.value.file_ownership != null) |
       select(.value.file_ownership[] as $glob |
         ($file | test($glob | gsub("\\*\\*"; ".*") | gsub("\\*"; "[^/]*")))
       ) |
       .key
      ] | unique | join(", ")
    ' "$_wc_plan" 2>/dev/null)" || _wc_owners=""

    if [ -n "$_wc_owners" ]; then
      _wc_conflicts="${_wc_conflicts}Conflict: '$_wc_changed_file' is an unplanned change overlapping ownership of: $_wc_owners\n"
    fi
  done < "$_wc_unplanned"

  if [ -n "$_wc_conflicts" ]; then
    printf "Wave conflict(s) detected:\n%b" "$_wc_conflicts" >&2
    return 1
  fi

  echo "No ownership conflicts in unplanned changes. Clean."
  return 0
}

# ============================================================
#  regenerate_summary — summary.md skeleton
# ============================================================

regenerate_summary() {
  _rs_name="$1"
  _rs_work_dir="$(resolve_row_dir "$_rs_name")"
  _rs_state_file="${_rs_work_dir}/state.json"
  _rs_summary_file="${_rs_work_dir}/summary.md"
  _rs_def_file="${_rs_work_dir}/definition.yaml"

  if [ ! -f "$_rs_state_file" ]; then
    echo "State file not found: $_rs_state_file" >&2
    return 2
  fi

  # Read state fields
  _rs_title="$(jq -r '.title // .name' "$_rs_state_file")"
  _rs_step="$(jq -r '.step' "$_rs_state_file")"
  _rs_step_status="$(jq -r '.step_status' "$_rs_state_file")"
  _rs_mode="$(jq -r '.mode' "$_rs_state_file")"

  # Deliverable counts
  _rs_total="$(jq -r '.deliverables | length' "$_rs_state_file")"
  if [ "$_rs_total" -eq 0 ] && [ -f "$_rs_def_file" ] && command -v yq > /dev/null 2>&1; then
    _rs_total="$(yq -r '.deliverables | length' "$_rs_def_file" 2>/dev/null)" || _rs_total="0"
    _rs_completed="0"
    _rs_deliv_label="${_rs_completed}/${_rs_total} (defined)"
  else
    _rs_completed="$(jq -r '[.deliverables | to_entries[] | select(.value.status == "completed")] | length' "$_rs_state_file")"
    _rs_deliv_label="${_rs_completed}/${_rs_total}"
  fi

  # Read objective from definition.yaml if available
  _rs_objective=""
  if [ -f "$_rs_def_file" ]; then
    if command -v yq > /dev/null 2>&1; then
      _rs_objective="$(yq -r '.objective // ""' "$_rs_def_file" 2>/dev/null)" || _rs_objective=""
    fi
  fi
  if [ -z "$_rs_objective" ]; then
    _rs_objective="$(jq -r '.description' "$_rs_state_file")"
  fi

  # Extract settled decisions from gates
  _rs_settled="$(jq -r '
    if (.gates | length) == 0 then "- No gates recorded yet"
    else
      [.gates[] | "- **\(.boundary)**: \(.outcome) \u2014 \(.evidence)"] | join("\n")
    end
  ' "$_rs_state_file")"

  # Context budget
  _rs_budget="Not measured"
  if command -v frw > /dev/null 2>&1; then
    _rs_budget="$(frw measure-context 2>/dev/null)" || _rs_budget="Measurement unavailable"
  fi

  # Artifact paths
  _rs_artifacts="- definition.yaml: ${_rs_work_dir}/definition.yaml
- state.json: ${_rs_work_dir}/state.json"

  [ -f "${_rs_work_dir}/plan.json" ] && _rs_artifacts="$_rs_artifacts
- plan.json: ${_rs_work_dir}/plan.json"
  [ -f "${_rs_work_dir}/research.md" ] && _rs_artifacts="$_rs_artifacts
- research.md: ${_rs_work_dir}/research.md"
  [ -d "${_rs_work_dir}/research" ] && _rs_artifacts="$_rs_artifacts
- research/: ${_rs_work_dir}/research/"
  [ -f "${_rs_work_dir}/spec.md" ] && _rs_artifacts="$_rs_artifacts
- spec.md: ${_rs_work_dir}/spec.md"
  [ -d "${_rs_work_dir}/specs" ] && _rs_artifacts="$_rs_artifacts
- specs/: ${_rs_work_dir}/specs/"
  [ -f "${_rs_work_dir}/team-plan.md" ] && _rs_artifacts="$_rs_artifacts
- team-plan.md: ${_rs_work_dir}/team-plan.md"

  # Preserve agent-written sections from existing summary
  _rs_key_findings=""
  _rs_open_questions=""
  _rs_recommendations=""

  if [ -f "$_rs_summary_file" ]; then
    _rs_key_findings="$(extract_md_section "$_rs_summary_file" "Key Findings")"
    _rs_open_questions="$(extract_md_section "$_rs_summary_file" "Open Questions")"
    _rs_recommendations="$(extract_md_section "$_rs_summary_file" "Recommendations")"
  fi

  # Trim whitespace from preserved sections
  _rs_key_findings="$(echo "$_rs_key_findings" | sed '/^$/d' | sed 's/^[[:space:]]*//')"
  _rs_open_questions="$(echo "$_rs_open_questions" | sed '/^$/d' | sed 's/^[[:space:]]*//')"
  _rs_recommendations="$(echo "$_rs_recommendations" | sed '/^$/d' | sed 's/^[[:space:]]*//')"

  # Write summary atomically
  _rs_tmp="${_rs_summary_file}.tmp.$$"
  trap 'rm -f "$_rs_tmp"' EXIT INT TERM

  cat > "$_rs_tmp" << ENDMD
# ${_rs_title} -- Summary

## Task
${_rs_objective}

## Current State
Step: ${_rs_step} | Status: ${_rs_step_status}
Deliverables: ${_rs_deliv_label}
Mode: ${_rs_mode}

## Artifact Paths
${_rs_artifacts}

## Settled Decisions
${_rs_settled}

## Context Budget
${_rs_budget}

## Key Findings
${_rs_key_findings}

## Open Questions
${_rs_open_questions}

## Recommendations
${_rs_recommendations}
ENDMD

  mv "$_rs_tmp" "$_rs_summary_file"
  trap - EXIT INT TERM

  # Validate all required sections present
  _rs_missing=""
  for _rs_section in "Task" "Current State" "Artifact Paths" "Settled Decisions" "Context Budget" "Key Findings" "Open Questions" "Recommendations"; do
    if ! grep -q "^## $_rs_section" "$_rs_summary_file"; then
      _rs_missing="$_rs_missing $_rs_section"
    fi
  done

  if [ -n "$_rs_missing" ]; then
    echo "Warning: summary.md missing sections:$_rs_missing" >&2
  fi

  echo "Summary regenerated: $_rs_summary_file"
}

# ============================================================
#  update_summary — update an agent-written summary section
# ============================================================

update_summary() {
  _usm_name="$1"
  _usm_section="$2"
  _usm_replace="${3:-false}"

  _usm_work_dir="$(resolve_row_dir "$_usm_name")"
  _usm_summary_file="${_usm_work_dir}/summary.md"

  if [ ! -f "$_usm_summary_file" ]; then
    echo "summary.md not found: $_usm_summary_file" >&2
    exit "$EXIT_NOT_FOUND"
  fi

  # Map kebab-case section to display name
  case "$_usm_section" in
    reintegration)
      printf '[furrow:error] '\''reintegration'\'' is a machine-generated section; use '\''rws generate-reintegration'\'' instead\n' >&2
      exit "$EXIT_VALIDATION"
      ;;
    key-findings)     _usm_display="Key Findings" ;;
    open-questions)   _usm_display="Open Questions" ;;
    recommendations)  _usm_display="Recommendations" ;;
    *)
      echo "Invalid section: $_usm_section (must be key-findings, open-questions, or recommendations)" >&2
      exit "$EXIT_USAGE"
      ;;
  esac

  # Reject if stdin is a TTY
  if [ -t 0 ]; then
    echo "Content must be piped via stdin (not a TTY)" >&2
    exit "$EXIT_USAGE"
  fi

  # Read content from stdin, reject empty or whitespace-only
  _usm_content="$(cat)"

  _usm_trimmed="$(echo "$_usm_content" | sed '/^[[:space:]]*$/d')"
  if [ -z "$_usm_trimmed" ]; then
    echo "No substantive content provided on stdin (empty or whitespace-only)" >&2
    exit "$EXIT_VALIDATION"
  fi

  # Protect the reintegration block (write-protected from update-summary).
  # The <!-- reintegration:begin --> ... <!-- reintegration:end --> block is
  # machine-generated by rws generate-reintegration. Two failure modes are
  # avoided by stripping the block BEFORE running the section replace:
  #   (a) extract_md_section stops at ^## headings but not at HTML comment
  #       markers, so an append-mode edit on a section adjacent to the block
  #       would slurp <!-- reintegration:begin --> into the retained content
  #       and write a duplicate marker into the updated section.
  #   (b) replace_md_section's "replacing" mode runs from the target header to
  #       the next ^## header, which swallows the begin marker line because
  #       ## Reintegration sits inside the markers.
  # Strip the block (markers + content) up-front, run the replace on the
  # stripped file, then restore the block byte-identically at the end.
  _usm_reint_block=""
  if grep -q '<!-- reintegration:begin -->' "$_usm_summary_file" 2>/dev/null \
     && grep -q '<!-- reintegration:end -->' "$_usm_summary_file" 2>/dev/null; then
    _usm_reint_block="$(awk '
      /<!-- reintegration:begin -->/ { capture=1 }
      capture { print }
      /<!-- reintegration:end -->/ { capture=0 }
    ' "$_usm_summary_file")"
    _usm_stripped_tmp="${_usm_summary_file}.stripped.$$"
    awk '
      /<!-- reintegration:begin -->/ { skip=1 }
      !skip { print }
      /<!-- reintegration:end -->/ { skip=0 }
    ' "$_usm_summary_file" > "$_usm_stripped_tmp"
    mv "$_usm_stripped_tmp" "$_usm_summary_file"
  fi

  # For append mode, extract existing section content and prepend it
  # (done after stripping so the extract can never pick up block markers).
  if [ "$_usm_replace" != "true" ]; then
    _usm_existing="$(extract_md_section "$_usm_summary_file" "$_usm_display")"
    if [ -n "$_usm_existing" ]; then
      _usm_content="${_usm_existing}
${_usm_content}"
    fi
  fi

  # Atomic rewrite: replace only the target section
  replace_md_section "$_usm_summary_file" "$_usm_display" "$_usm_content"

  # Restore the reintegration block at the end of the file (byte-identical).
  if [ -n "$_usm_reint_block" ]; then
    # Ensure file ends with a newline before appending
    if [ -s "$_usm_summary_file" ]; then
      _usm_last_byte="$(tail -c 1 "$_usm_summary_file" | wc -c)"
      _usm_last_nl="$(tail -c 1 "$_usm_summary_file" | tr -c '\n' 'X' | tr -d 'X')"
      if [ "$_usm_last_byte" -gt 0 ] && [ -z "$_usm_last_nl" ]; then
        printf '\n' >> "$_usm_summary_file"
      fi
    fi
    printf '%s\n' "$_usm_reint_block" >> "$_usm_summary_file"
  fi

  # Update state.json timestamp to reflect summary change
  update_state "$_usm_name" "." > /dev/null 2>&1 || true

  echo "Updated ${_usm_display} in summary.md"
}

# ============================================================
#  validate_summary — summary section validation
# ============================================================

validate_summary() {
  _vs_name="$1"
  _vs_step="${2:-}"

  _vs_work_dir="$(resolve_row_dir "$_vs_name")"
  _vs_state_file="${_vs_work_dir}/state.json"
  _vs_summary_file="${_vs_work_dir}/summary.md"

  # No summary exists yet: pass
  if [ ! -f "$_vs_summary_file" ]; then
    return 0
  fi

  # Skip if last gate was prechecked (auto-advanced, no human summary expected)
  _vs_last_decided="$(jq -r '.gates | last | .decided_by // ""' "$_vs_state_file" 2>/dev/null)" || _vs_last_decided=""
  if [ "$_vs_last_decided" = "prechecked" ]; then
    return 0
  fi

  _vs_errors=""

  # Check required sections
  for _vs_section in "Task" "Current State" "Artifact Paths" "Settled Decisions" "Key Findings" "Open Questions" "Recommendations"; do
    if ! grep -q "^## $_vs_section" "$_vs_summary_file"; then
      _vs_errors="${_vs_errors}Missing section: $_vs_section\n"
    fi
  done

  # Check agent-written sections have >= 1 non-empty line
  for _vs_section in "Key Findings" "Open Questions" "Recommendations"; do
    # Step-aware: ideate only requires Open Questions
    if [ "$_vs_step" = "ideate" ] && [ "$_vs_section" != "Open Questions" ]; then
      continue
    fi

    _vs_content="$(awk -v sec="$_vs_section" '
      $0 ~ "^## " sec { found=1; next }
      /^## / { if(found) exit }
      found && /[^ ]/ { count++ }
      END { print count+0 }
    ' "$_vs_summary_file")"

    if [ "$_vs_content" -lt 1 ]; then
      _vs_errors="${_vs_errors}Section '$_vs_section' needs at least 1 non-empty line (has $_vs_content).\n"
    fi
  done

  # If ## Reintegration section is present, BOTH markers must exist
  if grep -q '^## Reintegration' "$_vs_summary_file" 2>/dev/null; then
    _vs_has_begin=0
    _vs_has_end=0
    grep -q '<!-- reintegration:begin -->' "$_vs_summary_file" 2>/dev/null && _vs_has_begin=1
    grep -q '<!-- reintegration:end -->' "$_vs_summary_file" 2>/dev/null && _vs_has_end=1
    if [ "$_vs_has_begin" -eq 0 ] || [ "$_vs_has_end" -eq 0 ]; then
      _vs_errors="${_vs_errors}Section 'Reintegration' is present but missing required markers (<!-- reintegration:begin --> and/or <!-- reintegration:end -->). Use 'rws generate-reintegration' to populate this section.\n"
    fi
  fi

  if [ -n "$_vs_errors" ]; then
    printf "summary.md validation failed:\n%b" "$_vs_errors" >&2
    return 1
  fi

  return 0
}

# ============================================================
#  update_worktree_summary — update an agent-written worktree-summary section
# ============================================================

update_worktree_summary() {
  _uwts_name="$1"
  _uwts_section="$2"
  _uwts_replace="${3:-false}"

  _uwts_work_dir="$(resolve_row_dir "$_uwts_name")"
  _uwts_summary_file="${_uwts_work_dir}/worktree-summary.md"

  if [ ! -f "$_uwts_summary_file" ]; then
    echo "worktree-summary.md not found: $_uwts_summary_file" >&2
    exit "$EXIT_NOT_FOUND"
  fi

  # Map kebab-case section to display name
  case "$_uwts_section" in
    files-changed)  _uwts_display="Files Changed" ;;
    decisions)      _uwts_display="Decisions" ;;
    open-items)     _uwts_display="Open Items" ;;
    test-results)   _uwts_display="Test Results" ;;
    *)
      echo "Invalid section: $_uwts_section (must be files-changed, decisions, open-items, or test-results)" >&2
      exit "$EXIT_USAGE"
      ;;
  esac

  # Reject if stdin is a TTY
  if [ -t 0 ]; then
    echo "Content must be piped via stdin (not a TTY)" >&2
    exit "$EXIT_USAGE"
  fi

  # Read content from stdin, reject empty or whitespace-only
  _uwts_content="$(cat)"

  _uwts_trimmed="$(echo "$_uwts_content" | sed '/^[[:space:]]*$/d')"
  if [ -z "$_uwts_trimmed" ]; then
    echo "No substantive content provided on stdin (empty or whitespace-only)" >&2
    exit "$EXIT_VALIDATION"
  fi

  # For append mode, extract existing section content and prepend it
  if [ "$_uwts_replace" != "true" ]; then
    _uwts_existing="$(extract_md_section "$_uwts_summary_file" "$_uwts_display")"
    if [ -n "$_uwts_existing" ]; then
      _uwts_content="${_uwts_existing}
${_uwts_content}"
    fi
  fi

  # Atomic rewrite: replace only the target section
  replace_md_section "$_uwts_summary_file" "$_uwts_display" "$_uwts_content"

  # Update state.json timestamp to reflect summary change
  update_state "$_uwts_name" "." > /dev/null 2>&1 || true

  echo "Updated ${_uwts_display} in worktree-summary.md"
}

# ============================================================
#  regenerate_worktree_summary — regenerate worktree-summary.md skeleton
# ============================================================

regenerate_worktree_summary() {
  _rwts_name="$1"

  _rwts_work_dir="$(resolve_row_dir "$_rwts_name")"
  _rwts_summary_file="${_rwts_work_dir}/worktree-summary.md"

  # Preserve existing agent-written sections
  _rwts_files_changed=""
  _rwts_decisions=""
  _rwts_open_items=""
  _rwts_test_results=""

  if [ -f "$_rwts_summary_file" ]; then
    _rwts_files_changed="$(extract_md_section "$_rwts_summary_file" "Files Changed")"
    _rwts_decisions="$(extract_md_section "$_rwts_summary_file" "Decisions")"
    _rwts_open_items="$(extract_md_section "$_rwts_summary_file" "Open Items")"
    _rwts_test_results="$(extract_md_section "$_rwts_summary_file" "Test Results")"
  fi

  # Write skeleton atomically
  _rwts_tmp="${_rwts_summary_file}.tmp.$$"
  trap 'rm -f "$_rwts_tmp"' EXIT INT TERM

  cat > "$_rwts_tmp" << ENDWTS
# Worktree Summary: ${_rwts_name}
## Files Changed
${_rwts_files_changed}
## Decisions
${_rwts_decisions}
## Open Items
${_rwts_open_items}
## Test Results
${_rwts_test_results}
ENDWTS

  mv "$_rwts_tmp" "$_rwts_summary_file"
  trap - EXIT INT TERM

  if [ ! -f "$_rwts_summary_file" ]; then
    echo "Error: worktree-summary.md not found after write — mv failed" >&2
    exit "$EXIT_SUB_FAILED"
  fi

  # Validate all required sections present
  _rwts_missing=""
  for _rwts_section in "Files Changed" "Decisions" "Open Items" "Test Results"; do
    if ! grep -q "^## ${_rwts_section}$" "$_rwts_summary_file"; then
      _rwts_missing="${_rwts_missing} ${_rwts_section}"
    fi
  done

  if [ -n "$_rwts_missing" ]; then
    echo "Warning: worktree-summary.md missing sections:${_rwts_missing}" >&2
  fi

  echo "Worktree summary regenerated: $_rwts_summary_file"
}

# ============================================================
#  validate_worktree_summary — worktree-summary section validation
# ============================================================

validate_worktree_summary() {
  _vwts_name="$1"

  _vwts_work_dir="$(resolve_row_dir "$_vwts_name")"
  _vwts_summary_file="${_vwts_work_dir}/worktree-summary.md"

  if [ ! -f "$_vwts_summary_file" ]; then
    echo "worktree-summary.md not found: $_vwts_summary_file" >&2
    return 1
  fi

  _vwts_errors=""

  # Check all 4 sections present with >= 1 non-empty line
  for _vwts_section in "Files Changed" "Decisions" "Open Items" "Test Results"; do
    if ! grep -q "^## ${_vwts_section}$" "$_vwts_summary_file"; then
      _vwts_errors="${_vwts_errors}Missing section: ${_vwts_section}\n"
      continue
    fi

    _vwts_count="$(awk -v sec="$_vwts_section" '
      $0 == "## " sec { found=1; next }
      /^## /          { if (found) exit }
      found && /[^ ]/ { count++ }
      END             { print count+0 }
    ' "$_vwts_summary_file")"

    if [ "$_vwts_count" -lt 1 ]; then
      _vwts_errors="${_vwts_errors}Section '${_vwts_section}' needs at least 1 non-empty line (has ${_vwts_count}).\n"
    fi
  done

  if [ -n "$_vwts_errors" ]; then
    printf "worktree-summary.md validation failed:\n%b" "$_vwts_errors" >&2
    return 1
  fi

  return 0
}

# ============================================================
#  Subcommand: init
# ============================================================

rws_init() {
  if [ "$#" -lt 1 ]; then
    echo "Usage: rws init <name> [--title T] [--mode M] [--gate-policy P] [--source-todo ID] [--seed-id ID]" >&2
    exit "$EXIT_USAGE"
  fi

  _init_name="$1"
  shift

  _init_title=""
  _init_mode=""
  _init_gate_policy=""
  _init_source_todo=""
  _init_seed_id=""

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --title)
        _init_title="${2:-}"
        shift 2 || die "Missing value for --title"
        ;;
      --mode)
        _init_mode="${2:-}"
        shift 2 || die "Missing value for --mode"
        case "$_init_mode" in
          code|research) ;;
          *) die "Invalid mode: '$_init_mode'. Must be code or research." ;;
        esac
        ;;
      --gate-policy)
        _init_gate_policy="${2:-}"
        shift 2 || die "Missing value for --gate-policy"
        case "$_init_gate_policy" in
          supervised|delegated|autonomous) ;;
          *) die "Invalid gate-policy: '$_init_gate_policy'. Must be supervised, delegated, or autonomous." ;;
        esac
        ;;
      --source-todo)
        _init_source_todo="${2:-}"
        shift 2 || die "Missing value for --source-todo"
        if ! validate_kebab "$_init_source_todo"; then
          die "Invalid source-todo: must be kebab-case: '$_init_source_todo'"
        fi
        ;;
      --seed-id)
        _init_seed_id="${2:-}"
        shift 2 || die "Missing value for --seed-id"
        ;;
      *)
        die "Unknown argument: $1"
        ;;
    esac
  done

  # Validate name
  if ! validate_kebab "$_init_name"; then
    die "Name must be kebab-case: '$_init_name'"
  fi

  # Check row does not exist
  _init_work_dir="$(resolve_row_dir "$_init_name")"
  if [ -d "$_init_work_dir" ]; then
    echo "Row already exists: $_init_work_dir" >&2
    exit "$EXIT_NOT_FOUND"
  fi

  # Apply defaults from furrow.yaml
  if [ -z "$_init_mode" ]; then
    if [ -f "$FURROW_YAML" ] && command -v yq > /dev/null 2>&1; then
      _init_mode="$(yq -r '.defaults.mode // "code"' "$FURROW_YAML" 2>/dev/null)" || _init_mode="code"
    else
      _init_mode="code"
    fi
  fi

  if [ -z "$_init_gate_policy" ]; then
    if [ -f "$FURROW_YAML" ] && command -v yq > /dev/null 2>&1; then
      _init_gate_policy="$(yq -r '.defaults.gate_policy // "supervised"' "$FURROW_YAML" 2>/dev/null)" || _init_gate_policy="supervised"
    else
      _init_gate_policy="supervised"
    fi
  fi

  _init_title="${_init_title:-${_init_name}}"
  _init_base_commit="$(git rev-parse HEAD 2>/dev/null)" || _init_base_commit="unknown"
  _init_now="$(now_iso)"

  # Auto-detect branch if on a work/* branch
  _init_branch=""
  _init_current_branch="$(git branch --show-current 2>/dev/null || true)"
  if [ -n "$_init_current_branch" ] && echo "$_init_current_branch" | grep -q '^work/'; then
    _init_branch="$_init_current_branch"
  fi

  # Create directory
  mkdir -p "${_init_work_dir}/reviews"

  # Write state.json atomically
  _init_tmp="${_init_work_dir}/state.json.tmp.$$"
  trap 'rm -f "$_init_tmp"' EXIT

  jq -n \
    --arg name "$_init_name" \
    --arg title "$_init_title" \
    --arg description "$_init_title" \
    --arg mode "$_init_mode" \
    --arg base_commit "$_init_base_commit" \
    --arg now "$_init_now" \
    --arg source_todo "$_init_source_todo" \
    --arg gate_policy_init "$_init_gate_policy" \
    --arg seed_id "$_init_seed_id" \
    --arg branch "$_init_branch" \
    '{
      name: $name,
      title: $title,
      description: $description,
      step: "ideate",
      step_status: "in_progress",
      steps_sequence: ["ideate","research","plan","spec","decompose","implement","review"],
      deliverables: {},
      gates: [],
      force_stop_at: null,
      branch: (if $branch == "" then null else $branch end),
      mode: $mode,
      base_commit: $base_commit,
      seed_id: (if $seed_id == "" then null else $seed_id end),
      epic_seed_id: null,
      created_at: $now,
      updated_at: $now,
      archived_at: null,
      source_todo: (if $source_todo == "" then null else $source_todo end),
      gate_policy_init: (if $gate_policy_init == "" then null else $gate_policy_init end)
    }' > "$_init_tmp"

  mv "$_init_tmp" "${_init_work_dir}/state.json"
  trap - EXIT

  # --- Seed integration ---
  # After state.json exists, create or link a seed.

  if command -v sds > /dev/null 2>&1; then
    if [ -n "$_init_seed_id" ]; then
      # Case 2: --seed-id provided — validate and link
      if ! sds show "$_init_seed_id" > /dev/null 2>&1; then
        echo "rws: seed not found: $_init_seed_id" >&2
        rm -rf "$_init_work_dir"
        exit 7
      fi
      _init_seed_status="$(sds show "$_init_seed_id" --json | jq -r '.status')"
      if [ "$_init_seed_status" = "closed" ]; then
        echo "rws: seed is closed: $_init_seed_id (status=$_init_seed_status)" >&2
        rm -rf "$_init_work_dir"
        exit 7
      fi
      sds update "$_init_seed_id" --status claimed 2>/dev/null || \
        echo "Warning: failed to update seed status to claimed" >&2
      update_state "$_init_name" ".seed_id = \"$_init_seed_id\""

    elif [ -n "$_init_source_todo" ]; then
      # Case 3: --source-todo provided — check for existing seed_id in todos.yaml
      _init_todos_file=".furrow/almanac/todos.yaml"
      _init_todo_seed=""
      if [ -f "$_init_todos_file" ] && command -v yq > /dev/null 2>&1; then
        # shellcheck disable=SC2016 # yq expression uses --arg variables.
        _init_todo_seed="$(yq -r \
          --arg id "$_init_source_todo" \
          '[.todos[] | select(.id == $id) | .seed_id // ""] | .[0] // ""' \
          "$_init_todos_file" 2>/dev/null)" || _init_todo_seed=""
      fi

      if [ -n "$_init_todo_seed" ] && [ "$_init_todo_seed" != "null" ]; then
        # TODO already has a seed — validate and link
        if ! sds show "$_init_todo_seed" > /dev/null 2>&1; then
          echo "rws: seed from todo not found: $_init_todo_seed" >&2
          rm -rf "$_init_work_dir"
          exit 7
        fi
        _init_seed_status="$(sds show "$_init_todo_seed" --json | jq -r '.status')"
        if [ "$_init_seed_status" = "closed" ]; then
          echo "rws: seed from todo is closed: $_init_todo_seed" >&2
          rm -rf "$_init_work_dir"
          exit 7
        fi
        sds update "$_init_todo_seed" --status claimed 2>/dev/null || \
          echo "Warning: failed to update seed status to claimed" >&2
        update_state "$_init_name" ".seed_id = \"$_init_todo_seed\""
      else
        # TODO has no seed — create one and backfill
        _init_new_seed="$(sds create --title "$_init_title" --type task)"
        if [ -n "$_init_new_seed" ]; then
          sds update "$_init_new_seed" --status claimed 2>/dev/null || \
            echo "Warning: failed to update seed status to claimed" >&2
          update_state "$_init_name" ".seed_id = \"$_init_new_seed\""
          # Backfill seed_id into todos.yaml
          if [ -f "$_init_todos_file" ] && command -v yq > /dev/null 2>&1; then
            _init_backfill_ts="$(now_iso)"
            # shellcheck disable=SC2016 # yq expression uses --arg variables.
            yq -i \
              --arg id "$_init_source_todo" \
              --arg seed "$_init_new_seed" \
              --arg ts "$_init_backfill_ts" \
              '(.todos[] | select(.id == $id)) |= (.seed_id = $seed | .updated_at = $ts)' \
              "$_init_todos_file" 2>/dev/null || \
              echo "Warning: failed to backfill seed_id into todos.yaml" >&2
          fi
        else
          echo "Warning: failed to create seed" >&2
        fi
      fi

    else
      # Case 1: No --seed-id, no --source-todo — auto-create
      _init_new_seed="$(sds create --title "$_init_title" --type task)"
      if [ -n "$_init_new_seed" ]; then
        sds update "$_init_new_seed" --status claimed 2>/dev/null || \
          echo "Warning: failed to update seed status to claimed" >&2
        update_state "$_init_name" ".seed_id = \"$_init_new_seed\""
      else
        echo "Warning: failed to create seed" >&2
      fi
    fi
  else
    echo "rws: sds command not found — seeds are mandatory. Install sds and ensure it is on PATH." >&2
    rm -rf "$_init_work_dir"
    exit 1
  fi

  echo "Row initialized: $_init_work_dir"
}

# ============================================================
#  Subcommand: transition
# ============================================================

rws_transition() {
  if [ "$#" -lt 4 ]; then
    echo "Usage: rws transition <name> <outcome> <decided_by> <evidence> [conditions_json]" >&2
    exit "$EXIT_USAGE"
  fi

  _tr_name="$1"
  _tr_outcome="$2"
  _tr_decided_by="$3"
  _tr_evidence="$4"
  _tr_conditions="${5:-}"

  _tr_state_file="$(require_state "$_tr_name")"
  _tr_work_dir="$(resolve_row_dir "$_tr_name")"

  # Determine boundary
  _tr_current="$(jq -r '.step' "$_tr_state_file")"
  _tr_current_idx="$(jq -r --arg step "$_tr_current" '.steps_sequence | to_entries[] | select(.value == $step) | .key' "$_tr_state_file")"
  _tr_total="$(jq -r '.steps_sequence | length' "$_tr_state_file")"
  _tr_last=$((_tr_total - 1))
  _tr_next_idx=$((_tr_current_idx + 1))
  _tr_next="$(jq -r --argjson idx "$_tr_next_idx" '.steps_sequence[$idx] // "review"' "$_tr_state_file")"
  _tr_boundary="${_tr_current}->${_tr_next}"

  # Cannot advance past review (except for fail)
  if [ "$_tr_outcome" != "fail" ] && [ "$_tr_current_idx" -eq "$_tr_last" ]; then
    echo "Cannot advance past final step 'review'." >&2
    exit "$EXIT_VALIDATION"
  fi

  # 1. Record gate (before any validation so the gate is always persisted)
  if [ -n "$_tr_conditions" ]; then
    record_gate "$_tr_name" "$_tr_boundary" "$_tr_outcome" "$_tr_decided_by" "$_tr_evidence" "$_tr_conditions" || {
      echo "Failed to record gate" >&2
      exit "$EXIT_SUB_FAILED"
    }
  else
    record_gate "$_tr_name" "$_tr_boundary" "$_tr_outcome" "$_tr_decided_by" "$_tr_evidence" || {
      echo "Failed to record gate" >&2
      exit "$EXIT_SUB_FAILED"
    }
  fi

  # 1.5. Check for pending user actions (block on pass/conditional)
  if [ "$_tr_outcome" != "fail" ]; then
    _tr_pending="$(jq -r '[.pending_user_actions // [] | .[] | select(.completed_at == null)] | length' "$_tr_state_file" 2>/dev/null)" || _tr_pending=0
    if [ "$_tr_pending" -gt 0 ]; then
      echo "Transition blocked: $_tr_pending pending user action(s):" >&2
      jq -r '.pending_user_actions[] | select(.completed_at == null) | "  [PENDING] " + .id + " — " + .instructions' "$_tr_state_file" >&2
      exit 1
    fi
    _tr_ua_total="$(jq -r '.pending_user_actions | length' "$_tr_state_file" 2>/dev/null)" || _tr_ua_total=0
    if [ "$_tr_ua_total" -gt 0 ]; then
      _tr_evidence="${_tr_evidence} | user_actions: all ${_tr_ua_total} completed"
    fi
  fi

  # 2. Validate step artifacts (only on pass/conditional)
  if [ "$_tr_outcome" != "fail" ]; then
    validate_step_artifacts "$_tr_name" "$_tr_boundary" || {
      echo "Artifact validation failed for $_tr_boundary. Gate recorded but advancement blocked." >&2
      exit "$EXIT_SUB_FAILED"
    }
  fi

  # 3. Validate decided_by against gate_policy
  _tr_gate_policy="$(read_gate_policy "$_tr_name")"
  case "$_tr_gate_policy" in
    supervised)
      if [ "$_tr_decided_by" != "manual" ]; then
        echo "Policy violation: supervised mode requires decided_by=manual, got '$_tr_decided_by'." >&2
        exit "$EXIT_POLICY"
      fi
      ;;
    delegated)
      case "$_tr_decided_by" in
        manual|evaluated) ;;
        *)
          echo "Policy violation: delegated mode requires decided_by=manual or evaluated, got '$_tr_decided_by'." >&2
          exit "$EXIT_POLICY"
          ;;
      esac
      ;;
    autonomous)
      # All decided_by values accepted
      ;;
  esac

  # 4. Verdict nonce validation (evaluated gates)
  if [ "$_tr_decided_by" = "evaluated" ]; then
    _tr_verdict_file=""
    for _tr_vtype in post_step pre_step; do
      _tr_vf="${_tr_work_dir}/gate-verdicts/${_tr_vtype}-${_tr_current}.json"
      if [ -f "$_tr_vf" ]; then
        _tr_verdict_file="$_tr_vf"
        break
      fi
    done

    if [ -z "$_tr_verdict_file" ]; then
      echo "Verdict file not found in ${_tr_work_dir}/gate-verdicts/. Evaluator must write verdict before transition." >&2
      exit "$EXIT_SUB_FAILED"
    fi

    _tr_prompt_file=""
    for _tr_ptype in post_step pre_step; do
      _tr_pf="${_tr_work_dir}/gate-prompts/${_tr_ptype}-${_tr_current}.yaml"
      if [ -f "$_tr_pf" ]; then
        _tr_prompt_file="$_tr_pf"
        break
      fi
    done

    if [ -z "$_tr_prompt_file" ]; then
      echo "Prompt file not found in ${_tr_work_dir}/gate-prompts/. Cannot validate verdict nonce." >&2
      exit "$EXIT_SUB_FAILED"
    fi

    _tr_prompt_nonce="$(grep '^nonce:' "$_tr_prompt_file" | sed 's/^nonce: *//' | tr -d '[:space:]')" || _tr_prompt_nonce=""
    _tr_verdict_nonce="$(jq -r '.nonce // ""' "$_tr_verdict_file" 2>/dev/null)" || _tr_verdict_nonce=""

    if [ -n "$_tr_prompt_nonce" ] && [ "$_tr_prompt_nonce" != "$_tr_verdict_nonce" ]; then
      echo "Nonce mismatch: prompt='$_tr_prompt_nonce' verdict='$_tr_verdict_nonce'. Verdict may be stale or forged." >&2
      exit "$EXIT_SUB_FAILED"
    fi
  fi

  # 5. Handle fail: do not advance
  if [ "$_tr_outcome" = "fail" ]; then
    update_state "$_tr_name" '.step_status = "in_progress"'
    case "$_tr_current" in
      implement|review)
        update_state "$_tr_name" \
          '.deliverables |= with_entries(if .value.status == "in_progress" then .value.corrections = ((.value.corrections // 0) + 1) else . end)' \
          2>/dev/null || true
        ;;
    esac
    echo "Gate failed: $_tr_boundary. Step remains at $_tr_current."
    exit "$EXIT_SUCCESS"
  fi

  # 6. Wave conflict check at implement->review (code mode only)
  if [ "$_tr_current" = "implement" ] && [ "$_tr_next" = "review" ]; then
    _tr_mode="$(jq -r '.mode // "code"' "$_tr_state_file" 2>/dev/null)" || _tr_mode="code"
    if [ "$_tr_mode" = "code" ]; then
      check_wave_conflicts "$_tr_name" 2>&1 || {
        echo "Warning: wave conflicts detected (non-blocking)" >&2
      }
    fi
  fi

  # 6b. Validate summary sections
  validate_summary "$_tr_name" "$_tr_current" || {
    echo "Summary validation failed. Populate Key Findings, Open Questions, and Recommendations in summary.md before advancing." >&2
    echo "See skills/shared/summary-protocol.md for step-specific requirements." >&2
    exit "$EXIT_SUB_FAILED"
  }

  # 7. Advance step. Summary regeneration is no longer required for transition
  # truth; summary.md remains a context artifact validated at boundaries.
  advance_step "$_tr_name" || {
    echo "Failed to advance step" >&2
    exit "$EXIT_SUB_FAILED"
  }

  # 8. Sync seed status after successful advance
  sync_seed_status "$_tr_name" "$_tr_next"

  echo "Transition complete: $_tr_boundary ($_tr_outcome)"
}

# ============================================================
#  Subcommand: status
# ============================================================

rws_status() {
  rws_exec_furrow row status "$@"
}

# ============================================================
#  Subcommand: list
# ============================================================

rws_list() {
  case "${1:-}" in
    "") rws_exec_furrow row list --active ;;
    --active|--archived|--all|--json) rws_exec_furrow row list "$@" ;;
    *) die "Unknown flag: $1. Use --active, --archived, --all, or --json." ;;
  esac
}

# ============================================================
#  Subcommand: complete-deliverable
# ============================================================

rws_complete_deliverable() {
  if [ "$#" -lt 1 ]; then
    die "Usage: rws complete-deliverable <name> <deliverable>"
  fi

  # If only one arg, treat it as deliverable and resolve name
  if [ "$#" -eq 1 ]; then
    _cd_name="$(resolve_name "")"
    _cd_deliv="$1"
  else
    _cd_name="$1"
    _cd_deliv="$2"
  fi

  _cd_state_file="$(require_state "$_cd_name")"
  _cd_def_file="${ROWS_DIR}/${_cd_name}/definition.yaml"
  _cd_plan_file="${ROWS_DIR}/${_cd_name}/plan.json"

  # Validate deliverable exists in definition.yaml
  if [ ! -f "$_cd_def_file" ]; then
    echo "Definition file not found: $_cd_def_file" >&2
    exit "$EXIT_VALIDATION"
  fi

  if ! command -v yq > /dev/null 2>&1; then
    echo "yq is required for deliverable validation" >&2
    exit "$EXIT_SUB_FAILED"
  fi

  _cd_found="$(yq -r ".deliverables[] | select(.name == \"$_cd_deliv\") | .name" "$_cd_def_file" 2>/dev/null)" || _cd_found=""
  if [ -z "$_cd_found" ]; then
    echo "Deliverable '$_cd_deliv' not found in $_cd_def_file" >&2
    exit "$EXIT_VALIDATION"
  fi

  # Read wave from plan.json (default wave=1 if no plan or deliverable not in plan)
  _cd_wave=1
  if [ -f "$_cd_plan_file" ]; then
    _cd_plan_wave="$(jq -r --arg d "$_cd_deliv" '
      [.waves[] | .wave as $w | .deliverables[] | select(. == $d) | $w] | first // empty
    ' "$_cd_plan_file" 2>/dev/null)" || _cd_plan_wave=""
    if [ -n "$_cd_plan_wave" ]; then
      _cd_wave="$_cd_plan_wave"
    fi
  fi

  # Update state
  _cd_jq=".deliverables[\"${_cd_deliv}\"] = {\"status\":\"completed\",\"wave\":${_cd_wave},\"corrections\":0}"
  update_state "$_cd_name" "$_cd_jq"

  echo "Deliverable completed: $_cd_deliv (wave $_cd_wave)"
}

# ============================================================
#  Subcommand: complete-step
# ============================================================

rws_complete_step() {
  _cs_name="$(resolve_name "${1:-}")"
  _cs_state_file="$(require_state "$_cs_name")"

  _cs_step="$(jq -r '.step' "$_cs_state_file")"

  # At review step: validate all deliverables are completed
  if [ "$_cs_step" = "review" ]; then
    _cs_def_file="${ROWS_DIR}/${_cs_name}/definition.yaml"

    if [ -f "$_cs_def_file" ] && command -v yq > /dev/null 2>&1; then
      _cs_missing=""
      _cs_del_tmp="$(mktemp)"
      yq -r '.deliverables[].name' "$_cs_def_file" 2>/dev/null > "$_cs_del_tmp" || true
      while IFS= read -r _cs_del_name; do
        _cs_del_status="$(jq -r --arg d "$_cs_del_name" '.deliverables[$d].status // "missing"' "$_cs_state_file" 2>/dev/null)" || _cs_del_status="missing"
        if [ "$_cs_del_status" != "completed" ]; then
          _cs_missing="${_cs_missing}  deliverable '${_cs_del_name}' is ${_cs_del_status}\n"
        fi
      done < "$_cs_del_tmp"
      rm -f "$_cs_del_tmp"

      if [ -n "$_cs_missing" ]; then
        printf "Cannot complete review step: not all deliverables are completed\n" >&2
        printf "%b" "$_cs_missing" >&2
        exit "$EXIT_VALIDATION"
      fi
    fi
  fi

  update_state "$_cs_name" '.step_status = "completed"'

  echo "Step completed: $_cs_step"
}

# ============================================================
#  Subcommand: archive
# ============================================================

rws_archive() {
  if [ "$#" -lt 1 ]; then
    die "Usage: rws archive <name>"
  fi

  _ar_name="$1"
  _ar_state_file="$(require_state "$_ar_name")"
  _ar_errors=""

  # Pre-condition: step must be review
  _ar_step="$(jq -r '.step' "$_ar_state_file")"
  if [ "$_ar_step" != "review" ]; then
    _ar_errors="${_ar_errors}  step is '${_ar_step}' (expected 'review')\n"
  fi

  # Pre-condition: step_status must be completed
  _ar_status="$(jq -r '.step_status' "$_ar_state_file")"
  if [ "$_ar_status" != "completed" ]; then
    _ar_errors="${_ar_errors}  step_status is '${_ar_status}' (expected 'completed')\n"
  fi

  # Pre-condition: all deliverables completed
  _ar_inc_list="$(jq -r '
    [.deliverables | to_entries[] | select(.value.status != "completed") | .key] | .[]
  ' "$_ar_state_file" 2>/dev/null)" || _ar_inc_list=""

  for _ar_inc_name in $_ar_inc_list; do
    _ar_errors="${_ar_errors}  deliverable '${_ar_inc_name}' is not completed\n"
  done

  # Pre-condition: passing gate for implement->review
  _ar_final_gate="$(jq -r '
    [.gates[] | select(.boundary == "implement->review" and (.outcome == "pass" or .outcome == "conditional"))] | length
  ' "$_ar_state_file")"

  if [ "$_ar_final_gate" -eq 0 ]; then
    _ar_errors="${_ar_errors}  no passing gate for implement->review\n"
  fi

  if [ -n "$_ar_errors" ]; then
    printf "Cannot archive '%s': preconditions not met\n" "$_ar_name" >&2
    printf "%b" "$_ar_errors" >&2
    exit "$EXIT_VALIDATION"
  fi

  # Archive
  _ar_now="$(now_iso)"
  update_state "$_ar_name" ".archived_at = \"$_ar_now\" | .step_status = \"completed\""

  # Close seed
  _ar_seed_id="$(jq -r '.seed_id // ""' "$_ar_state_file" 2>/dev/null)" || _ar_seed_id=""
  if [ -n "$_ar_seed_id" ] && [ "$_ar_seed_id" != "null" ]; then
    if command -v sds > /dev/null 2>&1; then
      sds close "$_ar_seed_id" --reason "archived: $_ar_name" 2>/dev/null || \
        echo "Warning: failed to close seed $_ar_seed_id" >&2
    fi
  fi

  # Clear focus if archiving the focused row
  if [ -f "$FOCUSED_FILE" ]; then
    _ar_focused="$(cat "$FOCUSED_FILE" 2>/dev/null)" || _ar_focused=""
    if [ "$_ar_focused" = "$_ar_name" ]; then
      rm -f "$FOCUSED_FILE"
    fi
  fi

  echo "Archived: $_ar_name"
}

# ============================================================
#  Subcommand: gate-check
# ============================================================

rws_gate_check() {
  if [ "$#" -lt 3 ]; then
    echo "Usage: rws gate-check <step> <def_path> <state_path>" >&2
    exit "$EXIT_USAGE"
  fi

  _gc_step="$1"
  _gc_def_path="$2"
  _gc_state_path="$3"

  # Global exclusions
  case "$_gc_step" in
    ideate|implement|review) exit 1 ;;
  esac

  # force_stop_at blocks pre-step evaluation
  _gc_force_stop="$(jq -r '.force_stop_at // ""' "$_gc_state_path" 2>/dev/null)" || _gc_force_stop=""
  if [ "$_gc_force_stop" = "$_gc_step" ]; then
    exit 1
  fi

  _gc_deliv_count="$(yq -r '.deliverables | length' "$_gc_def_path" 2>/dev/null)" || _gc_deliv_count="0"
  _gc_mode="$(jq -r '.mode // "code"' "$_gc_state_path" 2>/dev/null)" || _gc_mode="code"
  case "$_gc_mode" in
    code|research) ;;
    *) echo "Warning: invalid mode '$_gc_mode', defaulting to 'code'" >&2; _gc_mode="code" ;;
  esac

  case "$_gc_step" in
    research)
      if [ "$_gc_mode" = "research" ]; then exit 1; fi
      if [ "$_gc_deliv_count" -ne 1 ]; then exit 1; fi
      _gc_has_paths="$(yq -r '.deliverables[0].acceptance_criteria[]' "$_gc_def_path" 2>/dev/null | grep -cE '/\w+' || true)"
      if [ "$_gc_has_paths" -eq 0 ]; then exit 1; fi
      _gc_has_dirs="$(yq -r '.context_pointers[].path' "$_gc_def_path" 2>/dev/null | grep -cE '/$' || true)"
      if [ "$_gc_has_dirs" -gt 0 ]; then exit 1; fi
      _gc_first_file="$(yq -r '.deliverables[0].acceptance_criteria[0]' "$_gc_def_path" 2>/dev/null | grep -oE '[^ ]*/\w+' | head -1)"
      echo "Single deliverable targeting known location (${_gc_first_file}); structural preconditions met for pre-step evaluation"
      exit 0
      ;;
    plan)
      if [ "$_gc_deliv_count" -ne 1 ]; then exit 1; fi
      _gc_deps="$(yq -r '.deliverables[0].depends_on | length' "$_gc_def_path" 2>/dev/null)" || _gc_deps="0"
      if [ "$_gc_deps" -gt 0 ]; then exit 1; fi
      echo "Single deliverable, no dependencies -- structural preconditions met for pre-step evaluation"
      exit 0
      ;;
    spec)
      if [ "$_gc_deliv_count" -ne 1 ]; then exit 1; fi
      _gc_ac_count="$(yq -r '.deliverables[0].acceptance_criteria | length' "$_gc_def_path" 2>/dev/null)" || _gc_ac_count="0"
      if [ "$_gc_ac_count" -lt 2 ]; then exit 1; fi
      echo "Single deliverable with ${_gc_ac_count} acceptance criteria -- structural preconditions met for pre-step evaluation"
      exit 0
      ;;
    decompose)
      if [ "$_gc_deliv_count" -gt 2 ]; then exit 1; fi
      _gc_has_deps="$(yq -r '[.deliverables[] | select(.depends_on != null and (.depends_on | length) > 0)] | length' "$_gc_def_path" 2>/dev/null)" || _gc_has_deps="0"
      if [ "$_gc_has_deps" -gt 0 ]; then exit 1; fi
      _gc_spec_count="$(yq -r '[.deliverables[].specialist // "default"] | unique | length' "$_gc_def_path" 2>/dev/null)" || _gc_spec_count="1"
      if [ "$_gc_spec_count" -gt 1 ]; then exit 1; fi
      echo "Single wave, ${_gc_deliv_count} deliverable(s), no dependencies -- structural preconditions met for pre-step evaluation"
      exit 0
      ;;
    *)
      exit 1
      ;;
  esac
}

# ============================================================
#  Subcommand: rewind
# ============================================================

rws_rewind() {
  if [ "$#" -lt 2 ]; then
    die "Usage: rws rewind <name> <target_step>"
  fi

  _rw_name="$1"
  _rw_target="$2"
  _rw_state_file="$(require_state "$_rw_name")"

  # Validate target step is in sequence
  _rw_target_idx="$(jq -r --arg step "$_rw_target" '
    .steps_sequence | to_entries[] | select(.value == $step) | .key
  ' "$_rw_state_file" 2>/dev/null)" || _rw_target_idx=""

  if [ -z "$_rw_target_idx" ]; then
    echo "Invalid step: '$_rw_target' is not in steps_sequence." >&2
    exit "$EXIT_VALIDATION"
  fi

  # Check target is at or before current step
  _rw_current="$(jq -r '.step' "$_rw_state_file")"
  _rw_current_idx="$(jq -r --arg step "$_rw_current" '
    .steps_sequence | to_entries[] | select(.value == $step) | .key
  ' "$_rw_state_file")"

  if [ "$_rw_target_idx" -gt "$_rw_current_idx" ]; then
    echo "Cannot rewind forward: '$_rw_target' is after current step '$_rw_current'." >&2
    exit "$EXIT_SUB_FAILED"
  fi

  # Record fail gate (non-sequential boundary is intentional for rewinds)
  _rw_boundary="${_rw_current}->${_rw_target}"
  record_gate "$_rw_name" "$_rw_boundary" "fail" "manual" \
    "User rewound: pre-step evaluation was incorrect or step needs rework"

  # Reset step
  update_state "$_rw_name" ".step = \"$_rw_target\" | .step_status = \"not_started\""

  echo "Rewound: $_rw_current -> $_rw_target. Artifacts preserved."
}

# ============================================================
#  Subcommand: diff
# ============================================================

rws_diff() {
  _di_name="$(resolve_name "${1:-}")"
  _di_state_file="$(require_state "$_di_name")"

  _di_base="$(jq -r '.base_commit' "$_di_state_file")"

  if [ -z "$_di_base" ] || [ "$_di_base" = "null" ] || [ "$_di_base" = "unknown" ]; then
    echo "No valid base_commit in state.json." >&2
    exit "$EXIT_NOT_FOUND"
  fi

  echo "=== Row Diff: $_di_name ==="
  echo "Base commit: $_di_base"
  echo "Current HEAD: $(git rev-parse HEAD)"
  echo ""

  git diff --stat "$_di_base..HEAD"
}

# ============================================================
#  Subcommand: focus
# ============================================================

rws_focus() {
  rws_exec_furrow row focus "$@"
}

# ============================================================
#  Subcommand: regenerate-summary
# ============================================================

rws_regenerate_summary() {
  _rgs_name="$(resolve_name "${1:-}")"
  require_state "$_rgs_name" > /dev/null
  regenerate_summary "$_rgs_name"
}

# ============================================================
#  Subcommand: validate-summary
# ============================================================

rws_validate_summary() {
  _vsub_name=""
  _vsub_step=""

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --step)
        _vsub_step="${2:-}"
        shift 2 || die "Missing value for --step"
        ;;
      *)
        _vsub_name="$1"
        shift
        ;;
    esac
  done

  _vsub_name="$(resolve_name "$_vsub_name")"
  require_state "$_vsub_name" > /dev/null

  # If step not provided, read from state
  if [ -z "$_vsub_step" ]; then
    _vsub_state_file="$(resolve_state_file "$_vsub_name")"
    _vsub_step="$(jq -r '.step' "$_vsub_state_file" 2>/dev/null)" || _vsub_step=""
  fi

  if ! validate_summary "$_vsub_name" "$_vsub_step"; then
    exit 1
  fi

  echo "Summary valid."
}

# ============================================================
#  Subcommand: update-summary
# ============================================================

rws_update_summary() {
  _usub_name=""
  _usub_section=""
  _usub_replace="false"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --replace)
        _usub_replace="true"
        shift
        ;;
      *)
        if [ -z "$_usub_section" ]; then
          # Could be name or section — check if it's a valid section
          case "$1" in
            reintegration|key-findings|open-questions|recommendations)
              _usub_section="$1"
              ;;
            *)
              if [ -z "$_usub_name" ]; then
                _usub_name="$1"
              else
                _usub_section="$1"
              fi
              ;;
          esac
        fi
        shift
        ;;
    esac
  done

  if [ -z "$_usub_section" ]; then
    die "Usage: rws update-summary [name] <section> [--replace]"
  fi

  # Reject reintegration before resolving name (machine-generated section)
  if [ "$_usub_section" = "reintegration" ]; then
    printf '[furrow:error] '\''reintegration'\'' is a machine-generated section; use '\''rws generate-reintegration'\'' instead\n' >&2
    exit "$EXIT_VALIDATION"
  fi

  _usub_name="$(resolve_name "$_usub_name")"
  require_state "$_usub_name" > /dev/null

  update_summary "$_usub_name" "$_usub_section" "$_usub_replace"
}

# ============================================================
#  Subcommand: update-worktree-summary
# ============================================================

rws_update_worktree_summary() {
  _uwtsub_name=""
  _uwtsub_section=""
  _uwtsub_replace="false"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --replace)
        _uwtsub_replace="true"
        shift
        ;;
      *)
        if [ -z "$_uwtsub_section" ]; then
          # Could be name or section — check if it's a valid section
          case "$1" in
            files-changed|decisions|open-items|test-results)
              _uwtsub_section="$1"
              ;;
            *)
              if [ -z "$_uwtsub_name" ]; then
                _uwtsub_name="$1"
              else
                _uwtsub_section="$1"
              fi
              ;;
          esac
        fi
        shift
        ;;
    esac
  done

  if [ -z "$_uwtsub_section" ]; then
    die "Usage: rws update-worktree-summary [name] <section> [--replace]"
  fi

  _uwtsub_name="$(resolve_name "$_uwtsub_name")"
  require_state "$_uwtsub_name" > /dev/null

  update_worktree_summary "$_uwtsub_name" "$_uwtsub_section" "$_uwtsub_replace"
}

