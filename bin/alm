# ============================================================
# alm help — usage information
# ============================================================
cmd_help() {
  cat <<'USAGE'
alm — almanac CLI for planning and knowledge management

Usage: alm <command> [options]

Commands:
  add         Create a new TODO entry
  extract     Extract TODO candidates from row artifacts
  list        List TODOs with optional filtering
  show        Display full detail of a single TODO
  triage      Run dependency graph analysis and generate roadmap
  next        Generate handoff prompts from roadmap
  validate    Validate todos.yaml and observations.yaml against schemas
  render      Generate Markdown from roadmap.yaml
  learn       Knowledge management (list, search, show, promote, add)
  observe     Manage post-ship observations (add, list, show, resolve, dismiss, activate, on-archive)
  rationale   Component rationale management (list, show, add)
  docs        Documentation management (stub)
  specialists Specialist agent management (stub)
  history     Work history and analytics (stub)

Run 'alm <command> --help' for command-specific usage.
USAGE
}

# --- Normalization helper ---

# normalize_todos — call frw normalize-todos if frw is available.
# Runs after any write that mutates todos.yaml.
normalize_todos() {
  if command -v frw >/dev/null 2>&1; then
    frw normalize-todos 2>/dev/null || true
  fi
}

# --- Dependency check ---

require_cmd yq
require_cmd jq

# --- Dispatch ---

cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in
  add)         cmd_add "$@"; normalize_todos ;;
  extract)     cmd_extract "$@" ;;
  list)        cmd_list "$@" ;;
  show)        cmd_show "$@" ;;
  triage)      cmd_triage "$@" ;;
  next)        cmd_next "$@" ;;
  validate)    cmd_validate "$@" ;;
  render)      cmd_render "$@" ;;
  learn)       cmd_learn "$@" ;;
  observe)     cmd_observe "$@" ;;
  rationale)   cmd_rationale "$@" ;;
  docs)        cmd_docs ;;
  specialists) cmd_specialists ;;
  history)     cmd_history ;;
  help|--help|-h) cmd_help ;;
  *)        die "unknown command: $cmd" ;;
esac
