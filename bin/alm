#!/bin/sh
# alm — almanac CLI for planning and knowledge management
# Requires: yq, jq, python3 (for triage/validate), awk (POSIX)
# No daemon, no database. Reads/writes YAML under .furrow/almanac/.
set -eu

# --- Configuration ---

ALM_DIR=".furrow/almanac"
ALM_TODOS="$ALM_DIR/todos.yaml"
ALM_ROADMAP="$ALM_DIR/roadmap.yaml"
ROWS_DIR=".furrow/rows"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SCHEMA_FILE="$SCRIPT_DIR/../adapters/shared/schemas/todos.schema.yaml"

# --- Helpers ---

die() { printf 'alm: %s\n' "$1" >&2; exit "${2:-1}"; }

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "required command not found: $1"
}

now_iso() {
  date -Iseconds
}

ensure_almanac_dir() {
  [ -d "$ALM_DIR" ] || mkdir -p "$ALM_DIR"
}

todos_json() {
  yq -o=json '.' "$ALM_TODOS"
}

slugify() {
  printf '%s' "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | sed 's/[^a-z0-9]/-/g; s/--*/-/g; s/^-//; s/-$//' \
    | cut -c1-50 \
    | sed 's/-$//'
}

# Resolve the todos.yaml path: explicit arg > ALM_TODOS > ./todos.yaml fallback
resolve_todos_path() {
  if [ -n "${1:-}" ]; then
    printf '%s' "$1"
  elif [ -f "$ALM_TODOS" ]; then
    printf '%s' "$ALM_TODOS"
  elif [ -f "./todos.yaml" ]; then
    printf '%s' "./todos.yaml"
  else
    printf '%s' "$ALM_TODOS"
  fi
}

# --- Subcommands ---

# ============================================================
# alm add — create a new TODO entry
# ============================================================
cmd_add() {
  title="" context="" work="" risks="" source_type="manual"
  source_work_unit="" seed_id=""
  refs="" depends="" files=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --title)       shift; title="${1:-}"; shift ;;
      --context)     shift; context="${1:-}"; shift ;;
      --work)        shift; work="${1:-}"; shift ;;
      --risks)       shift; risks="${1:-}"; shift ;;
      --source-type) shift; source_type="${1:-}"; shift ;;
      --source-work-unit) shift; source_work_unit="${1:-}"; shift ;;
      --seed-id)     shift; seed_id="${1:-}"; shift ;;
      --refs)
        shift
        while [ $# -gt 0 ] && case "$1" in --*) false ;; *) true ;; esac; do
          refs="${refs:+$refs|}$1"
          shift
        done
        ;;
      --depends-on)
        shift
        while [ $# -gt 0 ] && case "$1" in --*) false ;; *) true ;; esac; do
          depends="${depends:+$depends|}$1"
          shift
        done
        ;;
      --files-touched)
        shift
        while [ $# -gt 0 ] && case "$1" in --*) false ;; *) true ;; esac; do
          files="${files:+$files|}$1"
          shift
        done
        ;;
      --help|-h)
        printf 'Usage: alm add --title T --context C --work W [--risks R]\n'
        printf '               [--refs R1 R2 ...] [--source-type TYPE]\n'
        printf '               [--source-work-unit NAME] [--seed-id ID]\n'
        printf '               [--depends-on D1 D2 ...] [--files-touched F1 F2 ...]\n'
        return 0
        ;;
      *) die "add: unknown flag: $1" ;;
    esac
  done

  # Validate required flags
  [ -n "$title" ]   || die "add: --title is required"
  [ -n "$context" ] || die "add: --context is required"
  [ -n "$work" ]    || die "add: --work is required"

  ensure_almanac_dir

  # Generate slug
  slug=$(slugify "$title")
  [ -n "$slug" ] || die "add: could not generate slug from title"

  # Handle collision
  if [ -f "$ALM_TODOS" ]; then
    suffix=1
    base_slug="$slug"
    while yq -e ".[] | select(.id == \"$slug\")" "$ALM_TODOS" >/dev/null 2>&1; do
      suffix=$((suffix + 1))
      slug="${base_slug}-${suffix}"
    done
  fi

  ts=$(now_iso)

  # Initialize empty array if file doesn't exist
  if [ ! -f "$ALM_TODOS" ]; then
    printf '[]' > "$ALM_TODOS"
  fi

  # Build the new entry as JSON, then append via yq
  # Build arrays from pipe-separated values
  refs_json="[]"
  if [ -n "$refs" ]; then
    refs_json=$(printf '%s' "$refs" | tr '|' '\n' | jq -R '.' | jq -s '.')
  fi

  depends_json="[]"
  if [ -n "$depends" ]; then
    depends_json=$(printf '%s' "$depends" | tr '|' '\n' | jq -R '.' | jq -s '.')
  fi

  files_json="[]"
  if [ -n "$files" ]; then
    files_json=$(printf '%s' "$files" | tr '|' '\n' | jq -R '.' | jq -s '.')
  fi

  # Build the entry JSON
  entry=$(jq -n \
    --arg id "$slug" \
    --arg title "$title" \
    --arg context "$context" \
    --arg work "$work" \
    --arg risks "$risks" \
    --arg source_type "$source_type" \
    --arg source_work_unit "$source_work_unit" \
    --arg seed_id "$seed_id" \
    --arg created_at "$ts" \
    --arg updated_at "$ts" \
    --argjson refs "$refs_json" \
    --argjson depends_on "$depends_json" \
    --argjson files_touched "$files_json" \
    '{
      id: $id,
      title: $title,
      context: $context,
      work_needed: $work,
      source_type: $source_type,
      status: "active",
      created_at: $created_at,
      updated_at: $updated_at
    }
    + (if $risks != "" then {risks: $risks} else {} end)
    + (if ($refs | length) > 0 then {references: $refs} else {} end)
    + (if $source_work_unit != "" then {source_work_unit: $source_work_unit} else {} end)
    + (if $seed_id != "" then {seed_id: $seed_id} else {} end)
    + (if ($depends_on | length) > 0 then {depends_on: $depends_on} else {} end)
    + (if ($files_touched | length) > 0 then {files_touched: $files_touched} else {} end)
    ')

  # Append entry to todos.yaml via temp file + yq eval-all
  entry_tmp=$(mktemp)
  printf '[%s]' "$entry" | yq -P '.' > "$entry_tmp"
  yq eval-all '. as $item ireduce ([]; . + $item)' "$ALM_TODOS" "$entry_tmp" > "${ALM_TODOS}.tmp" && \
    mv "${ALM_TODOS}.tmp" "$ALM_TODOS" && \
    rm -f "$entry_tmp" || {
    rm -f "$entry_tmp" "${ALM_TODOS}.tmp"
    die "add: failed to write entry to $ALM_TODOS"
  }

  # Validate post-write; rollback on failure
  # Run in subshell so validate's exit doesn't kill the parent
  if ! (cmd_validate "$ALM_TODOS" >/dev/null 2>&1); then
    # Remove the last entry
    yq -i 'del(.[-1])' "$ALM_TODOS"
    die "add: validation failed after write; entry removed"
  fi

  printf '%s\n' "$slug"
}

# ============================================================
# alm extract — extract TODO candidates from row artifacts
# ============================================================
cmd_extract() {
  if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    printf 'Usage: alm extract [<row-name>]\n'
    printf '  Extract TODO candidates from row artifacts.\n'
    printf '  If <row-name> omitted, extracts from all rows.\n'
    return 0
  fi

  row_name="${1:-}"

  _tmpdir=$(mktemp -d)
  trap 'rm -rf "$_tmpdir"' EXIT

  if [ -n "$row_name" ]; then
    row_dir="$ROWS_DIR/$row_name"
    [ -d "$row_dir" ] || die "extract: row '$row_name' not found at $row_dir/"
    _extract_row "$row_name" "$_tmpdir"
  else
    # All rows
    if [ ! -d "$ROWS_DIR" ]; then
      printf '[]\n'
      return 0
    fi
    for row_dir in "$ROWS_DIR"/*/; do
      [ -d "$row_dir" ] || continue
      name=$(basename "$row_dir")
      _extract_row "$name" "$_tmpdir"
    done
  fi

  # Merge all per-row results
  if [ -f "$_tmpdir/all.json" ] && [ -s "$_tmpdir/all.json" ]; then
    jq -s 'add // []' "$_tmpdir"/row_*.json 2>/dev/null || printf '[]\n'
  else
    # Check if any row files exist
    found_files=false
    for f in "$_tmpdir"/row_*.json; do
      [ -f "$f" ] && found_files=true && break
    done
    if [ "$found_files" = true ]; then
      jq -s 'add // []' "$_tmpdir"/row_*.json 2>/dev/null || printf '[]\n'
    else
      printf '[]\n'
    fi
  fi
}

_extract_row() {
  name="$1"
  tmpdir="$2"
  row_dir="$ROWS_DIR/$name"

  # Initialize per-source temp files
  printf '[]' > "$tmpdir/${name}_summary.json"
  printf '[]' > "$tmpdir/${name}_learnings.json"
  printf '[]' > "$tmpdir/${name}_reviews.json"

  # Source 1: summary.md Open Questions
  summary_file="$row_dir/summary.md"
  if [ -f "$summary_file" ]; then
    section=$(awk '
      /^## Open Questions/ { found=1; next }
      found && /^## / { exit }
      found { print }
    ' "$summary_file")

    if [ -n "$section" ]; then
      source_file="$ROWS_DIR/${name}/summary.md"
      printf '%s\n' "$section" | while IFS= read -r line; do
        trimmed=$(printf '%s' "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        [ -z "$trimmed" ] && continue
        printf '%s' "$trimmed" | jq -R --arg source "summary-open-questions" \
          --arg name "$name" \
          --arg source_file "$source_file" \
          '{
            source: $source,
            title: (if (. | length) > 80 then (.[:80] + "...") else . end),
            context: ("Open question from " + $name + " row"),
            raw_content: .,
            source_file: $source_file
          }'
      done | jq -s '.' > "$tmpdir/${name}_summary.json" 2>/dev/null || true
    fi
  fi

  # Source 2: learnings.jsonl unpromoted pitfalls
  learnings_file="$row_dir/learnings.jsonl"
  if [ -f "$learnings_file" ]; then
    source_file="$ROWS_DIR/${name}/learnings.jsonl"
    while IFS= read -r line; do
      printf '%s' "$line" | jq -c --arg name "$name" --arg source_file "$source_file" '
        select(.category == "pitfall" and .promoted == false) |
        {
          source: "learnings-pitfall",
          title: (if (.content | length) > 80 then (.content[:80] + "...") else .content end),
          context: (.context // ("Pitfall from " + $name + " row")),
          raw_content: (. | tostring),
          source_file: $source_file
        }
      ' 2>/dev/null || true
    done < "$learnings_file" | jq -s '.' > "$tmpdir/${name}_learnings.json" 2>/dev/null || true
  fi

  # Source 3: reviews/*.json non-pass dimensions
  reviews_dir="$row_dir/reviews"
  if [ -d "$reviews_dir" ]; then
    : > "$tmpdir/${name}_review_candidates.jsonl"

    for review_file in "$reviews_dir"/*.json; do
      [ -f "$review_file" ] || continue

      basename_file=$(basename "$review_file")
      source_file="$ROWS_DIR/${name}/reviews/${basename_file}"
      stem="${basename_file%.json}"

      # Skip malformed JSON
      jq -e '.' "$review_file" > /dev/null 2>&1 || continue

      deliverable=$(jq -r --arg stem "$stem" '.deliverable // $stem' "$review_file" 2>/dev/null) || deliverable="$stem"

      jq -c --arg deliverable "$deliverable" --arg source_file "$source_file" '
        .phase_b.dimensions // [] | .[] |
        select(.verdict != "pass") |
        {
          source: "review-finding",
          title: ("Review finding: " + .name + " (" + .verdict + ")"),
          context: (.evidence // ("Non-pass dimension in " + $deliverable + " review")),
          raw_content: ({deliverable: $deliverable} + . | tostring),
          source_file: $source_file
        }
      ' "$review_file" 2>/dev/null >> "$tmpdir/${name}_review_candidates.jsonl" || true
    done

    if [ -s "$tmpdir/${name}_review_candidates.jsonl" ]; then
      jq -s '.' "$tmpdir/${name}_review_candidates.jsonl" > "$tmpdir/${name}_reviews.json" 2>/dev/null || true
    fi
  fi

  # Merge per-source into per-row result
  jq -s 'add // []' \
    "$tmpdir/${name}_summary.json" \
    "$tmpdir/${name}_learnings.json" \
    "$tmpdir/${name}_reviews.json" \
    > "$tmpdir/row_${name}.json" 2>/dev/null || printf '[]' > "$tmpdir/row_${name}.json"
}

# ============================================================
# alm list — list TODOs with optional filtering
# ============================================================
cmd_list() {
  show_seed=false
  status_filter=""
  json_output=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --seed)   show_seed=true; shift ;;
      --status) shift; status_filter="${1:-}"; shift ;;
      --json)   json_output=true; shift ;;
      --help|-h)
        printf 'Usage: alm list [--seed] [--status S] [--json]\n'
        printf '  --seed    Show seed_id column with linked seed status\n'
        printf '  --status  Filter by: active|done|blocked|deferred\n'
        printf '  --json    Output as JSON array\n'
        return 0
        ;;
      *) die "list: unknown flag: $1" ;;
    esac
  done

  todos_path=$(resolve_todos_path "")
  [ -f "$todos_path" ] || die "list: todos file not found: $todos_path" 1

  todos=$(yq -o=json '.' "$todos_path") || die "list: failed to parse $todos_path"

  # Apply status filter
  if [ -n "$status_filter" ]; then
    todos=$(printf '%s' "$todos" | jq --arg s "$status_filter" '[.[] | select(.status == $s)]')
  fi

  # JSON output mode
  if [ "$json_output" = true ]; then
    printf '%s\n' "$todos"
    return 0
  fi

  # Table output
  if [ "$show_seed" = true ]; then
    printf '%-24s %-9s %-9s %-17s %-14s %s\n' "ID" "STATUS" "URGENCY" "SEED" "SEED STATUS" "TITLE"
    printf '%s\n' "$todos" | jq -r '.[] | [.id, (.status // "-"), (.urgency // "-"), (.seed_id // "-"), .title] | @tsv' | \
    while IFS="$(printf '\t')" read -r id status urgency seed_id title; do
      seed_status="-"
      if [ "$seed_id" != "-" ] && [ -n "$seed_id" ] && [ "$seed_id" != "null" ]; then
        seed_status=$(sds show "$seed_id" --json 2>/dev/null | jq -r '.status // "(unknown)"' 2>/dev/null) || seed_status="(unknown)"
        [ -z "$seed_status" ] && seed_status="(unknown)"
        [ "$seed_status" = "null" ] && seed_status="(unknown)"
      fi
      printf '%-24s %-9s %-9s %-17s %-14s %s\n' "$id" "$status" "$urgency" "$seed_id" "$seed_status" "$title"
    done
  else
    printf '%-24s %-9s %-9s %s\n' "ID" "STATUS" "URGENCY" "TITLE"
    printf '%s\n' "$todos" | jq -r '.[] | [.id, (.status // "-"), (.urgency // "-"), .title] | @tsv' | \
    while IFS="$(printf '\t')" read -r id status urgency title; do
      printf '%-24s %-9s %-9s %s\n' "$id" "$status" "$urgency" "$title"
    done
  fi
}

# ============================================================
# alm show — display full TODO detail
# ============================================================
cmd_show() {
  if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    printf 'Usage: alm show <id>\n'
    return 0
  fi

  [ -n "${1:-}" ] || die "show: <id> argument required"
  target_id="$1"

  todos_path=$(resolve_todos_path "")
  [ -f "$todos_path" ] || die "show: todos file not found: $todos_path" 1

  entry=$(yq -o=json ".[] | select(.id == \"$target_id\")" "$todos_path" 2>/dev/null)
  [ -n "$entry" ] || die "show: TODO not found: $target_id"

  # Display fields
  printf 'TODO: %s\n' "$(printf '%s' "$entry" | jq -r '.id')"
  printf 'Status: %s\n' "$(printf '%s' "$entry" | jq -r '.status // "active"')"
  printf 'Title: %s\n' "$(printf '%s' "$entry" | jq -r '.title')"

  _ctx=$(printf '%s' "$entry" | jq -r '.context // empty')
  if [ -n "$_ctx" ]; then
    printf 'Context:\n'
    printf '%s\n' "$_ctx" | sed 's/^/  /'
  fi

  _work=$(printf '%s' "$entry" | jq -r '.work_needed // empty')
  if [ -n "$_work" ]; then
    printf 'Work Needed:\n'
    printf '%s\n' "$_work" | sed 's/^/  /'
  fi

  _risks=$(printf '%s' "$entry" | jq -r '.risks // empty')
  if [ -n "$_risks" ]; then
    printf 'Risks:\n'
    printf '%s\n' "$_risks" | sed 's/^/  /'
  fi

  _refs=$(printf '%s' "$entry" | jq -r 'if .references then .references[] else empty end' 2>/dev/null)
  if [ -n "$_refs" ]; then
    printf 'References:\n'
    printf '%s\n' "$_refs" | sed 's/^/  - /'
  fi

  _source=$(printf '%s' "$entry" | jq -r '.source_type // empty')
  [ -n "$_source" ] && printf 'Source: %s\n' "$_source"

  _swu=$(printf '%s' "$entry" | jq -r '.source_work_unit // empty')
  [ -n "$_swu" ] && printf 'Source Work Unit: %s\n' "$_swu"

  printf 'Created: %s\n' "$(printf '%s' "$entry" | jq -r '.created_at')"
  printf 'Updated: %s\n' "$(printf '%s' "$entry" | jq -r '.updated_at')"

  _deps=$(printf '%s' "$entry" | jq -r 'if .depends_on then .depends_on | join(", ") else empty end' 2>/dev/null)
  [ -n "$_deps" ] && printf 'Depends On: %s\n' "$_deps"

  _files=$(printf '%s' "$entry" | jq -r 'if .files_touched then .files_touched | join(", ") else empty end' 2>/dev/null)
  [ -n "$_files" ] && printf 'Files Touched: %s\n' "$_files"

  # Urgency / Impact / Effort
  _urg=$(printf '%s' "$entry" | jq -r '.urgency // empty')
  [ -n "$_urg" ] && printf 'Urgency: %s\n' "$_urg"
  _imp=$(printf '%s' "$entry" | jq -r '.impact // empty')
  [ -n "$_imp" ] && printf 'Impact: %s\n' "$_imp"
  _eff=$(printf '%s' "$entry" | jq -r '.effort // empty')
  [ -n "$_eff" ] && printf 'Effort: %s\n' "$_eff"

  # Seed linkage
  _seed=$(printf '%s' "$entry" | jq -r '.seed_id // empty')
  if [ -n "$_seed" ]; then
    printf 'Seed: %s\n' "$_seed"
    _seed_status=$(sds show "$_seed" --json 2>/dev/null | jq -r '.status // "(unknown)"' 2>/dev/null) || _seed_status="(unknown)"
    [ -z "$_seed_status" ] && _seed_status="(unknown)"
    [ "$_seed_status" = "null" ] && _seed_status="(unknown)"
    printf 'Seed Status: %s\n' "$_seed_status"
  fi
}

# ============================================================
# alm triage — dependency graph analysis + roadmap generation
# ============================================================
cmd_triage() {
  full_mode=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --full) full_mode=true; shift ;;
      --help|-h)
        printf 'Usage: alm triage [--full]\n'
        printf '  --full  Regenerate all phases from scratch\n'
        return 0
        ;;
      *) die "triage: unknown flag: $1" ;;
    esac
  done

  require_cmd python3

  todos_path=$(resolve_todos_path "")
  [ -f "$todos_path" ] || die "triage: todos file not found: $todos_path" 2

  # Validate first
  if ! cmd_validate "$todos_path" >/dev/null 2>&1; then
    die "triage: todos.yaml failed validation" 3
  fi

  todos=$(yq -o=json '.' "$todos_path") || die "triage: failed to parse $todos_path" 3

  # Step 1: Python graph analysis (Kahn's algorithm)
  python_errors=$(mktemp)
  _old_trap=$(trap -p EXIT | sed "s/^trap -- '//;s/' EXIT$//")
  trap "rm -f \"$python_errors\"; $_old_trap" EXIT

  graph_output=$(python3 -c "
import json, sys

todos = json.loads(sys.argv[1])

# Filter: only active and blocked TODOs (skip done, deferred)
active = [t for t in todos if t.get('status', 'active') not in ('done', 'deferred')]

if not active:
    print(json.dumps({
        'todos': [],
        'graph': {'topo_order': [], 'waves': [], 'cycles': []},
        'conflicts': []
    }))
    sys.exit(0)

ids = {t['id'] for t in active}
all_ids = {t['id'] for t in todos}
graph = {}

for t in active:
    tid = t['id']
    deps = t.get('depends_on') or []
    for dep in deps:
        if dep not in all_ids:
            print(f'Error: dangling dependency: {tid} depends on {dep} which does not exist', file=sys.stderr)
            sys.exit(1)
    active_deps = [d for d in deps if d in ids]
    graph[tid] = active_deps

# Build reverse graph
reverse = {n: [] for n in ids}
for node, deps in graph.items():
    for dep in deps:
        reverse[dep].append(node)

# Kahn's algorithm
in_degree = {n: len(graph[n]) for n in ids}
queue = sorted([n for n in ids if in_degree[n] == 0])
topo_order = []

while queue:
    current = sorted(queue)
    queue = []
    for node in current:
        topo_order.append(node)
    for node in current:
        for dependent in reverse.get(node, []):
            in_degree[dependent] -= 1
            if in_degree[dependent] == 0:
                queue.append(dependent)

# Cycle detection
if len(topo_order) != len(ids):
    remaining = sorted(ids - set(topo_order))
    print(f'Error: dependency cycle involving: {\" -> \".join(remaining)}', file=sys.stderr)
    sys.exit(1)

# Assign wave numbers
wave_map = {}
for node in topo_order:
    deps = graph[node]
    if not deps:
        wave_map[node] = 1
    else:
        wave_map[node] = max(wave_map[dep] for dep in deps) + 1

max_wave = max(wave_map.values()) if wave_map else 0
waves = []
for w in range(1, max_wave + 1):
    wave_todos = sorted([n for n, wv in wave_map.items() if wv == w])
    waves.append({'wave': w, 'todos': wave_todos})

todo_output = []
for t in active:
    tid = t['id']
    todo_output.append({
        'id': tid,
        'title': t.get('title', ''),
        'depends_on': t.get('depends_on') or [],
        'files_touched': t.get('files_touched') or [],
        'urgency': t.get('urgency'),
        'impact': t.get('impact'),
        'effort': t.get('effort'),
        'status': t.get('status', 'active'),
        'wave': wave_map.get(tid, 1)
    })

result = {
    'todos': todo_output,
    'graph': {
        'topo_order': topo_order,
        'waves': waves,
        'cycles': []
    }
}

print(json.dumps(result))
" "$todos" 2>"$python_errors") || {
    cat "$python_errors" >&2
    die "triage: graph analysis failed" 3
  }

  if [ -s "$python_errors" ]; then
    cat "$python_errors" >&2
    die "triage: graph analysis failed" 3
  fi

  # Validate JSON output
  printf '%s' "$graph_output" | jq empty 2>/dev/null || die "triage: graph analysis produced invalid JSON" 3

  # Step 2: Detect file conflicts within waves
  conflicts=$(printf '%s' "$graph_output" | jq '
    .graph.waves as $waves |
    .todos as $todos |
    ($todos | map({key: .id, value: .files_touched}) | from_entries) as $files |
    [
      $waves[] |
      .todos as $wave_todos |
      .wave as $wave_num |
      [range($wave_todos | length)] as $indices |
      $indices[] as $i |
      $indices[] as $j |
      select($i < $j) |
      $wave_todos[$i] as $a |
      $wave_todos[$j] as $b |
      $files[$a] as $files_a |
      $files[$b] as $files_b |
      select(($files_a | length) > 0 and ($files_b | length) > 0) |
      [
        $files_a[] as $fa |
        $files_b[] as $fb |
        select(
          ($fa | test($fb | gsub("/$"; "/**") | gsub("\\*\\*"; "\u0000") | gsub("\\*"; "[^/]*") | gsub("\u0000"; ".*"))) or
          ($fb | test($fa | gsub("/$"; "/**") | gsub("\\*\\*"; "\u0000") | gsub("\\*"; "[^/]*") | gsub("\u0000"; ".*")))
        ) |
        ($fa, $fb)
      ] | unique as $overlaps |
      select(($overlaps | length) > 0) |
      {
        phase: $wave_num,
        file_pattern: ($overlaps | join(", ")),
        work_units: [$a, $b],
        severity: (if ($overlaps | length) > 3 then "high" elif ($overlaps | length) > 1 then "medium" else "low" end),
        mitigation: "sequential ordering"
      }
    ]
  ')

  # Step 3: Build full analysis output (backward compat with triage-todos.sh)
  analysis=$(printf '%s' "$graph_output" | jq --argjson conflicts "$conflicts" '.conflicts = $conflicts')

  # Step 4: Generate roadmap.yaml
  ensure_almanac_dir

  ts=$(now_iso)

  # Build dependency graph nodes and edges for roadmap
  dep_graph=$(printf '%s' "$analysis" | jq '{
    nodes: [.todos[] | {id: .id, label: .title, phase: .wave, status: .status}],
    edges: [.todos[] | . as $t | (.depends_on // [])[] | {from: $t.id, to: ., kind: "hard", reason: "explicit depends_on"}],
    waves: .graph.waves
  }')

  # Build deferred list
  deferred=$(yq -o=json '.' "$todos_path" | jq '[.[] | select(.status == "deferred") | {id: .id, title: .title, reason: "deferred by triage"}]')

  # Build phases from waves
  phases=$(printf '%s' "$analysis" | jq --arg ts "$ts" '[
    .graph.waves[] | {
      number: .wave,
      title: ("Phase " + (.wave | tostring)),
      status: "planned",
      rationale: "Wave " + (.wave | tostring) + " of dependency graph",
      work_units: [.todos | to_entries[] | {
        index: (.key + 1),
        branch_name: ("work/" + .value),
        description: .value,
        todos: [.value],
        depends_on: [],
        key_files: [],
        conflict_risk: "none",
        completed_at: null
      }]
    }
  ]')

  # If not --full and existing roadmap, preserve done phases
  if [ "$full_mode" = false ] && [ -f "$ALM_ROADMAP" ]; then
    existing_phases=$(yq -o=json '.phases // []' "$ALM_ROADMAP" 2>/dev/null) || existing_phases="[]"
    done_phases=$(printf '%s' "$existing_phases" | jq '[.[] | select(.status == "done")]')
    done_count=$(printf '%s' "$done_phases" | jq 'length')

    # Merge: keep done phases, replace the rest with new analysis
    if [ "$done_count" -gt 0 ]; then
      phases=$(jq -n --argjson done "$done_phases" --argjson new "$phases" '$done + $new')
    fi
  fi

  total_phases=$(printf '%s' "$phases" | jq 'length')
  completed_phases=$(printf '%s' "$phases" | jq '[.[] | select(.status == "done")] | length')

  # Assemble roadmap
  roadmap=$(jq -n \
    --arg ts "$ts" \
    --argjson total "$total_phases" \
    --argjson completed "$completed_phases" \
    --argjson dep_graph "$dep_graph" \
    --argjson conflicts "$conflicts" \
    --argjson phases "$phases" \
    --argjson deferred "$deferred" \
    '{
      schema_version: "1.0",
      metadata: {
        project: "furrow",
        generated_at: $ts,
        total_phases: $total,
        completed_phases: $completed
      },
      dependency_graph: $dep_graph,
      conflict_zones: $conflicts,
      phases: $phases,
      deferred: $deferred,
      handoff: {
        template: "Start with: `/work {branch_name} — {description}`\nSource TODOs: {todo_ids}\nKey files: {key_files}"
      }
    }')

  # Write roadmap.yaml
  printf '%s' "$roadmap" | yq -P '.' > "$ALM_ROADMAP"

  # Output analysis JSON to stdout
  printf '%s\n' "$analysis"
}

# ============================================================
# alm next — generate handoff prompts from roadmap
# ============================================================
cmd_next() {
  phase_num=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --phase) shift; phase_num="${1:-}"; shift ;;
      --help|-h)
        printf 'Usage: alm next [--phase N]\n'
        printf '  Generate handoff prompts for the next phase of work.\n'
        return 0
        ;;
      *) die "next: unknown flag: $1" ;;
    esac
  done

  # Try roadmap.yaml, fall back to ROADMAP.md
  if [ -f "$ALM_ROADMAP" ]; then
    roadmap_file="$ALM_ROADMAP"
  elif [ -f "ROADMAP.md" ]; then
    # Markdown fallback: just print it and exit
    printf 'Note: using ROADMAP.md fallback (no roadmap.yaml found)\n\n' >&2
    cat "ROADMAP.md"
    return 0
  else
    die "next: roadmap not found at $ALM_ROADMAP"
  fi

  roadmap=$(yq -o=json '.' "$roadmap_file") || die "next: failed to parse $roadmap_file"

  # Determine target phase
  if [ -n "$phase_num" ]; then
    phase=$(printf '%s' "$roadmap" | jq --argjson n "$phase_num" '.phases[] | select(.number == $n)')
    [ -n "$phase" ] || die "next: phase $phase_num not found"
  else
    phase=$(printf '%s' "$roadmap" | jq 'first(.phases[] | select(.status != "done"))')
    [ -n "$phase" ] && [ "$phase" != "null" ] || die "next: all phases are done"
  fi

  # Get handoff template
  template=$(printf '%s' "$roadmap" | jq -r '.handoff.template // "Start with: `/work {branch_name} — {description}`\nSource TODOs: {todo_ids}\nKey files: {key_files}"')

  phase_title=$(printf '%s' "$phase" | jq -r '.title // ("Phase " + (.number | tostring))')
  printf '=== %s ===\n\n' "$phase_title"

  # Generate a handoff prompt for each work unit
  printf '%s' "$phase" | jq -r '.work_units[]' 2>/dev/null | jq -r '
    "Start with: `/work " + .branch_name + " — " + .description + "`\n" +
    "Source TODOs: " + (.todos | join(", ")) + "\n" +
    "Key files: " + (if (.key_files | length) > 0 then (.key_files | join(", ")) else "(none specified)" end) + "\n"
  '
}

# ============================================================
# alm validate — validate todos.yaml against schema
# ============================================================
cmd_validate() {
  if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    printf 'Usage: alm validate [<path>]\n'
    printf '  Default path: %s (fallback: ./todos.yaml)\n' "$ALM_TODOS"
    return 0
  fi

  todos_path=$(resolve_todos_path "${1:-}")
  errors=""

  [ -f "$todos_path" ] || die "validate: file not found: $todos_path" 2

  if [ ! -f "$SCHEMA_FILE" ]; then
    die "validate: schema not found: $SCHEMA_FILE" 2
  fi

  # Step 1: Schema validation (requires yq + python3)
  if command -v yq >/dev/null 2>&1 && command -v python3 >/dev/null 2>&1; then
    json_tmp=$(mktemp)
    schema_tmp=$(mktemp)
    _old_trap=$(trap -p EXIT | sed "s/^trap -- '//;s/' EXIT$//")
    trap "rm -f \"$json_tmp\" \"$schema_tmp\"; $_old_trap" EXIT

    if ! yq -o=json '.' "$todos_path" > "$json_tmp" 2>/dev/null; then
      errors="${errors}Invalid YAML syntax in $todos_path\n"
    elif ! yq -o=json '.' "$SCHEMA_FILE" > "$schema_tmp" 2>/dev/null; then
      errors="${errors}Invalid YAML syntax in schema: $SCHEMA_FILE\n"
    else
      schema_errors=$(python3 -c "
import json, sys
try:
    from jsonschema import Draft202012Validator, FormatChecker
except ImportError:
    try:
        from jsonschema import Draft7Validator as Draft202012Validator
        FormatChecker = None
    except ImportError:
        print('SKIP: jsonschema not installed', file=sys.stderr)
        sys.exit(0)
with open(sys.argv[1]) as f:
    schema = json.load(f)
with open(sys.argv[2]) as f:
    instance = json.load(f)
kwargs = {}
if FormatChecker is not None:
    try:
        kwargs['format_checker'] = FormatChecker()
    except Exception:
        pass
validator = Draft202012Validator(schema, **kwargs)
errs = sorted(validator.iter_errors(instance), key=lambda e: list(e.path))
for e in errs:
    path = '.'.join(str(p) for p in e.absolute_path) or '(root)'
    print(f'Schema error at {path}: {e.message}')
" "$schema_tmp" "$json_tmp" 2>&1)
      if [ -n "$schema_errors" ]; then
        errors="${errors}${schema_errors}\n"
      fi
    fi
  elif command -v yq >/dev/null 2>&1; then
    printf 'Warning: python3 not found; skipping schema validation\n' >&2
  else
    printf 'Warning: yq not found; skipping all validation\n' >&2
    printf 'todos.yaml is valid\n'
    return 0
  fi

  # Step 2: Cross-field checks — unique IDs
  if command -v yq >/dev/null 2>&1; then
    ids=$(yq -r '.[].id' "$todos_path" 2>/dev/null) || ids=""
    if [ -n "$ids" ]; then
      dupes=$(printf '%s\n' "$ids" | sort | uniq -d)
      if [ -n "$dupes" ]; then
        for dupe in $dupes; do
          errors="${errors}Duplicate TODO id: ${dupe}\n"
        done
      fi
    fi
  fi

  # Step 3: Cross-field checks — dependency references
  if command -v yq >/dev/null 2>&1; then
    all_ids=$(yq -r '.[].id' "$todos_path" 2>/dev/null | sort) || all_ids=""
    dep_ids=$(yq -r '.[] | (.depends_on // [])[]' "$todos_path" 2>/dev/null | sort -u) || dep_ids=""
    if [ -n "$dep_ids" ]; then
      for dep in $dep_ids; do
        if ! printf '%s\n' "$all_ids" | grep -qx "$dep"; then
          errors="${errors}Dangling dependency: $dep does not exist\n"
        fi
      done
    fi
  fi

  # Step 4: Cross-field checks — slug format
  if command -v yq >/dev/null 2>&1; then
    bad_ids=$(yq -r '.[].id' "$todos_path" 2>/dev/null | grep -v -E '^[a-z][a-z0-9]*(-[a-z0-9]+)*$' || true)
    if [ -n "$bad_ids" ]; then
      for bad in $bad_ids; do
        errors="${errors}Invalid slug format: $bad\n"
      done
    fi
  fi

  # Report results
  if [ -n "$errors" ]; then
    printf '%b' "$errors" | sed '/^$/d' >&2
    exit 3
  fi

  printf 'todos.yaml is valid\n'
}

# ============================================================
# alm render — generate Markdown from roadmap.yaml
# ============================================================
cmd_render() {
  output_path=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --output) shift; output_path="${1:-}"; shift ;;
      --help|-h)
        printf 'Usage: alm render [--output PATH]\n'
        printf '  Generate Markdown from roadmap.yaml.\n'
        printf '  Default output: stdout\n'
        return 0
        ;;
      *) die "render: unknown flag: $1" ;;
    esac
  done

  [ -f "$ALM_ROADMAP" ] || die "render: roadmap not found at $ALM_ROADMAP"

  roadmap=$(yq -o=json '.' "$ALM_ROADMAP") || die "render: failed to parse $ALM_ROADMAP"

  md=$(printf '%s' "$roadmap" | jq -r '
    # Header
    "# Roadmap\n\n" +
    "**Updated:** " + .metadata.generated_at + "  \n" +
    "**Progress:** " + (.metadata.completed_phases | tostring) + "/" + (.metadata.total_phases | tostring) + " phases completed\n\n" +

    # Dependency DAG
    "## Dependency Graph\n\n```\n" +
    (if (.dependency_graph.edges | length) > 0 then
      ([.dependency_graph.edges[] | .from + " --> " + .to + "  (" + .kind + ")"] | join("\n"))
    else
      "(no dependencies)"
    end) +
    "\n```\n\n" +

    # Legend
    "## Legend\n\n" +
    "- `-->` hard dependency (explicit depends_on)\n" +
    "- `..>` inferred dependency (file conflict)\n" +
    "- Phase N = Nth wave of parallelizable work\n\n" +

    # Conflict Zones
    "## Conflict Zones\n\n" +
    (if (.conflict_zones | length) > 0 then
      "| Phase | Pattern | Work Units | Severity | Mitigation |\n" +
      "|-------|---------|------------|----------|------------|\n" +
      ([.conflict_zones[] |
        "| " + (.phase | tostring) + " | " + .file_pattern + " | " + (.work_units | join(", ")) + " | " + .severity + " | " + .mitigation + " |"
      ] | join("\n")) + "\n\n"
    else
      "No file conflicts detected.\n\n"
    end) +

    # Phases
    ([.phases[] |
      "## Phase " + (.number | tostring) + ": " + .title + "\n\n" +
      "**Status:** " + .status + "  \n" +
      "**Rationale:** " + (.rationale // "-") + "\n\n" +
      ([.work_units[] |
        "### " + (.index | tostring) + ". " + .branch_name + "\n\n" +
        .description + "\n\n" +
        "- **TODOs:** " + (.todos | join(", ")) + "\n" +
        "- **Key files:** " + (if (.key_files | length) > 0 then (.key_files | join(", ")) else "(none)" end) + "\n" +
        "- **Conflict risk:** " + .conflict_risk + "\n" +
        (if .completed_at then "- **Completed:** " + .completed_at + "\n" else "" end)
      ] | join("\n"))
    ] | join("\n")) +

    # Deferred
    (if (.deferred | length) > 0 then
      "\n## Deferred\n\n" +
      ([.deferred[] | "- **" + .id + "**: " + .title + " — " + (.reason // "no reason given")] | join("\n")) + "\n"
    else
      ""
    end) +

    # Worktree Commands
    "\n## Worktree Commands\n\n```sh\n" +
    ([.phases[] | select(.status != "done") |
      "# Phase " + (.number | tostring) + "\n" +
      ([.work_units[] | "git worktree add ../wt-" + .branch_name + " -b " + .branch_name] | join("\n"))
    ] | join("\n\n")) +
    "\n```\n"
  ')

  if [ -n "$output_path" ]; then
    printf '%s\n' "$md" > "$output_path"
    printf 'Wrote %s\n' "$output_path" >&2
  else
    printf '%s\n' "$md"
  fi
}

# ============================================================
# alm learn — knowledge management lifecycle
# ============================================================
cmd_learn() {
  subcmd="${1:-}"
  [ -n "$subcmd" ] || die "learn: subcommand required (list|search|show|promote|add)"
  shift

  case "$subcmd" in
    list)    _learn_list "$@" ;;
    search)  _learn_search "$@" ;;
    show)    _learn_show "$@" ;;
    promote) _learn_promote "$@" ;;
    add)     _learn_add "$@" ;;
    --help|-h)
      printf 'Usage: alm learn <subcommand> [options]\n\n'
      printf 'Subcommands:\n'
      printf '  list    [--row NAME]                              List all learnings\n'
      printf '  search  <query>                                   Search across all learnings\n'
      printf '  show    <row> <index>                             Show full learning detail\n'
      printf '  promote <row> [--all|--id INDEX]                  Promote to almanac\n'
      printf '  add     <row> --category C --content C --context C  Add a learning\n'
      return 0
      ;;
    *) die "learn: unknown subcommand: $subcmd" ;;
  esac
}

_learn_list() {
  row_filter=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --row) shift; row_filter="${1:-}"; shift ;;
      --help|-h)
        printf 'Usage: alm learn list [--row NAME]\n'
        return 0
        ;;
      *) die "learn list: unknown flag: $1" ;;
    esac
  done

  printf '%-24s %-12s %-8s %s\n' "ROW" "CATEGORY" "PROMOTED" "CONTENT"

  # Scan per-row learnings
  if [ -d "$ROWS_DIR" ]; then
    for row_dir in "$ROWS_DIR"/*/; do
      [ -d "$row_dir" ] || continue
      name=$(basename "$row_dir")
      [ -n "$row_filter" ] && [ "$name" != "$row_filter" ] && continue
      lfile="$row_dir/learnings.jsonl"
      [ -f "$lfile" ] || continue
      while IFS= read -r line; do
        [ -z "$line" ] && continue
        _category=$(printf '%s' "$line" | jq -r '.category // "-"')
        _promoted=$(printf '%s' "$line" | jq -r 'if .promoted == true then "yes" else "no" end')
        _content=$(printf '%s' "$line" | jq -r '.content // "-"')
        _trunc=$(printf '%.60s' "$_content")
        [ ${#_content} -gt 60 ] && _trunc="${_trunc}..."
        printf '%-24s %-12s %-8s %s\n' "$name" "$_category" "$_promoted" "$_trunc"
      done < "$lfile"
    done
  fi

  # Scan promoted learnings
  promoted_dir="$ALM_DIR/learnings"
  if [ -d "$promoted_dir" ]; then
    for pfile in "$promoted_dir"/*.jsonl; do
      [ -f "$pfile" ] || continue
      pname=$(basename "$pfile" .jsonl)
      [ -n "$row_filter" ] && [ "$pname" != "$row_filter" ] && continue
      while IFS= read -r line; do
        [ -z "$line" ] && continue
        # Skip if already shown from row source
        _promoted=$(printf '%s' "$line" | jq -r 'if .promoted == true then "yes" else "no" end')
        _category=$(printf '%s' "$line" | jq -r '.category // "-"')
        _content=$(printf '%s' "$line" | jq -r '.content // "-"')
        _trunc=$(printf '%.60s' "$_content")
        [ ${#_content} -gt 60 ] && _trunc="${_trunc}..."
        printf '%-24s %-12s %-8s %s\n' "$pname(promoted)" "$_category" "$_promoted" "$_trunc"
      done < "$pfile"
    done
  fi
}

_learn_search() {
  [ -n "${1:-}" ] || die "learn search: <query> argument required"
  query="$1"

  # Search per-row learnings
  if [ -d "$ROWS_DIR" ]; then
    for row_dir in "$ROWS_DIR"/*/; do
      [ -d "$row_dir" ] || continue
      name=$(basename "$row_dir")
      lfile="$row_dir/learnings.jsonl"
      [ -f "$lfile" ] || continue
      matches=$(grep -inF "$query" "$lfile" 2>/dev/null) || true
      if [ -n "$matches" ]; then
        printf '%s\n' "$matches" | while IFS= read -r match; do
          printf '[row:%s] %s\n' "$name" "$match"
        done
      fi
    done
  fi

  # Search promoted learnings
  promoted_dir="$ALM_DIR/learnings"
  if [ -d "$promoted_dir" ]; then
    for pfile in "$promoted_dir"/*.jsonl; do
      [ -f "$pfile" ] || continue
      pname=$(basename "$pfile" .jsonl)
      matches=$(grep -inF "$query" "$pfile" 2>/dev/null) || true
      if [ -n "$matches" ]; then
        printf '%s\n' "$matches" | while IFS= read -r match; do
          printf '[promoted:%s] %s\n' "$pname" "$match"
        done
      fi
    done
  fi
}

_learn_show() {
  [ -n "${1:-}" ] || die "learn show: <row> argument required"
  [ -n "${2:-}" ] || die "learn show: <index> argument required (1-based)"
  row="$1"
  idx="$2"

  # Check row learnings
  lfile="$ROWS_DIR/$row/learnings.jsonl"
  if [ -f "$lfile" ]; then
    line=$(sed -n "${idx}p" "$lfile")
    if [ -n "$line" ]; then
      printf 'Source: row/%s (line %s)\n\n' "$row" "$idx"
      printf '%s\n' "$line" | jq '.'
      return 0
    fi
  fi

  # Check promoted learnings
  pfile="$ALM_DIR/learnings/$row.jsonl"
  if [ -f "$pfile" ]; then
    line=$(sed -n "${idx}p" "$pfile")
    if [ -n "$line" ]; then
      printf 'Source: promoted/%s (line %s)\n\n' "$row" "$idx"
      printf '%s\n' "$line" | jq '.'
      return 0
    fi
  fi

  die "learn show: no learning found at index $idx for row '$row'"
}

_learn_promote() {
  [ -n "${1:-}" ] || die "learn promote: <row> argument required"
  row="$1"
  shift

  promote_all=false
  promote_id=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --all) promote_all=true; shift ;;
      --id)  shift; promote_id="${1:-}"; shift ;;
      --help|-h)
        printf 'Usage: alm learn promote <row> [--all|--id INDEX]\n'
        return 0
        ;;
      *) die "learn promote: unknown flag: $1" ;;
    esac
  done

  lfile="$ROWS_DIR/$row/learnings.jsonl"
  [ -f "$lfile" ] || die "learn promote: no learnings found at $lfile"

  promoted_dir="$ALM_DIR/learnings"
  mkdir -p "$promoted_dir"
  pfile="$promoted_dir/$row.jsonl"

  if [ "$promote_all" = true ]; then
    count=0
    line_num=0
    tmp_source=$(mktemp)
    cp "$lfile" "$tmp_source"
    : > "${lfile}.tmp"

    while IFS= read -r line; do
      line_num=$((line_num + 1))
      [ -z "$line" ] && printf '\n' >> "${lfile}.tmp" && continue
      already=$(printf '%s' "$line" | jq -r '.promoted')
      if [ "$already" = "true" ]; then
        printf '%s\n' "$line" >> "${lfile}.tmp"
        continue
      fi
      promoted_line=$(printf '%s' "$line" | jq -c '.promoted = true')
      printf '%s\n' "$promoted_line" >> "$pfile"
      printf '%s\n' "$promoted_line" >> "${lfile}.tmp"
      count=$((count + 1))
    done < "$tmp_source"

    mv "${lfile}.tmp" "$lfile"
    rm -f "$tmp_source"
    printf 'Promoted %d learning(s) from %s\n' "$count" "$row"

  elif [ -n "$promote_id" ]; then
    line=$(sed -n "${promote_id}p" "$lfile")
    [ -n "$line" ] || die "learn promote: no learning at index $promote_id"

    already=$(printf '%s' "$line" | jq -r '.promoted')
    [ "$already" != "true" ] || die "learn promote: learning at index $promote_id is already promoted"

    promoted_line=$(printf '%s' "$line" | jq -c '.promoted = true')
    printf '%s\n' "$promoted_line" >> "$pfile"

    # Update source entry in-place
    tmp_source=$(mktemp)
    awk -v idx="$promote_id" -v replacement="$promoted_line" \
      'NR == idx { print replacement; next } { print }' "$lfile" > "$tmp_source"
    mv "$tmp_source" "$lfile"

    printf 'Promoted learning %s from %s\n' "$promote_id" "$row"

  else
    die "learn promote: specify --all or --id INDEX"
  fi
}

_learn_add() {
  [ -n "${1:-}" ] || die "learn add: <row> argument required"
  row="$1"
  shift

  category="" content="" context=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --category) shift; category="${1:-}"; shift ;;
      --content)  shift; content="${1:-}"; shift ;;
      --context)  shift; context="${1:-}"; shift ;;
      --help|-h)
        printf 'Usage: alm learn add <row> --category CAT --content C --context CTX\n'
        return 0
        ;;
      *) die "learn add: unknown flag: $1" ;;
    esac
  done

  [ -n "$category" ] || die "learn add: --category is required"
  [ -n "$content" ]  || die "learn add: --content is required"
  [ -n "$context" ]  || die "learn add: --context is required"

  # Validate category
  case "$category" in
    pattern|pitfall|preference|convention|dependency) ;;
    *) die "learn add: invalid category '$category' (must be: pattern, pitfall, preference, convention, dependency)" ;;
  esac

  # Validate row exists
  row_dir="$ROWS_DIR/$row"
  [ -d "$row_dir" ] || die "learn add: row '$row' not found at $row_dir/"

  lfile="$row_dir/learnings.jsonl"

  # Generate ID: {row}-{NNN}
  if [ -f "$lfile" ]; then
    line_count=$(wc -l < "$lfile" | tr -d ' ')
  else
    line_count=0
  fi
  seq_num=$((line_count + 1))
  learning_id=$(printf '%s-%03d' "$row" "$seq_num")

  ts=$(now_iso)

  entry=$(jq -n \
    --arg id "$learning_id" \
    --arg ts "$ts" \
    --arg category "$category" \
    --arg content "$content" \
    --arg context "$context" \
    --arg source_task "$row" \
    '{
      id: $id,
      timestamp: $ts,
      category: $category,
      content: $content,
      context: $context,
      source_task: $source_task,
      source_step: "manual",
      promoted: false
    }')

  printf '%s\n' "$entry" | jq -c '.' >> "$lfile"
  printf '%s\n' "$learning_id"
}

# ============================================================
# alm rationale — component rationale management
# ============================================================
cmd_rationale() {
  subcmd="${1:-}"
  [ -n "$subcmd" ] || die "rationale: subcommand required (list|show|add)"
  shift

  case "$subcmd" in
    list)   _rationale_list "$@" ;;
    show)   _rationale_show "$@" ;;
    add)    _rationale_add "$@" ;;
    --help|-h)
      printf 'Usage: alm rationale <subcommand> [options]\n\n'
      printf 'Subcommands:\n'
      printf '  list                           List all components with rationale\n'
      printf '  show  <component>              Show full rationale for a component\n'
      printf '  add   <component> --reason R   Add or update component rationale\n'
      return 0
      ;;
    *) die "rationale: unknown subcommand: $subcmd" ;;
  esac
}

_rationale_list() {
  rationale_file="$ALM_DIR/rationale.yaml"
  [ -f "$rationale_file" ] || die "rationale list: rationale.yaml not found at $rationale_file"

  printf '%-50s %s\n' "COMPONENT" "EXISTS BECAUSE"
  yq -r '.components[] | [.path, .exists_because] | @tsv' "$rationale_file" | \
  while IFS="$(printf '\t')" read -r path reason; do
    _trunc=$(printf '%.60s' "$reason")
    [ ${#reason} -gt 60 ] && _trunc="${_trunc}..."
    printf '%-50s %s\n' "$path" "$_trunc"
  done
}

_rationale_show() {
  [ -n "${1:-}" ] || die "rationale show: <component> argument required"
  component="$1"

  rationale_file="$ALM_DIR/rationale.yaml"
  [ -f "$rationale_file" ] || die "rationale show: rationale.yaml not found at $rationale_file"

  entry=$(yq -o=json ".components[] | select(.path == \"$component\")" "$rationale_file" 2>/dev/null)
  [ -n "$entry" ] || die "rationale show: component not found: $component"

  printf 'Component: %s\n' "$(printf '%s' "$entry" | jq -r '.path')"
  printf 'Exists Because: %s\n' "$(printf '%s' "$entry" | jq -r '.exists_because')"

  _dw=$(printf '%s' "$entry" | jq -r '.delete_when // empty')
  if [ -n "$_dw" ]; then
    printf 'Delete When: %s\n' "$_dw"
  fi
}

_rationale_add() {
  [ -n "${1:-}" ] || die "rationale add: <component> argument required"
  component="$1"
  shift

  reason=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --reason) shift; reason="${1:-}"; shift ;;
      --help|-h)
        printf 'Usage: alm rationale add <component> --reason "why it exists"\n'
        return 0
        ;;
      *) die "rationale add: unknown flag: $1" ;;
    esac
  done

  [ -n "$reason" ] || die "rationale add: --reason is required"

  rationale_file="$ALM_DIR/rationale.yaml"
  ensure_almanac_dir

  # Create file with empty components array if it doesn't exist
  if [ ! -f "$rationale_file" ]; then
    printf 'components: []\n' > "$rationale_file"
  fi

  # Check if component already exists
  existing=$(yq -o=json ".components[] | select(.path == \"$component\")" "$rationale_file" 2>/dev/null)

  if [ -n "$existing" ]; then
    # Update exists_because for existing component
    yq -i "(.components[] | select(.path == \"$component\")).exists_because = \"$reason\"" "$rationale_file"
    printf 'Updated rationale for %s\n' "$component"
  else
    # Append new entry
    yq -i ".components += [{\"path\": \"$component\", \"exists_because\": \"$reason\"}]" "$rationale_file"
    printf 'Added rationale for %s\n' "$component"
  fi
}

