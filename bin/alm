#!/bin/sh
# alm — almanac CLI for planning and knowledge management
# Requires: yq, jq, python3 (for triage/validate), awk (POSIX)
# No daemon, no database. Reads/writes YAML under .furrow/almanac/.
set -eu

# --- Configuration ---

ALM_DIR=".furrow/almanac"
ALM_TODOS="$ALM_DIR/todos.yaml"
ALM_ROADMAP="$ALM_DIR/roadmap.yaml"
ALM_OBSERVATIONS="${ALM_OBSERVATIONS:-$ALM_DIR/observations.yaml}"
ROWS_DIR=".furrow/rows"
_alm_self="$0"
if [ -L "$_alm_self" ]; then
  _alm_self="$(readlink -f "$_alm_self")"
fi
SCRIPT_DIR="$(cd "$(dirname "$_alm_self")" && pwd)"
SCHEMA_FILE_TODOS="$SCRIPT_DIR/../adapters/shared/schemas/todos.schema.yaml"
SCHEMA_FILE_OBSERVATIONS="$SCRIPT_DIR/../adapters/shared/schemas/observations.schema.yaml"
# Deprecated alias — kept for external compatibility; internal callers use $SCHEMA_FILE_TODOS.
SCHEMA_FILE="$SCHEMA_FILE_TODOS"

# --- Helpers ---

die() { printf 'alm: %s\n' "$1" >&2; exit "${2:-1}"; }

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "required command not found: $1"
}

now_iso() {
  date -Iseconds
}

ensure_almanac_dir() {
  [ -d "$ALM_DIR" ] || mkdir -p "$ALM_DIR"
}

todos_json() {
  yq -o=json '.' "$ALM_TODOS"
}

slugify() {
  printf '%s' "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | sed 's/[^a-z0-9]/-/g; s/--*/-/g; s/^-//; s/-$//' \
    | cut -c1-50 \
    | sed 's/-$//'
}

# Resolve the todos.yaml path: explicit arg > ALM_TODOS
resolve_todos_path() {
  if [ -n "${1:-}" ]; then
    printf '%s' "$1"
  else
    printf '%s' "$ALM_TODOS"
  fi
}

# --- Subcommands ---

# ============================================================
# alm add — create a new TODO entry
# ============================================================
cmd_add() {
  title="" context="" work="" risks="" source_type="manual"
  source_work_unit="" seed_id=""
  refs="" depends="" files=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --title)       shift; title="${1:-}"; shift ;;
      --context)     shift; context="${1:-}"; shift ;;
      --work)        shift; work="${1:-}"; shift ;;
      --risks)       shift; risks="${1:-}"; shift ;;
      --source-type) shift; source_type="${1:-}"; shift ;;
      --source-work-unit) shift; source_work_unit="${1:-}"; shift ;;
      --seed-id)     shift; seed_id="${1:-}"; shift ;;
      --refs)
        shift
        while [ $# -gt 0 ] && case "$1" in --*) false ;; *) true ;; esac; do
          refs="${refs:+$refs|}$1"
          shift
        done
        ;;
      --depends-on)
        shift
        while [ $# -gt 0 ] && case "$1" in --*) false ;; *) true ;; esac; do
          depends="${depends:+$depends|}$1"
          shift
        done
        ;;
      --files-touched)
        shift
        while [ $# -gt 0 ] && case "$1" in --*) false ;; *) true ;; esac; do
          files="${files:+$files|}$1"
          shift
        done
        ;;
      --help|-h)
        printf 'Usage: alm add --title T --context C --work W [--risks R]\n'
        printf '               [--refs R1 R2 ...] [--source-type TYPE]\n'
        printf '               [--source-work-unit NAME] [--seed-id ID]\n'
        printf '               [--depends-on D1 D2 ...] [--files-touched F1 F2 ...]\n'
        return 0
        ;;
      *) die "add: unknown flag: $1" ;;
    esac
  done

  # Validate required flags
  [ -n "$title" ]   || die "add: --title is required"
  [ -n "$context" ] || die "add: --context is required"
  [ -n "$work" ]    || die "add: --work is required"

  ensure_almanac_dir

  # Generate slug
  slug=$(slugify "$title")
  [ -n "$slug" ] || die "add: could not generate slug from title"

  # Handle collision
  if [ -f "$ALM_TODOS" ]; then
    suffix=1
    base_slug="$slug"
    while yq -e ".[] | select(.id == \"$slug\")" "$ALM_TODOS" >/dev/null 2>&1; do
      suffix=$((suffix + 1))
      slug="${base_slug}-${suffix}"
    done
  fi

  ts=$(now_iso)

  # Initialize empty array if file doesn't exist
  if [ ! -f "$ALM_TODOS" ]; then
    printf '[]' > "$ALM_TODOS"
  fi

  # Build the new entry as JSON, then append via yq
  # Build arrays from pipe-separated values
  refs_json="[]"
  if [ -n "$refs" ]; then
    refs_json=$(printf '%s' "$refs" | tr '|' '\n' | jq -R '.' | jq -s '.')
  fi

  depends_json="[]"
  if [ -n "$depends" ]; then
    depends_json=$(printf '%s' "$depends" | tr '|' '\n' | jq -R '.' | jq -s '.')
  fi

  files_json="[]"
  if [ -n "$files" ]; then
    files_json=$(printf '%s' "$files" | tr '|' '\n' | jq -R '.' | jq -s '.')
  fi

  # Build the entry JSON
  entry=$(jq -n \
    --arg id "$slug" \
    --arg title "$title" \
    --arg context "$context" \
    --arg work "$work" \
    --arg risks "$risks" \
    --arg source_type "$source_type" \
    --arg source_work_unit "$source_work_unit" \
    --arg seed_id "$seed_id" \
    --arg created_at "$ts" \
    --arg updated_at "$ts" \
    --argjson refs "$refs_json" \
    --argjson depends_on "$depends_json" \
    --argjson files_touched "$files_json" \
    '{
      id: $id,
      title: $title,
      context: $context,
      work_needed: $work,
      source_type: $source_type,
      status: "active",
      created_at: $created_at,
      updated_at: $updated_at
    }
    + (if $risks != "" then {risks: $risks} else {} end)
    + (if ($refs | length) > 0 then {references: $refs} else {} end)
    + (if $source_work_unit != "" then {source_work_unit: $source_work_unit} else {} end)
    + (if $seed_id != "" then {seed_id: $seed_id} else {} end)
    + (if ($depends_on | length) > 0 then {depends_on: $depends_on} else {} end)
    + (if ($files_touched | length) > 0 then {files_touched: $files_touched} else {} end)
    ')

  # Append entry to todos.yaml via temp file + yq eval-all
  entry_tmp=$(mktemp)
  printf '[%s]' "$entry" | yq -P '.' > "$entry_tmp"
  yq eval-all '. as $item ireduce ([]; . + $item)' "$ALM_TODOS" "$entry_tmp" > "${ALM_TODOS}.tmp" && \
    mv "${ALM_TODOS}.tmp" "$ALM_TODOS" && \
    rm -f "$entry_tmp" || {
    rm -f "$entry_tmp" "${ALM_TODOS}.tmp"
    die "add: failed to write entry to $ALM_TODOS"
  }

  # Validate post-write; rollback on failure
  # Run in subshell so validate's exit doesn't kill the parent
  if ! (cmd_validate "$ALM_TODOS" >/dev/null 2>&1); then
    # Remove the last entry
    yq -i 'del(.[-1])' "$ALM_TODOS"
    die "add: validation failed after write; entry removed"
  fi

  printf '%s\n' "$slug"
}

# ============================================================
# alm extract — extract TODO candidates from row artifacts
# ============================================================
cmd_extract() {
  if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    printf 'Usage: alm extract [<row-name>]\n'
    printf '  Extract TODO candidates from row artifacts.\n'
    printf '  If <row-name> omitted, extracts from all rows.\n'
    return 0
  fi

  row_name="${1:-}"

  _tmpdir=$(mktemp -d)
  trap 'rm -rf "$_tmpdir"' EXIT

  if [ -n "$row_name" ]; then
    row_dir="$ROWS_DIR/$row_name"
    [ -d "$row_dir" ] || die "extract: row '$row_name' not found at $row_dir/"
    _extract_row "$row_name" "$_tmpdir"
  else
    # All rows
    if [ ! -d "$ROWS_DIR" ]; then
      printf '[]\n'
      return 0
    fi
    for row_dir in "$ROWS_DIR"/*/; do
      [ -d "$row_dir" ] || continue
      name=$(basename "$row_dir")
      _extract_row "$name" "$_tmpdir"
    done
  fi

  # Merge all per-row results
  if [ -f "$_tmpdir/all.json" ] && [ -s "$_tmpdir/all.json" ]; then
    jq -s 'add // []' "$_tmpdir"/row_*.json 2>/dev/null || printf '[]\n'
  else
    # Check if any row files exist
    found_files=false
    for f in "$_tmpdir"/row_*.json; do
      [ -f "$f" ] && found_files=true && break
    done
    if [ "$found_files" = true ]; then
      jq -s 'add // []' "$_tmpdir"/row_*.json 2>/dev/null || printf '[]\n'
    else
      printf '[]\n'
    fi
  fi
}

_extract_row() {
  name="$1"
  tmpdir="$2"
  row_dir="$ROWS_DIR/$name"

  # Initialize per-source temp files
  printf '[]' > "$tmpdir/${name}_summary.json"
  printf '[]' > "$tmpdir/${name}_learnings.json"
  printf '[]' > "$tmpdir/${name}_reviews.json"

  # Source 1: summary.md Open Questions
  summary_file="$row_dir/summary.md"
  if [ -f "$summary_file" ]; then
    section=$(awk '
      /^## Open Questions/ { found=1; next }
      found && /^## / { exit }
      found { print }
    ' "$summary_file")

    if [ -n "$section" ]; then
      source_file="$ROWS_DIR/${name}/summary.md"
      printf '%s\n' "$section" | while IFS= read -r line; do
        trimmed=$(printf '%s' "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        [ -z "$trimmed" ] && continue
        printf '%s' "$trimmed" | jq -R --arg source "summary-open-questions" \
          --arg name "$name" \
          --arg source_file "$source_file" \
          '{
            source: $source,
            title: (if (. | length) > 80 then (.[:80] + "...") else . end),
            context: ("Open question from " + $name + " row"),
            raw_content: .,
            source_file: $source_file
          }'
      done | jq -s '.' > "$tmpdir/${name}_summary.json" 2>/dev/null || true
    fi
  fi

  # Source 2: learnings.jsonl unpromoted pitfalls
  learnings_file="$row_dir/learnings.jsonl"
  if [ -f "$learnings_file" ]; then
    source_file="$ROWS_DIR/${name}/learnings.jsonl"
    while IFS= read -r line; do
      printf '%s' "$line" | jq -c --arg name "$name" --arg source_file "$source_file" '
        select(.category == "pitfall" and .promoted == false) |
        {
          source: "learnings-pitfall",
          title: (if (.content | length) > 80 then (.content[:80] + "...") else .content end),
          context: (.context // ("Pitfall from " + $name + " row")),
          raw_content: (. | tostring),
          source_file: $source_file
        }
      ' 2>/dev/null || true
    done < "$learnings_file" | jq -s '.' > "$tmpdir/${name}_learnings.json" 2>/dev/null || true
  fi

  # Source 3: reviews/*.json non-pass dimensions
  reviews_dir="$row_dir/reviews"
  if [ -d "$reviews_dir" ]; then
    : > "$tmpdir/${name}_review_candidates.jsonl"

    for review_file in "$reviews_dir"/*.json; do
      [ -f "$review_file" ] || continue

      basename_file=$(basename "$review_file")
      source_file="$ROWS_DIR/${name}/reviews/${basename_file}"
      stem="${basename_file%.json}"

      # Skip malformed JSON
      jq -e '.' "$review_file" > /dev/null 2>&1 || continue

      deliverable=$(jq -r --arg stem "$stem" '.deliverable // $stem' "$review_file" 2>/dev/null) || deliverable="$stem"

      jq -c --arg deliverable "$deliverable" --arg source_file "$source_file" '
        .phase_b.dimensions // [] | .[] |
        select(.verdict != "pass") |
        {
          source: "review-finding",
          title: ("Review finding: " + .name + " (" + .verdict + ")"),
          context: (.evidence // ("Non-pass dimension in " + $deliverable + " review")),
          raw_content: ({deliverable: $deliverable} + . | tostring),
          source_file: $source_file
        }
      ' "$review_file" 2>/dev/null >> "$tmpdir/${name}_review_candidates.jsonl" || true
    done

    if [ -s "$tmpdir/${name}_review_candidates.jsonl" ]; then
      jq -s '.' "$tmpdir/${name}_review_candidates.jsonl" > "$tmpdir/${name}_reviews.json" 2>/dev/null || true
    fi
  fi

  # Merge per-source into per-row result
  jq -s 'add // []' \
    "$tmpdir/${name}_summary.json" \
    "$tmpdir/${name}_learnings.json" \
    "$tmpdir/${name}_reviews.json" \
    > "$tmpdir/row_${name}.json" 2>/dev/null || printf '[]' > "$tmpdir/row_${name}.json"
}

# ============================================================
# alm list — list TODOs with optional filtering
# ============================================================
cmd_list() {
  show_seed=false
  status_filter=""
  json_output=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --seed)   show_seed=true; shift ;;
      --status) shift; status_filter="${1:-}"; shift ;;
      --json)   json_output=true; shift ;;
      --help|-h)
        printf 'Usage: alm list [--seed] [--status S] [--json]\n'
        printf '  --seed    Show seed_id column with linked seed status\n'
        printf '  --status  Filter by: active|done|blocked|deferred\n'
        printf '  --json    Output as JSON array\n'
        return 0
        ;;
      *) die "list: unknown flag: $1" ;;
    esac
  done

  todos_path=$(resolve_todos_path "")
  [ -f "$todos_path" ] || die "list: todos file not found: $todos_path" 1

  todos=$(yq -o=json '.' "$todos_path") || die "list: failed to parse $todos_path"

  # Apply status filter
  if [ -n "$status_filter" ]; then
    todos=$(printf '%s' "$todos" | jq --arg s "$status_filter" '[.[] | select(.status == $s)]')
  fi

  # JSON output mode
  if [ "$json_output" = true ]; then
    printf '%s\n' "$todos"
    return 0
  fi

  # Table output
  if [ "$show_seed" = true ]; then
    printf '%-24s %-9s %-9s %-17s %-14s %s\n' "ID" "STATUS" "URGENCY" "SEED" "SEED STATUS" "TITLE"
    printf '%s\n' "$todos" | jq -r '.[] | [.id, (.status // "-"), (.urgency // "-"), (.seed_id // "-"), .title] | @tsv' | \
    while IFS="$(printf '\t')" read -r id status urgency seed_id title; do
      seed_status="-"
      if [ "$seed_id" != "-" ] && [ -n "$seed_id" ] && [ "$seed_id" != "null" ]; then
        seed_status=$(sds show "$seed_id" --json 2>/dev/null | jq -r '.status // "(unknown)"' 2>/dev/null) || seed_status="(unknown)"
        [ -z "$seed_status" ] && seed_status="(unknown)"
        [ "$seed_status" = "null" ] && seed_status="(unknown)"
      fi
      printf '%-24s %-9s %-9s %-17s %-14s %s\n' "$id" "$status" "$urgency" "$seed_id" "$seed_status" "$title"
    done
  else
    printf '%-24s %-9s %-9s %s\n' "ID" "STATUS" "URGENCY" "TITLE"
    printf '%s\n' "$todos" | jq -r '.[] | [.id, (.status // "-"), (.urgency // "-"), .title] | @tsv' | \
    while IFS="$(printf '\t')" read -r id status urgency title; do
      printf '%-24s %-9s %-9s %s\n' "$id" "$status" "$urgency" "$title"
    done
  fi
}

# ============================================================
# alm show — display full TODO detail
# ============================================================
cmd_show() {
  if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    printf 'Usage: alm show <id>\n'
    return 0
  fi

  [ -n "${1:-}" ] || die "show: <id> argument required"
  target_id="$1"

  todos_path=$(resolve_todos_path "")
  [ -f "$todos_path" ] || die "show: todos file not found: $todos_path" 1

  entry=$(yq -o=json ".[] | select(.id == \"$target_id\")" "$todos_path" 2>/dev/null)
  [ -n "$entry" ] || die "show: TODO not found: $target_id"

  # Display fields
  printf 'TODO: %s\n' "$(printf '%s' "$entry" | jq -r '.id')"
  printf 'Status: %s\n' "$(printf '%s' "$entry" | jq -r '.status // "active"')"
  printf 'Title: %s\n' "$(printf '%s' "$entry" | jq -r '.title')"

  _ctx=$(printf '%s' "$entry" | jq -r '.context // empty')
  if [ -n "$_ctx" ]; then
    printf 'Context:\n'
    printf '%s\n' "$_ctx" | sed 's/^/  /'
  fi

  _work=$(printf '%s' "$entry" | jq -r '.work_needed // empty')
  if [ -n "$_work" ]; then
    printf 'Work Needed:\n'
    printf '%s\n' "$_work" | sed 's/^/  /'
  fi

  _risks=$(printf '%s' "$entry" | jq -r '.risks // empty')
  if [ -n "$_risks" ]; then
    printf 'Risks:\n'
    printf '%s\n' "$_risks" | sed 's/^/  /'
  fi

  _refs=$(printf '%s' "$entry" | jq -r 'if .references then .references[] else empty end' 2>/dev/null)
  if [ -n "$_refs" ]; then
    printf 'References:\n'
    printf '%s\n' "$_refs" | sed 's/^/  - /'
  fi

  _source=$(printf '%s' "$entry" | jq -r '.source_type // empty')
  [ -n "$_source" ] && printf 'Source: %s\n' "$_source"

  _swu=$(printf '%s' "$entry" | jq -r '.source_work_unit // empty')
  [ -n "$_swu" ] && printf 'Source Work Unit: %s\n' "$_swu"

  printf 'Created: %s\n' "$(printf '%s' "$entry" | jq -r '.created_at')"
  printf 'Updated: %s\n' "$(printf '%s' "$entry" | jq -r '.updated_at')"

  _deps=$(printf '%s' "$entry" | jq -r 'if .depends_on then .depends_on | join(", ") else empty end' 2>/dev/null)
  [ -n "$_deps" ] && printf 'Depends On: %s\n' "$_deps"

  _files=$(printf '%s' "$entry" | jq -r 'if .files_touched then .files_touched | join(", ") else empty end' 2>/dev/null)
  [ -n "$_files" ] && printf 'Files Touched: %s\n' "$_files"

  # Urgency / Impact / Effort
  _urg=$(printf '%s' "$entry" | jq -r '.urgency // empty')
  [ -n "$_urg" ] && printf 'Urgency: %s\n' "$_urg"
  _imp=$(printf '%s' "$entry" | jq -r '.impact // empty')
  [ -n "$_imp" ] && printf 'Impact: %s\n' "$_imp"
  _eff=$(printf '%s' "$entry" | jq -r '.effort // empty')
  [ -n "$_eff" ] && printf 'Effort: %s\n' "$_eff"

  # Seed linkage
  _seed=$(printf '%s' "$entry" | jq -r '.seed_id // empty')
  if [ -n "$_seed" ]; then
    printf 'Seed: %s\n' "$_seed"
    _seed_status=$(sds show "$_seed" --json 2>/dev/null | jq -r '.status // "(unknown)"' 2>/dev/null) || _seed_status="(unknown)"
    [ -z "$_seed_status" ] && _seed_status="(unknown)"
    [ "$_seed_status" = "null" ] && _seed_status="(unknown)"
    printf 'Seed Status: %s\n' "$_seed_status"
  fi
}

# ============================================================
# alm triage — dependency graph analysis + roadmap generation
# ============================================================
cmd_triage() {
  full_mode=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --full) full_mode=true; shift ;;
      --help|-h)
        printf 'Usage: alm triage [--full]\n'
        printf '  --full  Regenerate all phases from scratch\n'
        return 0
        ;;
      *) die "triage: unknown flag: $1" ;;
    esac
  done

  require_cmd python3

  todos_path=$(resolve_todos_path "")
  [ -f "$todos_path" ] || die "triage: todos file not found: $todos_path" 2

  # Validate first
  if ! cmd_validate "$todos_path" >/dev/null 2>&1; then
    die "triage: todos.yaml failed validation" 3
  fi

  todos=$(yq -o=json '.' "$todos_path") || die "triage: failed to parse $todos_path" 3

  # Step 1: Python graph analysis (Kahn's algorithm)
  python_errors=$(mktemp)
  _old_trap=$(trap -p EXIT | sed "s/^trap -- '//;s/' EXIT$//")
  trap "rm -f \"$python_errors\"; $_old_trap" EXIT

  graph_output=$(python3 -c "
import json, sys

todos = json.loads(sys.argv[1])

# Filter: only active and blocked TODOs (skip done, deferred)
active = [t for t in todos if t.get('status', 'active') not in ('done', 'deferred')]

if not active:
    print(json.dumps({
        'todos': [],
        'graph': {'topo_order': [], 'waves': [], 'cycles': []},
        'conflicts': []
    }))
    sys.exit(0)

ids = {t['id'] for t in active}
all_ids = {t['id'] for t in todos}
graph = {}

for t in active:
    tid = t['id']
    deps = t.get('depends_on') or []
    for dep in deps:
        if dep not in all_ids:
            print(f'Error: dangling dependency: {tid} depends on {dep} which does not exist', file=sys.stderr)
            sys.exit(1)
    active_deps = [d for d in deps if d in ids]
    graph[tid] = active_deps

# Build reverse graph
reverse = {n: [] for n in ids}
for node, deps in graph.items():
    for dep in deps:
        reverse[dep].append(node)

# Kahn's algorithm
in_degree = {n: len(graph[n]) for n in ids}
queue = sorted([n for n in ids if in_degree[n] == 0])
topo_order = []

while queue:
    current = sorted(queue)
    queue = []
    for node in current:
        topo_order.append(node)
    for node in current:
        for dependent in reverse.get(node, []):
            in_degree[dependent] -= 1
            if in_degree[dependent] == 0:
                queue.append(dependent)

# Cycle detection
if len(topo_order) != len(ids):
    remaining = sorted(ids - set(topo_order))
    print(f'Error: dependency cycle involving: {\" -> \".join(remaining)}', file=sys.stderr)
    sys.exit(1)

# Assign wave numbers
wave_map = {}
for node in topo_order:
    deps = graph[node]
    if not deps:
        wave_map[node] = 1
    else:
        wave_map[node] = max(wave_map[dep] for dep in deps) + 1

max_wave = max(wave_map.values()) if wave_map else 0
waves = []
for w in range(1, max_wave + 1):
    wave_todos = sorted([n for n, wv in wave_map.items() if wv == w])
    waves.append({'wave': w, 'todos': wave_todos})

todo_output = []
for t in active:
    tid = t['id']
    todo_output.append({
        'id': tid,
        'title': t.get('title', ''),
        'depends_on': t.get('depends_on') or [],
        'files_touched': t.get('files_touched') or [],
        'urgency': t.get('urgency'),
        'impact': t.get('impact'),
        'effort': t.get('effort'),
        'status': t.get('status', 'active'),
        'wave': wave_map.get(tid, 1)
    })

result = {
    'todos': todo_output,
    'graph': {
        'topo_order': topo_order,
        'waves': waves,
        'cycles': []
    }
}

print(json.dumps(result))
" "$todos" 2>"$python_errors") || {
    cat "$python_errors" >&2
    die "triage: graph analysis failed" 3
  }

  if [ -s "$python_errors" ]; then
    cat "$python_errors" >&2
    die "triage: graph analysis failed" 3
  fi

  # Validate JSON output
  printf '%s' "$graph_output" | jq empty 2>/dev/null || die "triage: graph analysis produced invalid JSON" 3

  # Step 2: Detect file conflicts within waves
  conflicts=$(printf '%s' "$graph_output" | jq '
    .graph.waves as $waves |
    .todos as $todos |
    ($todos | map({key: .id, value: .files_touched}) | from_entries) as $files |
    [
      $waves[] |
      .todos as $wave_todos |
      .wave as $wave_num |
      [range($wave_todos | length)] as $indices |
      $indices[] as $i |
      $indices[] as $j |
      select($i < $j) |
      $wave_todos[$i] as $a |
      $wave_todos[$j] as $b |
      $files[$a] as $files_a |
      $files[$b] as $files_b |
      select(($files_a | length) > 0 and ($files_b | length) > 0) |
      [
        $files_a[] as $fa |
        $files_b[] as $fb |
        select(
          ($fa | test($fb | gsub("/$"; "/**") | gsub("\\*\\*"; "\u0000") | gsub("\\*"; "[^/]*") | gsub("\u0000"; ".*"))) or
          ($fb | test($fa | gsub("/$"; "/**") | gsub("\\*\\*"; "\u0000") | gsub("\\*"; "[^/]*") | gsub("\u0000"; ".*")))
        ) |
        ($fa, $fb)
      ] | unique as $overlaps |
      select(($overlaps | length) > 0) |
      {
        phase: $wave_num,
        file_pattern: ($overlaps | join(", ")),
        work_units: [$a, $b],
        severity: (if ($overlaps | length) > 3 then "high" elif ($overlaps | length) > 1 then "medium" else "low" end),
        mitigation: "sequential ordering"
      }
    ]
  ')

  # Step 3: Build full analysis output (backward compat with triage-todos.sh)
  analysis=$(printf '%s' "$graph_output" | jq --argjson conflicts "$conflicts" '.conflicts = $conflicts')

  # Step 4: Generate roadmap.yaml
  ensure_almanac_dir

  ts=$(now_iso)

  # Build dependency graph nodes and edges for roadmap
  dep_graph=$(printf '%s' "$analysis" | jq '{
    nodes: [.todos[] | {id: .id, label: .title, phase: .wave, status: .status}],
    edges: [.todos[] | . as $t | (.depends_on // [])[] | {from: $t.id, to: ., kind: "hard", reason: "explicit depends_on"}],
    waves: .graph.waves
  }')

  # Build deferred list
  deferred=$(yq -o=json '.' "$todos_path" | jq '[.[] | select(.status == "deferred") | {id: .id, title: .title, reason: "deferred by triage"}]')

  # Build phases from waves
  phases=$(printf '%s' "$analysis" | jq --arg ts "$ts" '[
    .graph.waves[] | {
      number: .wave,
      title: ("Phase " + (.wave | tostring)),
      status: "planned",
      rationale: "Wave " + (.wave | tostring) + " of dependency graph",
      work_units: [.todos | to_entries[] | {
        index: (.key + 1),
        branch_name: ("work/" + .value),
        description: .value,
        todos: [.value],
        depends_on: [],
        key_files: [],
        conflict_risk: "none",
        completed_at: null
      }]
    }
  ]')

  # If not --full and existing roadmap, preserve done phases
  if [ "$full_mode" = false ] && [ -f "$ALM_ROADMAP" ]; then
    existing_phases=$(yq -o=json '.phases // []' "$ALM_ROADMAP" 2>/dev/null) || existing_phases="[]"
    done_phases=$(printf '%s' "$existing_phases" | jq '[.[] | select(.status == "done")]')
    done_count=$(printf '%s' "$done_phases" | jq 'length')

    # Merge: keep done phases, replace the rest with new analysis
    if [ "$done_count" -gt 0 ]; then
      phases=$(jq -n --argjson done "$done_phases" --argjson new "$phases" '$done + $new')
    fi
  fi

  total_phases=$(printf '%s' "$phases" | jq 'length')
  completed_phases=$(printf '%s' "$phases" | jq '[.[] | select(.status == "done")] | length')

  # Compute active_observations: open + activation == active. Additive key;
  # omit entirely if empty to avoid diff noise for existing consumers.
  active_obs_json="[]"
  _obs_all=$(_observe_load_json)
  if [ "$_obs_all" != "[]" ]; then
    _obs_open=$(printf '%s' "$_obs_all" | jq -c '.[] | select(.lifecycle == "open")')
    if [ -n "$_obs_open" ]; then
      _ao_tmp=$(mktemp)
      printf '[' > "$_ao_tmp"
      _first=1
      printf '%s\n' "$_obs_open" | while IFS= read -r _obs; do
        [ -z "$_obs" ] && continue
        _act=$(_observe_compute_activation "$_obs" "")
        [ "$_act" = "active" ] || continue
        _tt=$(printf '%s' "$_obs" | jq -r '.triggered_by.type')
        case "$_tt" in
          row_archived)
            _row=$(printf '%s' "$_obs" | jq -r '.triggered_by.row')
            _reason="row_archived: $_row"
            ;;
          rows_since)
            _since=$(printf '%s' "$_obs" | jq -r '.triggered_by.since_row')
            _target=$(printf '%s' "$_obs" | jq -r '.triggered_by.count')
            _n=$(_observe_rows_since_count "$_obs")
            _reason="rows_since: $_n/$_target rows archived since $_since"
            ;;
          manual)
            _mts=$(printf '%s' "$_obs" | jq -r '.manual_activation_at // "unknown"')
            _reason="manual: activated at $_mts"
            ;;
          *)
            _reason="$_tt"
            ;;
        esac
        _entry=$(jq -n \
          --arg id "$(printf '%s' "$_obs" | jq -r '.id')" \
          --arg kind "$(printf '%s' "$_obs" | jq -r '.kind')" \
          --arg title "$(printf '%s' "$_obs" | jq -r '.title')" \
          --arg reason "$_reason" \
          '{id: $id, kind: $kind, title: $title, activation_reason: $reason}')
        if [ "$_first" = "1" ]; then
          printf '%s' "$_entry" >> "$_ao_tmp"
          _first=0
        else
          printf ',%s' "$_entry" >> "$_ao_tmp"
        fi
        # Track that we wrote at least one entry via a sentinel file
        : > "$_ao_tmp.nonempty"
      done
      printf ']' >> "$_ao_tmp"
      if [ -f "$_ao_tmp.nonempty" ]; then
        active_obs_json=$(cat "$_ao_tmp")
      fi
      rm -f "$_ao_tmp" "$_ao_tmp.nonempty"
    fi
  fi

  # Assemble roadmap
  roadmap=$(jq -n \
    --arg ts "$ts" \
    --argjson total "$total_phases" \
    --argjson completed "$completed_phases" \
    --argjson dep_graph "$dep_graph" \
    --argjson conflicts "$conflicts" \
    --argjson phases "$phases" \
    --argjson deferred "$deferred" \
    '{
      schema_version: "1.0",
      metadata: {
        project: "furrow",
        generated_at: $ts,
        total_phases: $total,
        completed_phases: $completed
      },
      dependency_graph: $dep_graph,
      conflict_zones: $conflicts,
      phases: $phases,
      deferred: $deferred,
      handoff: {
        template: "Start with: `/work {branch_name} — {description}`\nSource TODOs: {todo_ids}\nKey files: {key_files}"
      }
    }')

  # Additive: inject active_observations only when non-empty.
  # Placement: after `deferred`, before `handoff` (no top-level `waves` key exists
  # in this roadmap shape; `deferred` is the nearest analog).
  _ao_len=$(printf '%s' "$active_obs_json" | jq 'length')
  if [ "$_ao_len" -gt 0 ]; then
    roadmap=$(printf '%s' "$roadmap" | jq --argjson ao "$active_obs_json" '
      {schema_version, metadata, dependency_graph, conflict_zones, phases, deferred, active_observations: $ao, handoff}
    ')
    analysis=$(printf '%s' "$analysis" | jq --argjson ao "$active_obs_json" '. + {active_observations: $ao}')
  fi

  # Write roadmap.yaml
  printf '%s' "$roadmap" | yq -P '.' > "$ALM_ROADMAP"

  # Output analysis JSON to stdout
  printf '%s\n' "$analysis"
}

# ============================================================
# alm next — generate handoff prompts from roadmap
# ============================================================
cmd_next() {
  phase_num=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --phase) shift; phase_num="${1:-}"; shift ;;
      --help|-h)
        printf 'Usage: alm next [--phase N]\n'
        printf '  Generate handoff prompts for the next phase of work.\n'
        return 0
        ;;
      *) die "next: unknown flag: $1" ;;
    esac
  done

  # Try roadmap.yaml, fall back to ROADMAP.md
  if [ -f "$ALM_ROADMAP" ]; then
    roadmap_file="$ALM_ROADMAP"
  elif [ -f "ROADMAP.md" ]; then
    # Markdown fallback: just print it and exit
    printf 'Note: using ROADMAP.md fallback (no roadmap.yaml found)\n\n' >&2
    cat "ROADMAP.md"
    return 0
  else
    die "next: roadmap not found at $ALM_ROADMAP"
  fi

  roadmap=$(yq -o=json '.' "$roadmap_file") || die "next: failed to parse $roadmap_file"

  # Determine target phase
  if [ -n "$phase_num" ]; then
    phase=$(printf '%s' "$roadmap" | jq --argjson n "$phase_num" '.phases[] | select(.number == $n)')
    [ -n "$phase" ] || die "next: phase $phase_num not found"
  else
    phase=$(printf '%s' "$roadmap" | jq 'first(.phases[] | select(.status != "done"))')
    [ -n "$phase" ] && [ "$phase" != "null" ] || die "next: all phases are done"
  fi

  # Get handoff template
  template=$(printf '%s' "$roadmap" | jq -r '.handoff.template // "Start with: `/work {branch_name} — {description}`\nSource TODOs: {todo_ids}\nKey files: {key_files}"')

  phase_title=$(printf '%s' "$phase" | jq -r '.title // ("Phase " + (.number | tostring))')
  printf '=== %s ===\n\n' "$phase_title"

  # Generate a handoff prompt for each row in the phase
  printf '%s' "$phase" | jq -r '.rows[] |
    "Start with: `/work " + .branch + " — " + .description + "`\n" +
    "Source TODOs: " + (.todos | join(", ")) + "\n" +
    "Key files: " + (if (.key_files | length) > 0 then (.key_files | join(", ")) else "(none specified)" end) + "\n"
  '
}

# ============================================================
# alm validate — validate todos.yaml and observations.yaml against schemas
# ============================================================
# Dispatcher: preserves the public cmd_validate "<path>" signature used by
# cmd_add (todos path) and cmd_triage (todos path). With no arg, validates
# BOTH todos.yaml AND observations.yaml; returns non-zero if either fails.
cmd_validate() {
  if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    printf 'Usage: alm validate [<path>]\n'
    printf '  No arg: validate both todos.yaml and observations.yaml.\n'
    printf '  With path: infer schema by basename (todos*.yaml | observations*.yaml).\n'
    return 0
  fi

  if [ $# -eq 0 ]; then
    _rc=0
    cmd_validate_todos "$ALM_TODOS" || _rc=$?
    cmd_validate_observations "$ALM_OBSERVATIONS" || _rc=$?
    return $_rc
  fi

  case "$(basename "$1")" in
    todos*.yaml)        cmd_validate_todos "$1" ;;
    observations*.yaml) cmd_validate_observations "$1" ;;
    *) die "validate: unknown schema target: $1" 2 ;;
  esac
}

cmd_validate_todos() {
  todos_path=$(resolve_todos_path "${1:-}")
  errors=""

  [ -f "$todos_path" ] || die "validate: file not found: $todos_path" 2

  if [ ! -f "$SCHEMA_FILE_TODOS" ]; then
    die "validate: schema not found: $SCHEMA_FILE_TODOS" 2
  fi

  # Step 1: Schema validation (requires yq + python3)
  if command -v yq >/dev/null 2>&1 && command -v python3 >/dev/null 2>&1; then
    json_tmp=$(mktemp)
    schema_tmp=$(mktemp)
    _old_trap=$(trap -p EXIT | sed "s/^trap -- '//;s/' EXIT$//")
    trap "rm -f \"$json_tmp\" \"$schema_tmp\"; $_old_trap" EXIT

    if ! yq -o=json '.' "$todos_path" > "$json_tmp" 2>/dev/null; then
      errors="${errors}Invalid YAML syntax in $todos_path\n"
    elif ! yq -o=json '.' "$SCHEMA_FILE_TODOS" > "$schema_tmp" 2>/dev/null; then
      errors="${errors}Invalid YAML syntax in schema: $SCHEMA_FILE_TODOS\n"
    else
      schema_errors=$(python3 -c "
import json, sys
try:
    from jsonschema import Draft202012Validator, FormatChecker
except ImportError:
    try:
        from jsonschema import Draft7Validator as Draft202012Validator
        FormatChecker = None
    except ImportError:
        print('SKIP: jsonschema not installed', file=sys.stderr)
        sys.exit(0)
with open(sys.argv[1]) as f:
    schema = json.load(f)
with open(sys.argv[2]) as f:
    instance = json.load(f)
kwargs = {}
if FormatChecker is not None:
    try:
        kwargs['format_checker'] = FormatChecker()
    except Exception:
        pass
validator = Draft202012Validator(schema, **kwargs)
errs = sorted(validator.iter_errors(instance), key=lambda e: list(e.path))
for e in errs:
    path = '.'.join(str(p) for p in e.absolute_path) or '(root)'
    print(f'Schema error at {path}: {e.message}')
" "$schema_tmp" "$json_tmp" 2>&1)
      if [ -n "$schema_errors" ]; then
        errors="${errors}${schema_errors}\n"
      fi
    fi
  elif command -v yq >/dev/null 2>&1; then
    printf 'Warning: python3 not found; skipping schema validation\n' >&2
  else
    printf 'Warning: yq not found; skipping all validation\n' >&2
    printf 'todos.yaml is valid\n'
    return 0
  fi

  # Step 2: Cross-field checks — unique IDs
  if command -v yq >/dev/null 2>&1; then
    ids=$(yq -r '.[].id' "$todos_path" 2>/dev/null) || ids=""
    if [ -n "$ids" ]; then
      dupes=$(printf '%s\n' "$ids" | sort | uniq -d)
      if [ -n "$dupes" ]; then
        for dupe in $dupes; do
          errors="${errors}Duplicate TODO id: ${dupe}\n"
        done
      fi
    fi
  fi

  # Step 3: Cross-field checks — dependency references
  if command -v yq >/dev/null 2>&1; then
    all_ids=$(yq -r '.[].id' "$todos_path" 2>/dev/null | sort) || all_ids=""
    dep_ids=$(yq -r '.[] | (.depends_on // [])[]' "$todos_path" 2>/dev/null | sort -u) || dep_ids=""
    if [ -n "$dep_ids" ]; then
      for dep in $dep_ids; do
        if ! printf '%s\n' "$all_ids" | grep -qx "$dep"; then
          errors="${errors}Dangling dependency: $dep does not exist\n"
        fi
      done
    fi
  fi

  # Step 4: Cross-field checks — slug format
  if command -v yq >/dev/null 2>&1; then
    bad_ids=$(yq -r '.[].id' "$todos_path" 2>/dev/null | grep -v -E '^[a-z][a-z0-9]*(-[a-z0-9]+)*$' || true)
    if [ -n "$bad_ids" ]; then
      for bad in $bad_ids; do
        errors="${errors}Invalid slug format: $bad\n"
      done
    fi
  fi

  # Report results
  if [ -n "$errors" ]; then
    printf '%b' "$errors" | sed '/^$/d' >&2
    return 3
  fi

  printf 'todos.yaml is valid\n'
}

cmd_validate_observations() {
  obs_path="${1:-$ALM_OBSERVATIONS}"
  errors=""

  [ -f "$obs_path" ] || die "validate: file not found: $obs_path" 2

  if [ ! -f "$SCHEMA_FILE_OBSERVATIONS" ]; then
    die "validate: schema not found: $SCHEMA_FILE_OBSERVATIONS" 2
  fi

  # Step 1: Schema validation (requires yq + python3)
  if command -v yq >/dev/null 2>&1 && command -v python3 >/dev/null 2>&1; then
    json_tmp=$(mktemp)
    schema_tmp=$(mktemp)
    _old_trap=$(trap -p EXIT | sed "s/^trap -- '//;s/' EXIT$//")
    trap "rm -f \"$json_tmp\" \"$schema_tmp\"; $_old_trap" EXIT

    if ! yq -o=json '.' "$obs_path" > "$json_tmp" 2>/dev/null; then
      errors="${errors}Invalid YAML syntax in $obs_path\n"
    elif ! yq -o=json '.' "$SCHEMA_FILE_OBSERVATIONS" > "$schema_tmp" 2>/dev/null; then
      errors="${errors}Invalid YAML syntax in schema: $SCHEMA_FILE_OBSERVATIONS\n"
    else
      schema_errors=$(python3 -c "
import json, sys
try:
    from jsonschema import Draft202012Validator, FormatChecker
except ImportError:
    try:
        from jsonschema import Draft7Validator as Draft202012Validator
        FormatChecker = None
    except ImportError:
        print('SKIP: jsonschema not installed', file=sys.stderr)
        sys.exit(0)
with open(sys.argv[1]) as f:
    schema = json.load(f)
with open(sys.argv[2]) as f:
    instance = json.load(f)
kwargs = {}
if FormatChecker is not None:
    try:
        kwargs['format_checker'] = FormatChecker()
    except Exception:
        pass
validator = Draft202012Validator(schema, **kwargs)
errs = sorted(validator.iter_errors(instance), key=lambda e: list(e.path))
for e in errs:
    path = '.'.join(str(p) for p in e.absolute_path) or '(root)'
    print(f'Schema error at {path}: {e.message}')
" "$schema_tmp" "$json_tmp" 2>&1)
      if [ -n "$schema_errors" ]; then
        errors="${errors}${schema_errors}\n"
      fi
    fi
  elif command -v yq >/dev/null 2>&1; then
    printf 'Warning: python3 not found; skipping schema validation\n' >&2
  else
    printf 'Warning: yq not found; skipping all validation\n' >&2
    printf 'observations.yaml is valid\n'
    return 0
  fi

  # Step 2: Cross-field checks — unique IDs
  if command -v yq >/dev/null 2>&1; then
    ids=$(yq -r '.[].id' "$obs_path" 2>/dev/null) || ids=""
    if [ -n "$ids" ]; then
      dupes=$(printf '%s\n' "$ids" | sort | uniq -d)
      if [ -n "$dupes" ]; then
        for dupe in $dupes; do
          errors="${errors}Duplicate observation id: ${dupe}\n"
        done
      fi
    fi
  fi

  # Step 3: Cross-field checks — slug format on ids
  if command -v yq >/dev/null 2>&1; then
    bad_ids=$(yq -r '.[].id' "$obs_path" 2>/dev/null | grep -v -E '^[a-z][a-z0-9]*(-[a-z0-9]+)*$' || true)
    if [ -n "$bad_ids" ]; then
      for bad in $bad_ids; do
        errors="${errors}Invalid observation slug format: $bad\n"
      done
    fi
  fi

  # Report results
  if [ -n "$errors" ]; then
    printf '%b' "$errors" | sed '/^$/d' >&2
    return 3
  fi

  printf 'observations.yaml is valid\n'
}

# ============================================================
# alm render — generate Markdown from roadmap.yaml
# ============================================================
cmd_render() {
  output_path=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --output) shift; output_path="${1:-}"; shift ;;
      --help|-h)
        printf 'Usage: alm render [--output PATH]\n'
        printf '  Generate Markdown from roadmap.yaml.\n'
        printf '  Default output: stdout\n'
        return 0
        ;;
      *) die "render: unknown flag: $1" ;;
    esac
  done

  [ -f "$ALM_ROADMAP" ] || die "render: roadmap not found at $ALM_ROADMAP"

  roadmap=$(yq -o=json '.' "$ALM_ROADMAP") || die "render: failed to parse $ALM_ROADMAP"

  md=$(printf '%s' "$roadmap" | jq -r '
    (.metadata.project // "project") as $prefix |
    # Header
    "# Roadmap\n\n" +
    "**Updated:** " + .metadata.generated_at + "  \n" +
    "**Progress:** " + (.metadata.completed_phases | tostring) + "/" + (.metadata.total_phases | tostring) + " phases completed\n\n" +

    # Dependency DAG
    "## Dependency Graph\n\n```\n" +
    (if (.dependency_graph.edges | length) > 0 then
      ([.dependency_graph.edges[] | .from + " --> " + .to + "  (" + .kind + ")"] | join("\n"))
    else
      "(no dependencies)"
    end) +
    "\n```\n\n" +

    # Legend
    "## Legend\n\n" +
    "- `-->` hard dependency (explicit depends_on)\n" +
    "- `..>` inferred dependency (file conflict)\n" +
    "- Phase N = Nth wave of parallelizable work\n\n" +

    # Conflict Zones
    "## Conflict Zones\n\n" +
    (if (.conflict_zones | length) > 0 then
      "| Phase | Pattern | Work Units | Severity | Mitigation |\n" +
      "|-------|---------|------------|----------|------------|\n" +
      ([.conflict_zones[] |
        "| " + (.phase | tostring) + " | " + .file_pattern + " | " + (.work_units | join(", ")) + " | " + .severity + " | " + .mitigation + " |"
      ] | join("\n")) + "\n\n"
    else
      "No file conflicts detected.\n\n"
    end) +

    # Phases
    ([.phases[] |
      "## Phase " + (.number | tostring) + ": " + .title + "\n\n" +
      "**Status:** " + .status + "  \n" +
      "**Rationale:** " + (.rationale // "-") + "\n\n" +
      ([.work_units[] |
        "### " + (.index | tostring) + ". " + .branch_name + "\n\n" +
        .description + "\n\n" +
        "- **TODOs:** " + (.todos | join(", ")) + "\n" +
        "- **Key files:** " + (if (.key_files | length) > 0 then (.key_files | join(", ")) else "(none)" end) + "\n" +
        "- **Conflict risk:** " + .conflict_risk + "\n" +
        (if .completed_at then "- **Completed:** " + .completed_at + "\n" else "" end)
      ] | join("\n"))
    ] | join("\n")) +

    # Deferred
    (if (.deferred | length) > 0 then
      "\n## Deferred\n\n" +
      ([.deferred[] | "- **" + .id + "**: " + .title + " — " + (.reason // "no reason given")] | join("\n")) + "\n"
    else
      ""
    end) +

    # Worktree Commands
    "\n## Worktree Commands\n\n```sh\n" +
    ([.phases[] | select(.status != "done") |
      "# Phase " + (.number | tostring) + "\n" +
      ([.work_units[] | "git worktree add ../" + $prefix + "-" + .branch_name + " -b " + .branch_name] | join("\n"))
    ] | join("\n\n")) +
    "\n```\n"
  ')

  if [ -n "$output_path" ]; then
    printf '%s\n' "$md" > "$output_path"
    printf 'Wrote %s\n' "$output_path" >&2
  else
    printf '%s\n' "$md"
  fi
}

# ============================================================
# alm learn — knowledge management lifecycle
# ============================================================
cmd_learn() {
  subcmd="${1:-}"
  [ -n "$subcmd" ] || die "learn: subcommand required (list|search|show|promote|add)"
  shift

  case "$subcmd" in
    list)    _learn_list "$@" ;;
    search)  _learn_search "$@" ;;
    show)    _learn_show "$@" ;;
    promote) _learn_promote "$@" ;;
    add)     _learn_add "$@" ;;
    --help|-h)
      printf 'Usage: alm learn <subcommand> [options]\n\n'
      printf 'Subcommands:\n'
      printf '  list    [--row NAME]                              List all learnings\n'
      printf '  search  <query>                                   Search across all learnings\n'
      printf '  show    <row> <index>                             Show full learning detail\n'
      printf '  promote <row> [--all|--id INDEX]                  Promote to almanac\n'
      printf '  add     <row> --category C --content C --context C  Add a learning\n'
      return 0
      ;;
    *) die "learn: unknown subcommand: $subcmd" ;;
  esac
}

_learn_list() {
  row_filter=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --row) shift; row_filter="${1:-}"; shift ;;
      --help|-h)
        printf 'Usage: alm learn list [--row NAME]\n'
        return 0
        ;;
      *) die "learn list: unknown flag: $1" ;;
    esac
  done

  printf '%-24s %-12s %-8s %s\n' "ROW" "CATEGORY" "PROMOTED" "CONTENT"

  # Scan per-row learnings
  if [ -d "$ROWS_DIR" ]; then
    for row_dir in "$ROWS_DIR"/*/; do
      [ -d "$row_dir" ] || continue
      name=$(basename "$row_dir")
      [ -n "$row_filter" ] && [ "$name" != "$row_filter" ] && continue
      lfile="$row_dir/learnings.jsonl"
      [ -f "$lfile" ] || continue
      while IFS= read -r line; do
        [ -z "$line" ] && continue
        _category=$(printf '%s' "$line" | jq -r '.category // "-"')
        _promoted=$(printf '%s' "$line" | jq -r 'if .promoted == true then "yes" else "no" end')
        _content=$(printf '%s' "$line" | jq -r '.content // "-"')
        _trunc=$(printf '%.60s' "$_content")
        [ ${#_content} -gt 60 ] && _trunc="${_trunc}..."
        printf '%-24s %-12s %-8s %s\n' "$name" "$_category" "$_promoted" "$_trunc"
      done < "$lfile"
    done
  fi

  # Scan promoted learnings
  promoted_dir="$ALM_DIR/learnings"
  if [ -d "$promoted_dir" ]; then
    for pfile in "$promoted_dir"/*.jsonl; do
      [ -f "$pfile" ] || continue
      pname=$(basename "$pfile" .jsonl)
      [ -n "$row_filter" ] && [ "$pname" != "$row_filter" ] && continue
      while IFS= read -r line; do
        [ -z "$line" ] && continue
        # Skip if already shown from row source
        _promoted=$(printf '%s' "$line" | jq -r 'if .promoted == true then "yes" else "no" end')
        _category=$(printf '%s' "$line" | jq -r '.category // "-"')
        _content=$(printf '%s' "$line" | jq -r '.content // "-"')
        _trunc=$(printf '%.60s' "$_content")
        [ ${#_content} -gt 60 ] && _trunc="${_trunc}..."
        printf '%-24s %-12s %-8s %s\n' "$pname(promoted)" "$_category" "$_promoted" "$_trunc"
      done < "$pfile"
    done
  fi
}

_learn_search() {
  [ -n "${1:-}" ] || die "learn search: <query> argument required"
  query="$1"

  # Search per-row learnings
  if [ -d "$ROWS_DIR" ]; then
    for row_dir in "$ROWS_DIR"/*/; do
      [ -d "$row_dir" ] || continue
      name=$(basename "$row_dir")
      lfile="$row_dir/learnings.jsonl"
      [ -f "$lfile" ] || continue
      matches=$(grep -inF "$query" "$lfile" 2>/dev/null) || true
      if [ -n "$matches" ]; then
        printf '%s\n' "$matches" | while IFS= read -r match; do
          printf '[row:%s] %s\n' "$name" "$match"
        done
      fi
    done
  fi

  # Search promoted learnings
  promoted_dir="$ALM_DIR/learnings"
  if [ -d "$promoted_dir" ]; then
    for pfile in "$promoted_dir"/*.jsonl; do
      [ -f "$pfile" ] || continue
      pname=$(basename "$pfile" .jsonl)
      matches=$(grep -inF "$query" "$pfile" 2>/dev/null) || true
      if [ -n "$matches" ]; then
        printf '%s\n' "$matches" | while IFS= read -r match; do
          printf '[promoted:%s] %s\n' "$pname" "$match"
        done
      fi
    done
  fi
}

_learn_show() {
  [ -n "${1:-}" ] || die "learn show: <row> argument required"
  [ -n "${2:-}" ] || die "learn show: <index> argument required (1-based)"
  row="$1"
  idx="$2"

  # Check row learnings
  lfile="$ROWS_DIR/$row/learnings.jsonl"
  if [ -f "$lfile" ]; then
    line=$(sed -n "${idx}p" "$lfile")
    if [ -n "$line" ]; then
      printf 'Source: row/%s (line %s)\n\n' "$row" "$idx"
      printf '%s\n' "$line" | jq '.'
      return 0
    fi
  fi

  # Check promoted learnings
  pfile="$ALM_DIR/learnings/$row.jsonl"
  if [ -f "$pfile" ]; then
    line=$(sed -n "${idx}p" "$pfile")
    if [ -n "$line" ]; then
      printf 'Source: promoted/%s (line %s)\n\n' "$row" "$idx"
      printf '%s\n' "$line" | jq '.'
      return 0
    fi
  fi

  die "learn show: no learning found at index $idx for row '$row'"
}

_learn_promote() {
  [ -n "${1:-}" ] || die "learn promote: <row> argument required"
  row="$1"
  shift

  promote_all=false
  promote_id=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --all) promote_all=true; shift ;;
      --id)  shift; promote_id="${1:-}"; shift ;;
      --help|-h)
        printf 'Usage: alm learn promote <row> [--all|--id INDEX]\n'
        return 0
        ;;
      *) die "learn promote: unknown flag: $1" ;;
    esac
  done

  lfile="$ROWS_DIR/$row/learnings.jsonl"
  [ -f "$lfile" ] || die "learn promote: no learnings found at $lfile"

  promoted_dir="$ALM_DIR/learnings"
  mkdir -p "$promoted_dir"
  pfile="$promoted_dir/$row.jsonl"

  if [ "$promote_all" = true ]; then
    count=0
    line_num=0
    tmp_source=$(mktemp)
    cp "$lfile" "$tmp_source"
    : > "${lfile}.tmp"

    while IFS= read -r line; do
      line_num=$((line_num + 1))
      [ -z "$line" ] && printf '\n' >> "${lfile}.tmp" && continue
      already=$(printf '%s' "$line" | jq -r '.promoted')
      if [ "$already" = "true" ]; then
        printf '%s\n' "$line" >> "${lfile}.tmp"
        continue
      fi
      promoted_line=$(printf '%s' "$line" | jq -c '.promoted = true')
      printf '%s\n' "$promoted_line" >> "$pfile"
      printf '%s\n' "$promoted_line" >> "${lfile}.tmp"
      count=$((count + 1))
    done < "$tmp_source"

    mv "${lfile}.tmp" "$lfile"
    rm -f "$tmp_source"
    printf 'Promoted %d learning(s) from %s\n' "$count" "$row"

  elif [ -n "$promote_id" ]; then
    line=$(sed -n "${promote_id}p" "$lfile")
    [ -n "$line" ] || die "learn promote: no learning at index $promote_id"

    already=$(printf '%s' "$line" | jq -r '.promoted')
    [ "$already" != "true" ] || die "learn promote: learning at index $promote_id is already promoted"

    promoted_line=$(printf '%s' "$line" | jq -c '.promoted = true')
    printf '%s\n' "$promoted_line" >> "$pfile"

    # Update source entry in-place
    tmp_source=$(mktemp)
    awk -v idx="$promote_id" -v replacement="$promoted_line" \
      'NR == idx { print replacement; next } { print }' "$lfile" > "$tmp_source"
    mv "$tmp_source" "$lfile"

    printf 'Promoted learning %s from %s\n' "$promote_id" "$row"

  else
    die "learn promote: specify --all or --id INDEX"
  fi
}

_learn_add() {
  [ -n "${1:-}" ] || die "learn add: <row> argument required"
  row="$1"
  shift

  category="" content="" context=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --category) shift; category="${1:-}"; shift ;;
      --content)  shift; content="${1:-}"; shift ;;
      --context)  shift; context="${1:-}"; shift ;;
      --help|-h)
        printf 'Usage: alm learn add <row> --category CAT --content C --context CTX\n'
        return 0
        ;;
      *) die "learn add: unknown flag: $1" ;;
    esac
  done

  [ -n "$category" ] || die "learn add: --category is required"
  [ -n "$content" ]  || die "learn add: --content is required"
  [ -n "$context" ]  || die "learn add: --context is required"

  # Validate category
  case "$category" in
    pattern|pitfall|preference|convention|dependency) ;;
    *) die "learn add: invalid category '$category' (must be: pattern, pitfall, preference, convention, dependency)" ;;
  esac

  # Validate row exists
  row_dir="$ROWS_DIR/$row"
  [ -d "$row_dir" ] || die "learn add: row '$row' not found at $row_dir/"

  lfile="$row_dir/learnings.jsonl"

  # Generate ID: {row}-{NNN}
  if [ -f "$lfile" ]; then
    line_count=$(wc -l < "$lfile" | tr -d ' ')
  else
    line_count=0
  fi
  seq_num=$((line_count + 1))
  learning_id=$(printf '%s-%03d' "$row" "$seq_num")

  ts=$(now_iso)

  entry=$(jq -n \
    --arg id "$learning_id" \
    --arg ts "$ts" \
    --arg category "$category" \
    --arg content "$content" \
    --arg context "$context" \
    --arg source_task "$row" \
    '{
      id: $id,
      timestamp: $ts,
      category: $category,
      content: $content,
      context: $context,
      source_task: $source_task,
      source_step: "manual",
      promoted: false
    }')

  printf '%s\n' "$entry" | jq -c '.' >> "$lfile"
  printf '%s\n' "$learning_id"
}

# ============================================================
# alm rationale — component rationale management
# ============================================================
cmd_rationale() {
  subcmd="${1:-}"
  [ -n "$subcmd" ] || die "rationale: subcommand required (list|show|add)"
  shift

  case "$subcmd" in
    list)   _rationale_list "$@" ;;
    show)   _rationale_show "$@" ;;
    add)    _rationale_add "$@" ;;
    --help|-h)
      printf 'Usage: alm rationale <subcommand> [options]\n\n'
      printf 'Subcommands:\n'
      printf '  list                           List all components with rationale\n'
      printf '  show  <component>              Show full rationale for a component\n'
      printf '  add   <component> --reason R   Add or update component rationale\n'
      return 0
      ;;
    *) die "rationale: unknown subcommand: $subcmd" ;;
  esac
}

_rationale_list() {
  rationale_file="$ALM_DIR/rationale.yaml"
  [ -f "$rationale_file" ] || die "rationale list: rationale.yaml not found at $rationale_file"

  printf '%-50s %s\n' "COMPONENT" "EXISTS BECAUSE"
  yq -r '.components[] | [.path, .exists_because] | @tsv' "$rationale_file" | \
  while IFS="$(printf '\t')" read -r path reason; do
    _trunc=$(printf '%.60s' "$reason")
    [ ${#reason} -gt 60 ] && _trunc="${_trunc}..."
    printf '%-50s %s\n' "$path" "$_trunc"
  done
}

_rationale_show() {
  [ -n "${1:-}" ] || die "rationale show: <component> argument required"
  component="$1"

  rationale_file="$ALM_DIR/rationale.yaml"
  [ -f "$rationale_file" ] || die "rationale show: rationale.yaml not found at $rationale_file"

  entry=$(yq -o=json ".components[] | select(.path == \"$component\")" "$rationale_file" 2>/dev/null)
  [ -n "$entry" ] || die "rationale show: component not found: $component"

  printf 'Component: %s\n' "$(printf '%s' "$entry" | jq -r '.path')"
  printf 'Exists Because: %s\n' "$(printf '%s' "$entry" | jq -r '.exists_because')"

  _dw=$(printf '%s' "$entry" | jq -r '.delete_when // empty')
  if [ -n "$_dw" ]; then
    printf 'Delete When: %s\n' "$_dw"
  fi
}

_rationale_add() {
  [ -n "${1:-}" ] || die "rationale add: <component> argument required"
  component="$1"
  shift

  reason=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --reason) shift; reason="${1:-}"; shift ;;
      --help|-h)
        printf 'Usage: alm rationale add <component> --reason "why it exists"\n'
        return 0
        ;;
      *) die "rationale add: unknown flag: $1" ;;
    esac
  done

  [ -n "$reason" ] || die "rationale add: --reason is required"

  rationale_file="$ALM_DIR/rationale.yaml"
  ensure_almanac_dir

  # Create file with empty components array if it doesn't exist
  if [ ! -f "$rationale_file" ]; then
    printf 'components: []\n' > "$rationale_file"
  fi

  # Check if component already exists
  existing=$(yq -o=json ".components[] | select(.path == \"$component\")" "$rationale_file" 2>/dev/null)

  if [ -n "$existing" ]; then
    # Update exists_because for existing component
    yq -i "(.components[] | select(.path == \"$component\")).exists_because = \"$reason\"" "$rationale_file"
    printf 'Updated rationale for %s\n' "$component"
  else
    # Append new entry
    yq -i ".components += [{\"path\": \"$component\", \"exists_because\": \"$reason\"}]" "$rationale_file"
    printf 'Added rationale for %s\n' "$component"
  fi
}

# ============================================================
# alm observe — post-ship observations (watches + decision-reviews)
# ============================================================
cmd_observe() {
  if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ] || [ -z "${1:-}" ]; then
    _observe_help
    return 0
  fi
  _verb="$1"; shift
  case "$_verb" in
    add)        _observe_add "$@" ;;
    list)       _observe_list "$@" ;;
    show)       _observe_show "$@" ;;
    resolve)    _observe_resolve "$@" ;;
    dismiss)    _observe_dismiss "$@" ;;
    activate)   _observe_activate "$@" ;;
    on-archive) _observe_on_archive "$@" ;;
    *) die "observe: unknown verb: $_verb" 1 ;;
  esac
}

_observe_help() {
  cat <<'USAGE'
Usage: alm observe <verb> [options]

Verbs:
  add          Create a new observation (watch | decision-review)
  list         List observations (filter by activation/lifecycle)
  show <id>    Show full observation detail + computed activation
  resolve <id> Mark an observation resolved with kind-specific fields
  dismiss <id> Mark an observation dismissed
  activate <id> Manually activate a manual-trigger observation
  on-archive <row>  Display observations newly activated by a row archive

Run 'alm observe <verb> --help' for verb-specific usage.
USAGE
}

# Ensure observations.yaml exists as an empty array.
_observe_ensure_file() {
  ensure_almanac_dir
  if [ ! -f "$ALM_OBSERVATIONS" ]; then
    printf '[]\n' > "$ALM_OBSERVATIONS"
  fi
}

# Load observations.yaml as JSON array (prints "[]" if missing/empty).
_observe_load_json() {
  if [ ! -f "$ALM_OBSERVATIONS" ] || [ ! -s "$ALM_OBSERVATIONS" ]; then
    printf '[]'
    return 0
  fi
  _out=$(yq -o=json '.' "$ALM_OBSERVATIONS" 2>/dev/null) || _out="[]"
  [ -z "$_out" ] && _out="[]"
  [ "$_out" = "null" ] && _out="[]"
  printf '%s' "$_out"
}

# Write-validate-mv helper.
# $1 = full JSON array (stringified) representing the new observations.yaml contents.
_observe_write_validated() {
  _obs_new="$1"
  _tmp=$(mktemp)
  _err=$(mktemp)
  printf '%s' "$_obs_new" | yq -P -o=yaml '.' > "$_tmp"
  if cmd_validate_observations "$_tmp" > "$_err" 2>&1; then
    rm -f "$_err"
    mv "$_tmp" "$ALM_OBSERVATIONS"
    return 0
  else
    cat "$_err" >&2
    rm -f "$_tmp" "$_err"
    return 2
  fi
}

# Compute activation for a single observation.
# $1 = observation JSON
# $2 = optional row name to EXCLUDE (treat its archived_at as null) — used by on-archive.
# Invariant: archived_at timestamps are UTC with trailing Z; lexicographic compare
# of timestamps is only correct under that invariant.
_observe_compute_activation() {
  _obs="$1"
  _exclude_row="${2:-}"
  _trig_type=$(printf '%s' "$_obs" | jq -r '.triggered_by.type')
  case "$_trig_type" in
    row_archived)
      _row=$(printf '%s' "$_obs" | jq -r '.triggered_by.row')
      if [ -n "$_exclude_row" ] && [ "$_row" = "$_exclude_row" ]; then
        _archived="null"
      else
        _archived=$(jq -r '.archived_at // "null"' "$ROWS_DIR/$_row/state.json" 2>/dev/null) || _archived="null"
        [ -z "$_archived" ] && _archived="null"
      fi
      if [ "$_archived" = "null" ]; then
        printf 'pending'
      else
        printf 'active'
      fi
      ;;
    rows_since)
      _since=$(printf '%s' "$_obs" | jq -r '.triggered_by.since_row')
      _target=$(printf '%s' "$_obs" | jq -r '.triggered_by.count')
      if [ -n "$_exclude_row" ] && [ "$_since" = "$_exclude_row" ]; then
        _baseline="null"
      else
        _baseline=$(jq -r '.archived_at // "null"' "$ROWS_DIR/$_since/state.json" 2>/dev/null) || _baseline="null"
        [ -z "$_baseline" ] && _baseline="null"
      fi
      if [ "$_baseline" = "null" ]; then
        printf 'pending'
        return 0
      fi
      _count=0
      if [ -d "$ROWS_DIR" ]; then
        for _sf in "$ROWS_DIR"/*/state.json; do
          [ -f "$_sf" ] || continue
          _row_name=$(basename "$(dirname "$_sf")")
          if [ -n "$_exclude_row" ] && [ "$_row_name" = "$_exclude_row" ]; then
            continue
          fi
          _a=$(jq -r '.archived_at // "null"' "$_sf" 2>/dev/null) || continue
          [ "$_a" = "null" ] && continue
          [ -z "$_a" ] && continue
          # Lexicographic string compare — valid under Z-normalized UTC invariant.
          if [ "$_a" \> "$_baseline" ]; then
            _count=$((_count + 1))
          fi
        done
      fi
      if [ "$_count" -ge "$_target" ]; then
        printf 'active'
      else
        printf 'pending'
      fi
      ;;
    manual)
      _manual_ts=$(printf '%s' "$_obs" | jq -r '.manual_activation_at // "null"')
      if [ "$_manual_ts" = "null" ] || [ -z "$_manual_ts" ]; then
        printf 'pending'
      else
        printf 'active'
      fi
      ;;
    *)
      printf 'pending'
      ;;
  esac
}

# Compute qualifying count for rows_since (helper for show).
_observe_rows_since_count() {
  _obs="$1"
  _since=$(printf '%s' "$_obs" | jq -r '.triggered_by.since_row')
  _baseline=$(jq -r '.archived_at // "null"' "$ROWS_DIR/$_since/state.json" 2>/dev/null) || _baseline="null"
  [ -z "$_baseline" ] && _baseline="null"
  if [ "$_baseline" = "null" ]; then
    printf '0'
    return 0
  fi
  _count=0
  if [ -d "$ROWS_DIR" ]; then
    for _sf in "$ROWS_DIR"/*/state.json; do
      [ -f "$_sf" ] || continue
      _a=$(jq -r '.archived_at // "null"' "$_sf" 2>/dev/null) || continue
      [ "$_a" = "null" ] && continue
      [ -z "$_a" ] && continue
      if [ "$_a" \> "$_baseline" ]; then
        _count=$((_count + 1))
      fi
    done
  fi
  printf '%s' "$_count"
}

_observe_rows_since_baseline() {
  _obs="$1"
  _since=$(printf '%s' "$_obs" | jq -r '.triggered_by.since_row')
  _baseline=$(jq -r '.archived_at // "null"' "$ROWS_DIR/$_since/state.json" 2>/dev/null) || _baseline="null"
  [ -z "$_baseline" ] && _baseline="null"
  printf '%s' "$_baseline"
}

# ------------------------------------------------------------
# observe add
# ------------------------------------------------------------
_observe_add() {
  _kind="" _title="" _trigger="" _row="" _since_row="" _count=""
  _signal="" _question="" _options="" _acceptance=""
  _source_work_unit=""
  _evidence=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --kind)             shift; _kind="${1:-}"; shift ;;
      --title)            shift; _title="${1:-}"; shift ;;
      --trigger)          shift; _trigger="${1:-}"; shift ;;
      --row)              shift; _row="${1:-}"; shift ;;
      --since-row)        shift; _since_row="${1:-}"; shift ;;
      --count)            shift; _count="${1:-}"; shift ;;
      --signal)           shift; _signal="${1:-}"; shift ;;
      --question)         shift; _question="${1:-}"; shift ;;
      --options)          shift; _options="${1:-}"; shift ;;
      --acceptance)       shift; _acceptance="${1:-}"; shift ;;
      --evidence)         shift; _evidence="${_evidence:+$_evidence|}${1:-}"; shift ;;
      --source-work-unit) shift; _source_work_unit="${1:-}"; shift ;;
      --help|-h)
        cat <<'USAGE'
Usage: alm observe add --kind <watch|decision-review> --title T --trigger <row_archived|rows_since|manual> [trigger-flags] [kind-flags] [--source-work-unit NAME]

Trigger flags:
  --trigger row_archived --row <name>
  --trigger rows_since --since-row <name> --count <int>
  --trigger manual

Kind flags:
  --kind watch:           --signal <text>
  --kind decision-review: --question <text> --options <csv|json> --acceptance <text> [--evidence <text> ...]
USAGE
        return 0
        ;;
      *) die "observe add: unknown flag: $1" 1 ;;
    esac
  done

  [ -n "$_kind" ]    || die "observe add: --kind is required" 1
  [ -n "$_title" ]   || die "observe add: --title is required" 1
  [ -n "$_trigger" ] || die "observe add: --trigger is required" 1

  case "$_kind" in
    watch|decision-review) ;;
    *) die "observe add: invalid --kind '$_kind' (watch|decision-review)" 1 ;;
  esac

  case "$_trigger" in
    row_archived|rows_since|manual) ;;
    *) die "observe add: invalid --trigger '$_trigger' (row_archived|rows_since|manual)" 1 ;;
  esac

  # Trigger-specific validation
  case "$_trigger" in
    row_archived)
      [ -n "$_row" ] || die "observe add: --row required when --trigger row_archived" 1
      ;;
    rows_since)
      [ -n "$_since_row" ] || die "observe add: --since-row required when --trigger rows_since" 1
      [ -n "$_count" ] || die "observe add: --count required when --trigger rows_since" 1
      case "$_count" in
        ''|*[!0-9]*) die "observe add: --count must be a positive integer" 1 ;;
      esac
      [ "$_count" -ge 1 ] || die "observe add: --count must be >= 1" 1
      ;;
  esac

  # Kind-specific validation
  case "$_kind" in
    watch)
      [ -n "$_signal" ] || die "observe add: --signal required when --kind watch" 1
      ;;
    decision-review)
      [ -n "$_question" ]   || die "observe add: --question required when --kind decision-review" 1
      [ -n "$_options" ]    || die "observe add: --options required when --kind decision-review" 1
      [ -n "$_acceptance" ] || die "observe add: --acceptance required when --kind decision-review" 1
      ;;
  esac

  _observe_ensure_file

  # Generate slug id
  _slug=$(slugify "$_title")
  [ -n "$_slug" ] || die "observe add: could not generate slug from title" 1
  # Truncate to 40 chars (tighter than slugify's 50 default)
  _slug=$(printf '%s' "$_slug" | cut -c1-40 | sed 's/-$//')

  _existing=$(_observe_load_json)
  _base_slug="$_slug"
  _suffix=1
  while printf '%s' "$_existing" | jq -e --arg id "$_slug" '.[] | select(.id == $id)' >/dev/null 2>&1; do
    _suffix=$((_suffix + 1))
    _slug="${_base_slug}-${_suffix}"
  done

  _ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)

  # Build triggered_by block
  case "$_trigger" in
    row_archived)
      _trig_json=$(jq -n --arg row "$_row" '{type: "row_archived", row: $row}')
      ;;
    rows_since)
      _trig_json=$(jq -n --arg since "$_since_row" --argjson c "$_count" '{type: "rows_since", since_row: $since, count: $c}')
      ;;
    manual)
      _trig_json='{"type":"manual"}'
      ;;
  esac

  # Build options JSON for decision-review (accept JSON array or CSV of "id:label" pairs)
  _options_json="[]"
  if [ -n "$_options" ]; then
    # Try JSON first
    if printf '%s' "$_options" | jq -e 'type == "array"' >/dev/null 2>&1; then
      _options_json="$_options"
    else
      # CSV form: "id1:label1,id2:label2" or "id1,id2" (label defaults to id)
      _options_json=$(printf '%s' "$_options" | tr ',' '\n' | jq -R '
        split(":") |
        if length >= 2 then {id: .[0], label: (.[1:] | join(":"))}
        else {id: .[0], label: .[0]}
        end
      ' | jq -s '.')
    fi
  fi

  # Build evidence array
  _evidence_json="[]"
  if [ -n "$_evidence" ]; then
    _evidence_json=$(printf '%s' "$_evidence" | tr '|' '\n' | jq -R '.' | jq -s '.')
  fi

  _entry=$(jq -n \
    --arg id "$_slug" \
    --arg kind "$_kind" \
    --arg title "$_title" \
    --argjson triggered_by "$_trig_json" \
    --arg created_at "$_ts" \
    --arg updated_at "$_ts" \
    --arg signal "$_signal" \
    --arg question "$_question" \
    --argjson options "$_options_json" \
    --arg acceptance "$_acceptance" \
    --argjson evidence "$_evidence_json" \
    --arg source_work_unit "$_source_work_unit" \
    '{
      id: $id,
      kind: $kind,
      title: $title,
      triggered_by: $triggered_by,
      lifecycle: "open",
      created_at: $created_at,
      updated_at: $updated_at
    }
    + (if $kind == "watch" then {signal: $signal} else {} end)
    + (if $kind == "decision-review" then {question: $question, options: $options, acceptance_criteria: $acceptance} else {} end)
    + (if $kind == "decision-review" and ($evidence | length) > 0 then {evidence_needed: $evidence} else {} end)
    + (if $source_work_unit != "" then {source_work_unit: $source_work_unit} else {} end)
    ')

  _new_array=$(printf '%s' "$_existing" | jq --argjson e "$_entry" '. + [$e]')

  if _observe_write_validated "$_new_array"; then
    printf 'added observation: %s\n' "$_slug"
  else
    return 2
  fi
}

# ------------------------------------------------------------
# observe list
# ------------------------------------------------------------
_observe_list() {
  _filter="active"
  _kind_filter=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --active)    _filter="active"; shift ;;
      --pending)   _filter="pending"; shift ;;
      --resolved)  _filter="resolved"; shift ;;
      --dismissed) _filter="dismissed"; shift ;;
      --all)       _filter="all"; shift ;;
      --kind)      shift; _kind_filter="${1:-}"; shift ;;
      --help|-h)
        printf 'Usage: alm observe list [--active | --pending | --resolved | --dismissed | --all] [--kind watch|decision-review]\n'
        return 0
        ;;
      *) die "observe list: unknown flag: $1" 1 ;;
    esac
  done

  _all=$(_observe_load_json)

  # Sort by created_at ascending; emit one tsv line per entry with computed activation.
  _sorted=$(printf '%s' "$_all" | jq -c 'sort_by(.created_at) | .[]')
  [ -z "$_sorted" ] && return 0

  printf '%s\n' "$_sorted" | while IFS= read -r _obs; do
    [ -z "$_obs" ] && continue
    _id=$(printf '%s' "$_obs" | jq -r '.id')
    _k=$(printf '%s' "$_obs" | jq -r '.kind')
    _lc=$(printf '%s' "$_obs" | jq -r '.lifecycle')
    _title=$(printf '%s' "$_obs" | jq -r '.title')

    # Apply kind filter
    if [ -n "$_kind_filter" ] && [ "$_k" != "$_kind_filter" ]; then
      continue
    fi

    # Compute activation only when useful
    _act="-"
    if [ "$_lc" = "open" ]; then
      _act=$(_observe_compute_activation "$_obs")
    fi

    # Apply lifecycle/activation filter
    case "$_filter" in
      active)
        [ "$_lc" = "open" ] && [ "$_act" = "active" ] || continue
        ;;
      pending)
        [ "$_lc" = "open" ] && [ "$_act" = "pending" ] || continue
        ;;
      resolved)
        [ "$_lc" = "resolved" ] || continue
        ;;
      dismissed)
        [ "$_lc" = "dismissed" ] || continue
        ;;
      all)
        ;;
    esac

    printf '%s\t%s\t%s\t%s\t%s\n' "$_id" "$_k" "$_lc" "$_act" "$_title"
  done
}

# ------------------------------------------------------------
# observe show
# ------------------------------------------------------------
_observe_show() {
  if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    printf 'Usage: alm observe show <id>\n'
    return 0
  fi
  [ -n "${1:-}" ] || die "observe show: <id> required" 1
  _id="$1"

  _all=$(_observe_load_json)
  _obs=$(printf '%s' "$_all" | jq -c --arg id "$_id" '.[] | select(.id == $id)')
  [ -n "$_obs" ] || die "observation not found: $_id" 2

  printf 'Observation: %s\n' "$(printf '%s' "$_obs" | jq -r '.id')"
  printf 'Kind: %s\n' "$(printf '%s' "$_obs" | jq -r '.kind')"
  printf 'Title: %s\n' "$(printf '%s' "$_obs" | jq -r '.title')"
  printf 'Lifecycle: %s\n' "$(printf '%s' "$_obs" | jq -r '.lifecycle')"
  printf 'Created: %s\n' "$(printf '%s' "$_obs" | jq -r '.created_at')"
  printf 'Updated: %s\n' "$(printf '%s' "$_obs" | jq -r '.updated_at')"

  _swu=$(printf '%s' "$_obs" | jq -r '.source_work_unit // empty')
  [ -n "$_swu" ] && printf 'Source Work Unit: %s\n' "$_swu"

  _trig_type=$(printf '%s' "$_obs" | jq -r '.triggered_by.type')
  printf 'Trigger: %s\n' "$_trig_type"
  case "$_trig_type" in
    row_archived)
      printf '  row: %s\n' "$(printf '%s' "$_obs" | jq -r '.triggered_by.row')"
      ;;
    rows_since)
      printf '  since_row: %s\n' "$(printf '%s' "$_obs" | jq -r '.triggered_by.since_row')"
      printf '  count: %s\n' "$(printf '%s' "$_obs" | jq -r '.triggered_by.count')"
      ;;
    manual)
      _mts=$(printf '%s' "$_obs" | jq -r '.manual_activation_at // empty')
      if [ -n "$_mts" ]; then
        printf '  manual_activation_at: %s\n' "$_mts"
      fi
      ;;
  esac

  _kind=$(printf '%s' "$_obs" | jq -r '.kind')
  case "$_kind" in
    watch)
      _sig=$(printf '%s' "$_obs" | jq -r '.signal // empty')
      [ -n "$_sig" ] && printf 'Signal: %s\n' "$_sig"
      ;;
    decision-review)
      _q=$(printf '%s' "$_obs" | jq -r '.question // empty')
      [ -n "$_q" ] && printf 'Question: %s\n' "$_q"
      _ac=$(printf '%s' "$_obs" | jq -r '.acceptance_criteria // empty')
      [ -n "$_ac" ] && printf 'Acceptance Criteria: %s\n' "$_ac"
      _opts=$(printf '%s' "$_obs" | jq -r 'if .options then .options[] | "  - " + .id + ": " + .label else empty end')
      if [ -n "$_opts" ]; then
        printf 'Options:\n'
        printf '%s\n' "$_opts"
      fi
      _ev=$(printf '%s' "$_obs" | jq -r 'if .evidence_needed then .evidence_needed[] | "  - " + . else empty end')
      if [ -n "$_ev" ]; then
        printf 'Evidence Needed:\n'
        printf '%s\n' "$_ev"
      fi
      ;;
  esac

  # Resolution / dismissal blocks
  _res=$(printf '%s' "$_obs" | jq -c '.resolution // empty')
  if [ -n "$_res" ]; then
    printf 'Resolution:\n'
    printf '%s\n' "$_res" | jq -r 'to_entries[] | "  " + .key + ": " + (.value | tostring)'
  fi
  _dis=$(printf '%s' "$_obs" | jq -c '.dismissal // empty')
  if [ -n "$_dis" ]; then
    printf 'Dismissal:\n'
    printf '%s\n' "$_dis" | jq -r 'to_entries[] | "  " + .key + ": " + (.value | tostring)'
  fi

  # Computed activation block
  _lc=$(printf '%s' "$_obs" | jq -r '.lifecycle')
  if [ "$_lc" = "open" ]; then
    _act=$(_observe_compute_activation "$_obs")
    printf '\nComputed:\n'
    printf '  activation: %s\n' "$_act"
    if [ "$_trig_type" = "rows_since" ]; then
      _qc=$(_observe_rows_since_count "$_obs")
      _tgt=$(printf '%s' "$_obs" | jq -r '.triggered_by.count')
      _bl=$(_observe_rows_since_baseline "$_obs")
      printf '  qualifying_archived_rows: %s / target: %s\n' "$_qc" "$_tgt"
      if [ "$_bl" = "null" ]; then
        printf '  baseline: not archived yet\n'
      else
        printf '  baseline: %s\n' "$_bl"
      fi
    fi
  fi
}

# ------------------------------------------------------------
# observe resolve
# ------------------------------------------------------------
_observe_resolve() {
  if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    cat <<'USAGE'
Usage:
  alm observe resolve <id> --outcome <pass|fail|inconclusive> [--note <text>]   (watch)
  alm observe resolve <id> --option <option-id> --rationale <text>             (decision-review)
USAGE
    return 0
  fi
  [ -n "${1:-}" ] || die "observe resolve: <id> required" 1
  _id="$1"; shift

  _outcome="" _note="" _option="" _rationale=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --outcome)   shift; _outcome="${1:-}"; shift ;;
      --note)      shift; _note="${1:-}"; shift ;;
      --option)    shift; _option="${1:-}"; shift ;;
      --rationale) shift; _rationale="${1:-}"; shift ;;
      *) die "observe resolve: unknown flag: $1" 1 ;;
    esac
  done

  _all=$(_observe_load_json)
  _obs=$(printf '%s' "$_all" | jq -c --arg id "$_id" '.[] | select(.id == $id)')
  [ -n "$_obs" ] || die "observation not found: $_id" 2

  _lc=$(printf '%s' "$_obs" | jq -r '.lifecycle')
  [ "$_lc" = "open" ] || { printf 'cannot resolve: lifecycle is %s\n' "$_lc" >&2; return 2; }

  _kind=$(printf '%s' "$_obs" | jq -r '.kind')
  case "$_kind" in
    watch)
      if [ -n "$_option" ] || [ -n "$_rationale" ]; then
        printf 'use --outcome/--note for watch observations\n' >&2
        return 2
      fi
      [ -n "$_outcome" ] || die "observe resolve: --outcome required for watch" 1
      case "$_outcome" in
        pass|fail|inconclusive) ;;
        *) die "observe resolve: invalid --outcome '$_outcome' (pass|fail|inconclusive)" 1 ;;
      esac
      ;;
    decision-review)
      if [ -n "$_outcome" ] || [ -n "$_note" ]; then
        printf 'use --option/--rationale for decision-review observations\n' >&2
        return 2
      fi
      [ -n "$_option" ]    || die "observe resolve: --option required for decision-review" 1
      [ -n "$_rationale" ] || die "observe resolve: --rationale required for decision-review" 1
      # Validate option id exists in observation's options list
      _match=$(printf '%s' "$_obs" | jq --arg oid "$_option" '[.options[]? | select(.id == $oid)] | length')
      if [ "${_match:-0}" -lt 1 ]; then
        printf 'observe resolve: option "%s" not in observation options\n' "$_option" >&2
        return 2
      fi
      ;;
  esac

  _ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)

  case "$_kind" in
    watch)
      _res_json=$(jq -n --arg outcome "$_outcome" --arg note "$_note" --arg ts "$_ts" '
        {outcome: $outcome, resolved_at: $ts}
        + (if $note != "" then {note: $note} else {} end)
      ')
      ;;
    decision-review)
      _res_json=$(jq -n --arg opt "$_option" --arg rat "$_rationale" --arg ts "$_ts" '
        {option_id: $opt, rationale: $rat, resolved_at: $ts}
      ')
      ;;
  esac

  _new_array=$(printf '%s' "$_all" | jq \
    --arg id "$_id" \
    --arg ts "$_ts" \
    --argjson res "$_res_json" '
    map(if .id == $id then
      .lifecycle = "resolved"
      | .resolution = $res
      | .updated_at = $ts
    else . end)
  ')

  if _observe_write_validated "$_new_array"; then
    printf 'resolved observation: %s\n' "$_id"
  else
    return 2
  fi
}

# ------------------------------------------------------------
# observe dismiss
# ------------------------------------------------------------
_observe_dismiss() {
  if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    printf 'Usage: alm observe dismiss <id> [--reason <text>]\n'
    return 0
  fi
  [ -n "${1:-}" ] || die "observe dismiss: <id> required" 1
  _id="$1"; shift

  _reason=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --reason) shift; _reason="${1:-}"; shift ;;
      *) die "observe dismiss: unknown flag: $1" 1 ;;
    esac
  done

  _all=$(_observe_load_json)
  _obs=$(printf '%s' "$_all" | jq -c --arg id "$_id" '.[] | select(.id == $id)')
  [ -n "$_obs" ] || die "observation not found: $_id" 2

  _lc=$(printf '%s' "$_obs" | jq -r '.lifecycle')
  [ "$_lc" = "open" ] || { printf 'cannot dismiss: lifecycle is %s\n' "$_lc" >&2; return 2; }

  _ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  _dis_json=$(jq -n --arg r "$_reason" --arg ts "$_ts" '
    {dismissed_at: $ts}
    + (if $r != "" then {reason: $r} else {} end)
  ')

  _new_array=$(printf '%s' "$_all" | jq \
    --arg id "$_id" \
    --arg ts "$_ts" \
    --argjson dis "$_dis_json" '
    map(if .id == $id then
      .lifecycle = "dismissed"
      | .dismissal = $dis
      | .updated_at = $ts
    else . end)
  ')

  if _observe_write_validated "$_new_array"; then
    printf 'dismissed observation: %s\n' "$_id"
  else
    return 2
  fi
}

# ------------------------------------------------------------
# observe activate
# ------------------------------------------------------------
_observe_activate() {
  if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    printf 'Usage: alm observe activate <id>\n'
    return 0
  fi
  [ -n "${1:-}" ] || die "observe activate: <id> required" 1
  _id="$1"

  _all=$(_observe_load_json)
  _obs=$(printf '%s' "$_all" | jq -c --arg id "$_id" '.[] | select(.id == $id)')
  [ -n "$_obs" ] || die "observation not found: $_id" 2

  _trig_type=$(printf '%s' "$_obs" | jq -r '.triggered_by.type')
  if [ "$_trig_type" != "manual" ]; then
    printf 'cannot activate: trigger type is %s; activate only works on manual triggers\n' "$_trig_type" >&2
    return 2
  fi

  _existing_ts=$(printf '%s' "$_obs" | jq -r '.manual_activation_at // empty')
  if [ -n "$_existing_ts" ]; then
    printf 'already activated at %s\n' "$_existing_ts" >&2
    return 0
  fi

  _ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  _new_array=$(printf '%s' "$_all" | jq \
    --arg id "$_id" \
    --arg ts "$_ts" '
    map(if .id == $id then
      .manual_activation_at = $ts
      | .updated_at = $ts
    else . end)
  ')

  if _observe_write_validated "$_new_array"; then
    printf 'activated observation: %s\n' "$_id"
  else
    return 2
  fi
}

# ------------------------------------------------------------
# observe on-archive — STATELESS display helper
# ------------------------------------------------------------
_observe_on_archive() {
  if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    printf 'Usage: alm observe on-archive <row-name>\n'
    printf '  Print observations newly activated by archive of <row>. No state mutation.\n'
    return 0
  fi
  [ -n "${1:-}" ] || die "observe on-archive: <row-name> required" 1
  _row="$1"

  _state_file="$ROWS_DIR/$_row/state.json"
  _archived_at="null"
  if [ -f "$_state_file" ]; then
    _archived_at=$(jq -r '.archived_at // "null"' "$_state_file" 2>/dev/null) || _archived_at="null"
    [ -z "$_archived_at" ] && _archived_at="null"
  fi
  if [ "$_archived_at" = "null" ]; then
    printf 'row %s is not archived yet\n' "$_row" >&2
    return 1
  fi

  _all=$(_observe_load_json)
  _open=$(printf '%s' "$_all" | jq -c '.[] | select(.lifecycle == "open")')

  _any=0
  _out_tmp=$(mktemp)
  if [ -n "$_open" ]; then
    printf '%s\n' "$_open" | while IFS= read -r _obs; do
      [ -z "$_obs" ] && continue
      _with=$(_observe_compute_activation "$_obs" "")
      _without=$(_observe_compute_activation "$_obs" "$_row")
      if [ "$_with" = "active" ] && [ "$_without" = "pending" ]; then
        _id=$(printf '%s' "$_obs" | jq -r '.id')
        _k=$(printf '%s' "$_obs" | jq -r '.kind')
        _title=$(printf '%s' "$_obs" | jq -r '.title')
        _tt=$(printf '%s' "$_obs" | jq -r '.triggered_by.type')
        case "$_tt" in
          row_archived)
            _reason="row_archived: $(printf '%s' "$_obs" | jq -r '.triggered_by.row') archived"
            ;;
          rows_since)
            _tgt=$(printf '%s' "$_obs" | jq -r '.triggered_by.count')
            _since=$(printf '%s' "$_obs" | jq -r '.triggered_by.since_row')
            _reason="rows_since: $_tgt rows archived after $_since"
            ;;
          *)
            _reason="$_tt"
            ;;
        esac
        printf 'id: %s\n' "$_id" >> "$_out_tmp"
        printf '  kind: %s\n' "$_k" >> "$_out_tmp"
        printf '  title: %s\n' "$_title" >> "$_out_tmp"
        printf '  activation_reason: %s\n' "$_reason" >> "$_out_tmp"
      fi
    done
  fi

  if [ -s "$_out_tmp" ]; then
    cat "$_out_tmp"
    _any=1
  fi
  rm -f "$_out_tmp"

  if [ "$_any" -eq 0 ]; then
    printf 'no observations activated by archive of %s\n' "$_row"
  fi
  return 0
}

