{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Work Definition",
  "description": "Schema for definition.yaml — the work contract for a Furrow row.",
  "type": "object",
  "required": ["objective", "deliverables", "context_pointers", "constraints", "gate_policy"],
  "additionalProperties": false,
  "properties": {
    "objective": {
      "type": "string",
      "description": "One-sentence goal statement"
    },
    "deliverables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "acceptance_criteria"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
            "description": "Kebab-case identifier, unique within definition"
          },
          "acceptance_criteria": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "specialist": {
            "type": "string",
            "description": "Domain specialist type (e.g., api-designer)"
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Array of deliverable names this depends on"
          },
          "file_ownership": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Glob patterns for files owned by this deliverable"
          },
          "gate": {
            "type": "string",
            "enum": ["human", "automated"],
            "description": "Per-deliverable gate override"
          }
        }
      }
    },
    "context_pointers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "note"],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "description": "Relative path to file or directory"
          },
          "symbols": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Symbol names within the file"
          },
          "note": {
            "type": "string",
            "description": "Why this context matters"
          }
        }
      }
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "gate_policy": {
      "type": "string",
      "enum": ["supervised", "delegated", "autonomous"],
      "description": "Trust gradient level"
    },
    "mode": {
      "type": "string",
      "enum": ["code", "research"],
      "default": "code",
      "description": "Work mode — code (default) or research"
    },
    "source_todo": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
      "description": "ID of the TODO entry this row was created from (legacy single-TODO form; use source_todos for multi-TODO rows)"
    },
    "source_todos": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$"
      },
      "description": "IDs of the TODO entries this row consolidates. Use for multi-TODO rows (e.g., roadmap phase bundles). Mutually exclusive with source_todo."
    },
    "supersedes": {
      "type": "object",
      "description": "Declares that this row's work was superseded by a sibling row before completion. Presence triggers archive-time supersedence confirmation.",
      "required": ["commit", "row"],
      "additionalProperties": false,
      "properties": {
        "commit": {
          "type": "string",
          "description": "Short or full SHA of the commit that contains the superseding work"
        },
        "row": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
          "description": "Kebab-case name of the row whose work supersedes this one"
        }
      }
    }
  }
}
