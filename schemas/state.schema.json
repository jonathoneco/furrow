{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "state.schema.json",
  "$comment": "See .furrow/almanac/rationale.yaml for component rationale",
  "title": "Row State",
  "description": "Lifecycle and progress tracking for a Furrow row. Furrow-exclusive write — agents never write this file directly.",
  "type": "object",
  "required": [
    "name",
    "title",
    "description",
    "step",
    "step_status",
    "steps_sequence",
    "deliverables",
    "gates",
    "pending_user_actions",
    "force_stop_at",
    "branch",
    "mode",
    "base_commit",
    "seed_id",
    "created_at",
    "updated_at",
    "archived_at"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
      "description": "Kebab-case identifier matching the row directory name"
    },
    "title": {
      "type": "string",
      "description": "Human-readable title"
    },
    "description": {
      "type": "string",
      "description": "One-sentence summary"
    },
    "step": {
      "type": "string",
      "enum": ["ideate", "research", "plan", "spec", "decompose", "implement", "review"],
      "description": "Current step in the lifecycle"
    },
    "step_status": {
      "type": "string",
      "enum": ["not_started", "in_progress", "completed", "blocked"],
      "description": "Status of the current step"
    },
    "steps_sequence": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["ideate", "research", "plan", "spec", "decompose", "implement", "review"]
      },
      "minItems": 7,
      "maxItems": 7,
      "description": "Fixed ordered sequence of all steps"
    },
    "deliverables": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["status", "assigned_to", "wave", "corrections"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["not_started", "in_progress", "completed", "blocked"]
          },
          "assigned_to": {
            "type": ["string", "null"]
          },
          "wave": {
            "type": "integer",
            "minimum": 0
          },
          "corrections": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      },
      "description": "Map of deliverable names to their status objects"
    },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["boundary", "outcome", "decided_by", "evidence", "timestamp"],
        "properties": {
          "boundary": {
            "type": "string",
            "pattern": "^(ideate|research|plan|spec|decompose|implement|review)->(ideate|research|plan|spec|decompose|implement|review)$",
            "description": "Format: {from_step}->{to_step}"
          },
          "outcome": {
            "type": "string",
            "enum": ["pass", "fail", "conditional"]
          },
          "decided_by": {
            "type": "string",
            "enum": ["manual", "evaluated", "prechecked"]
          },
          "evidence": {
            "type": "string",
            "minLength": 1,
            "description": "One-line summary of proof or path to gate file"
          },
          "conditions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Present only when outcome is conditional"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp"
          }
        },
        "additionalProperties": false,
        "if": {
          "properties": {
            "outcome": { "const": "conditional" }
          }
        },
        "then": {
          "required": ["conditions"]
        }
      },
      "description": "Append-only array of gate records"
    },
    "pending_user_actions": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "required": ["id", "instructions", "created_at"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "instructions": { "type": "string", "minLength": 1 },
          "created_at": { "type": "string" },
          "completed_at": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      },
      "description": "User actions that must be completed before step transitions"
    },
    "force_stop_at": {
      "type": ["string", "null"],
      "description": "Step name to prevent auto-advance at, or null"
    },
    "branch": {
      "type": ["string", "null"],
      "description": "Git branch name or null"
    },
    "mode": {
      "type": "string",
      "enum": ["code", "research"],
      "description": "Mirrors definition.yaml mode field"
    },
    "base_commit": {
      "type": "string",
      "description": "Git SHA at row creation"
    },
    "seed_id": {
      "type": "string",
      "description": "Seeds tracker ID (from sds)"
    },
    "epic_seed_id": {
      "type": ["string", "null"],
      "description": "Epic seed ID or null"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 creation timestamp"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 last-mutation timestamp"
    },
    "archived_at": {
      "type": ["string", "null"],
      "description": "ISO 8601 archive timestamp or null"
    },
    "source_todo": {
      "type": ["string", "null"],
      "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
      "description": "TODO entry ID this row was created from, or null (legacy singular form; prefer source_todos for new rows)"
    },
    "source_todos": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$"
      },
      "description": "TODO entry IDs this row consolidates. Copied verbatim from definition.yaml source_todos on row init. If definition uses legacy source_todo (singular), this array contains that single id. Optional field for back-compat with pre-2f state files."
    },
    "gate_policy_init": {
      "type": ["string", "null"],
      "enum": ["supervised", "delegated", "autonomous", null],
      "description": "Init-time gate policy hint for ideate step, or null"
    }
  },
  "additionalProperties": false
}
