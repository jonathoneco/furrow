{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Execution Plan",
  "description": "Schema for plan.json — execution plan with wave assignments per spec 00 §1.3",
  "type": "object",
  "required": ["waves", "created_at", "created_by"],
  "properties": {
    "waves": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["wave", "deliverables", "assignments"],
        "properties": {
          "wave": {
            "type": "integer",
            "minimum": 1,
            "description": "Wave number, 1-indexed, sequential"
          },
          "deliverables": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" },
            "description": "Array of deliverable names from definition.yaml"
          },
          "assignments": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "required": ["specialist", "file_ownership"],
              "properties": {
                "specialist": {
                  "type": "string",
                  "description": "Specialist type"
                },
                "file_ownership": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Glob patterns"
                },
                "skills": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Optional skill names to inject"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601"
    },
    "created_by": {
      "type": "string",
      "description": "Agent identifier"
    }
  },
  "additionalProperties": false
}
